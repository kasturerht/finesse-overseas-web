---
// src/components/Navbar.astro
const navLinks = [
  { name: "Home", url: "/" },
  { name: "Destinations", url: "#" },
  { name: "Services", url: "#" },
  { name: "Success Stories", url: "#" },
  { name: "Contact", url: "/contact" }
];

const currentPath = Astro.url.pathname;
const isDarkTheme = currentPath.includes('mbbs');

// --- Dynamic Theme Logic (Fixed) ---
const headerBg = isDarkTheme 
  ? 'bg-[#030712]/80 border-white/[0.05] shadow-[0_8px_32px_rgba(0,0,0,0.5)]' 
  : 'bg-white/90 border-slate-200 shadow-sm';

const logoFilter = isDarkTheme ? 'brightness-0 invert opacity-90' : '';
const linkColor = isDarkTheme ? 'text-slate-300 hover:text-teal-400' : 'text-slate-600 hover:text-teal-600';
const btnClass = isDarkTheme
  ? 'bg-white/5 hover:bg-white/10 text-white border border-white/10'
  : 'bg-teal-600 hover:bg-teal-700 text-white';
---

<header class={`sticky top-0 z-[100] w-full backdrop-blur-xl border-b transition-all duration-500 ${headerBg}`}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-20">
      
      <div class="flex-shrink-0 flex items-center transition-opacity duration-300">
        <a href="/" class="flex items-center">
          <img src="/logo.png" alt="Finesse Logo" class={`h-10 md:h-12 w-auto object-contain ${logoFilter}`} />
        </a>
      </div>

      <nav class="hidden md:flex space-x-8">
        {navLinks.map((link) => (
          <a href={link.url} class={`text-sm font-bold uppercase tracking-widest transition-colors ${linkColor}`}>
            {link.name}
          </a>
        ))}
      </nav>

      <div class="hidden md:flex items-center">
        <a href="#consultation" class={`px-6 py-2.5 rounded-xl font-bold text-xs tracking-widest uppercase transition-all ${btnClass}`}>
          Book Audit
        </a>
      </div>
    </div>
  </div>
</header>