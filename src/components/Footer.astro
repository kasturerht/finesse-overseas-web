---
// src/components/Footer.astro
const year = new Date().getFullYear();
---

<footer class="bg-slate-50 pt-12 pb-6 relative overflow-hidden" id="footer">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <div class="bg-teal-600 rounded-[2.5rem] p-10 md:p-16 mb-20 relative overflow-hidden shadow-[0_30px_60px_-15px_rgba(13,148,136,0.3)]">
      <div class="absolute top-0 right-0 -mr-20 -mt-20 w-[400px] h-[400px] rounded-full bg-teal-400 blur-3xl opacity-50 mix-blend-screen pointer-events-none"></div>
      <div class="absolute bottom-0 left-0 -ml-20 -mb-20 w-[300px] h-[300px] rounded-full bg-teal-800 blur-3xl opacity-40 mix-blend-multiply pointer-events-none"></div>
      
      <div class="relative z-10 flex flex-col lg:flex-row justify-between items-center gap-10 text-white">
        <div class="max-w-2xl text-center lg:text-left">
          <span class="inline-block px-4 py-1.5 bg-white/10 backdrop-blur-md rounded-full text-xs font-black uppercase tracking-widest border border-white/20 mb-6">
            Your Global Journey
          </span>
          <h2 class="text-4xl md:text-5xl font-black mb-4 leading-tight tracking-tight">
            Stop worrying about the paperwork.
          </h2>
          <p class="text-teal-50 text-lg font-medium max-w-xl mx-auto lg:mx-0">
            Let our experts build a frictionless pathway to your dream university in Germany or Italy.
          </p>
        </div>
        
        <a href="/contact" class="group relative inline-flex items-center justify-center px-8 py-5 font-bold text-teal-900 bg-white rounded-full overflow-hidden transition-all hover:scale-105 hover:shadow-2xl duration-300 shrink-0">
          <span class="relative flex items-center gap-2">
            Book Free Consultation
            <svg class="w-5 h-5 transform group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
          </span>
        </a>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-12 gap-12 lg:gap-8 mb-20 px-4 md:px-8">
      
      <div class="lg:col-span-4 flex flex-col justify-between">
        <div>
          <img loading="lazy" decoding="async" src="/logo_finesse.png" alt="Finesse Overseas Education" class="h-10 w-auto mb-8" />
          <p class="text-slate-500 text-sm font-medium leading-relaxed max-w-xs mb-8">
            Empowering the youth with 22+ years of on-ground expertise. We navigate the complex European education systems so you don't have to.
          </p>
        </div>
        <div class="flex gap-3">
          <span class="px-3 py-1.5 bg-slate-200 text-slate-700 rounded-lg text-[10px] font-bold uppercase tracking-widest shadow-sm">ICEF Trained</span>
          <span class="px-3 py-1.5 bg-slate-200 text-slate-700 rounded-lg text-[10px] font-bold uppercase tracking-widest shadow-sm">22+ Years EXP</span>
        </div>
      </div>

      <div class="lg:col-span-2 lg:col-start-6">
        <h4 class="text-slate-900 font-black mb-6 uppercase tracking-widest text-xs">Destinations</h4>
        <ul class="space-y-4 text-sm font-bold text-slate-500">
          <li><a href="/study-in-germany" class="hover:text-teal-600 transition-colors flex items-center gap-2">Study in Germany</a></li>
          <li><a href="/study-in-italy" class="hover:text-teal-600 transition-colors flex items-center gap-2">Study in Italy</a></li>
          <li><a href="#" class="hover:text-teal-600 transition-colors flex items-center gap-2">Study in Austria</a></li>
        </ul>
      </div>

      <div class="lg:col-span-2">
        <h4 class="text-slate-900 font-black mb-6 uppercase tracking-widest text-xs">Expertise</h4>
        <ul class="space-y-4 text-sm font-bold text-slate-500">
          <li><a href="#" class="hover:text-teal-600 transition-colors">University Strategy</a></li>
          <li><a href="#" class="hover:text-teal-600 transition-colors">APS & Visa Processing</a></li>
          <li><a href="#" class="hover:text-teal-600 transition-colors">Scholarship Filing</a></li>
        </ul>
      </div>

      <div class="lg:col-span-3">
        <h4 class="text-slate-900 font-black mb-6 uppercase tracking-widest text-xs">Headquarters</h4>
        <ul class="space-y-4 text-sm font-bold text-slate-500">
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-teal-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
            <span class="leading-relaxed">Sakshi Samarth Plaza, First Floor, Above Sohala Showroom, Beside Lenskart, 4th Lane, Rajarampuri, Kolhapur.</span>
          </li>
          <li class="flex items-center gap-3 pt-2">
            <svg class="w-4 h-4 text-teal-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
            <a href="tel:+919850069600" class="hover:text-teal-600 transition-colors text-slate-800">+91 98500 69600</a>
          </li>
          <li class="flex items-center gap-3">
            <svg class="w-4 h-4 text-teal-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
            <a href="mailto:contact@finesseoverseas.com" class="hover:text-teal-600 transition-colors text-slate-800 break-words">contact@finesse.com</a>
          </li>
        </ul>
      </div>

    </div>

    <div class="pt-8 border-t border-slate-200/60 flex flex-col md:flex-row justify-between items-center gap-4 px-4 md:px-8">
      <p class="text-[10px] uppercase tracking-widest font-bold text-slate-400">
        © {year} Finesse Overseas Education. All rights reserved.
      </p>
      <div class="flex items-center gap-2 text-[10px] font-bold uppercase tracking-widest text-slate-400">
        <span>Made with</span>
        <svg class="w-3 h-3 text-red-500 fill-current" viewBox="0 0 20 20"><path d="M3.172 5.172a4 4 0 015.656 0L10 6.343l1.172-1.171a4 4 0 115.656 5.656L10 17.657l-6.828-6.829a4 4 0 010-5.656z"></path></svg>
        <span>in Kolhapur</span>
      </div>
    </div>

  </div>
</footer>