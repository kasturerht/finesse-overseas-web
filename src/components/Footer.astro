---
// src/components/Footer.astro
const year = new Date().getFullYear();

const destinations = [
  { name: 'Study in Germany', href: '/study-in-germany' },
  { name: 'Study in Italy', href: '/study-in-italy' },
  { name: 'MBBS Abroad', href: '/mbbs-India-abroad' },
  { name: 'Study in Austria', href: '/study-in-austria' }
];

const expertise = [
  { name: 'University Strategy', href: '/#services' },
  { name: 'APS & Visa Processing', href: '/#services' },
  { name: 'Scholarship Filing', href: '/#services' },
  { name: 'The Audit Vault', href: '/intelligence' }
];

// 🌟 The 3-Theme Architecture 
const { hideCTA = false, theme = 'light' } = Astro.props;

let bgClass = 'bg-slate-50';
let textClass = 'text-slate-500';
let headingClass = 'text-slate-900';
let borderClass = 'border-slate-200/60';
let badgeClass = 'bg-white border border-slate-200 text-slate-700 shadow-sm';
let iconClass = 'text-teal-500';
let linkHoverClass = 'group-hover:text-teal-600';
let ctaBg = 'bg-teal-900';
let ctaGlow = 'bg-teal-500';

if (theme === 'dark') { // 🇮🇹 For Italy
  bgClass = 'bg-[#050B14]';
  textClass = 'text-slate-400';
  headingClass = 'text-white';
  borderClass = 'border-white/10';
  badgeClass = 'bg-white/5 border border-white/10 text-slate-300';
  iconClass = 'text-amber-500';
  linkHoverClass = 'group-hover:text-amber-400';
  ctaBg = 'bg-[#0a1120] border border-white/10';
  ctaGlow = 'bg-amber-500';
} else if (theme === 'blue') { // 🇩🇪 For Germany
  bgClass = 'bg-slate-950';
  textClass = 'text-slate-400';
  headingClass = 'text-white';
  borderClass = 'border-white/10';
  badgeClass = 'bg-white/5 border border-white/10 text-slate-300';
  iconClass = 'text-blue-500';
  linkHoverClass = 'group-hover:text-blue-400';
  ctaBg = 'bg-slate-900 border border-white/10';
  ctaGlow = 'bg-blue-600';
} else if (theme === 'red') { // 🇦🇹 For Austria
  bgClass = 'bg-[#050505]';
  textClass = 'text-slate-400';
  headingClass = 'text-white';
  borderClass = 'border-white/5';
  badgeClass = 'bg-white/5 border border-white/10 text-slate-300';
  iconClass = 'text-red-500';
  linkHoverClass = 'group-hover:text-red-400';
  ctaBg = 'bg-[#111] border border-white/10';
  ctaGlow = 'bg-red-600';
}
---

<footer class={`${bgClass} pt-16 pb-8 relative overflow-hidden transition-colors duration-700`} id="footer">
  
  {/* 🌟 THE GIANT WATERMARK (Fixed opacity for better visibility) */}
  <div class="absolute bottom-0 left-0 w-full overflow-hidden flex justify-center pointer-events-none select-none opacity-[0.03] z-0">
    <div class="text-[18vw] font-black leading-[0.75] tracking-tighter text-current" aria-hidden="true">FINESSE</div>
  </div>

  <div class="max-w-[1400px] mx-auto px-6 lg:px-12 relative z-10">
    
    {/* --- THE CTA BLOCK --- */}
    {!hideCTA && (
      <div class={`relative rounded-[2rem] md:rounded-[3rem] p-10 md:p-16 mb-24 overflow-hidden shadow-2xl ${ctaBg}`}>
        <div class={`absolute top-0 right-0 -mr-20 -mt-20 w-[500px] h-[500px] rounded-full ${ctaGlow} blur-[120px] opacity-20 pointer-events-none animate-pulse`}></div>
        <div class="absolute bottom-0 left-0 -ml-20 -mb-20 w-[400px] h-[400px] rounded-full bg-white blur-[100px] opacity-5 pointer-events-none"></div>
        <div class="absolute inset-0 bg-[url('/noise.svg')] opacity-10 mix-blend-overlay pointer-events-none"></div>
        
        <div class="relative z-10 flex flex-col lg:flex-row justify-between items-center gap-12 text-white">
          <div class="max-w-3xl text-center lg:text-left">
            <span class="inline-flex items-center gap-3 px-5 py-2 bg-white/5 backdrop-blur-md rounded-full text-[11px] font-black uppercase tracking-[0.2em] border border-white/10 mb-8 shadow-xl">
              <span class={`w-2 h-2 rounded-full ${ctaGlow} animate-ping absolute`}></span>
              <span class={`w-2 h-2 rounded-full ${ctaGlow} relative`}></span>
              Your Global Journey
            </span>
            <h2 class="text-4xl md:text-5xl lg:text-6xl font-black mb-6 leading-[1.1] tracking-tight">
              Stop worrying about the <br class="hidden lg:block"/> 
              <span class="text-transparent bg-clip-text bg-gradient-to-r from-white to-white/50">complex paperwork.</span>
            </h2>
            <p class="text-white/70 text-lg md:text-xl font-medium max-w-xl mx-auto lg:mx-0 leading-relaxed">
              Let our experts build a frictionless pathway to your dream university abroad. We handle the maze, you handle the bags.
            </p>
          </div>
          
          <a href="/contact" class="group relative inline-flex items-center justify-center px-10 py-6 font-black text-slate-900 bg-white rounded-full overflow-hidden transition-all duration-500 hover:scale-[1.02] hover:shadow-[0_0_40px_rgba(255,255,255,0.3)] shrink-0">
            <span class="absolute w-0 h-0 transition-all duration-500 ease-out bg-slate-100 rounded-full group-hover:w-full group-hover:h-56"></span>
            <span class="relative flex items-center gap-3 text-lg">
              Book Free Consultation
              <svg class="w-6 h-6 transform group-hover:translate-x-2 transition-transform duration-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
            </span>
          </a>
        </div>
      </div>
    )}

    {/* --- MAIN FOOTER CONTENT (FIXED 12-COLUMN GRID) --- */}
    {/* 🚀 Changed to gap-y-16 lg:gap-x-8 to ensure exact horizontal fit */}
    <div class={`grid grid-cols-1 md:grid-cols-2 lg:grid-cols-12 gap-y-16 lg:gap-x-8 ${hideCTA ? 'mt-12' : ''} mb-24`}>
      
      {/* 1. Brand Column (Takes 4 columns) */}
      <div class="lg:col-span-4 flex flex-col justify-start lg:pr-8">
        
        {/* 🚀 FIXED LOGO: Removed the terrible invert filter. Kept it clean and natural. */}
        <div class="mb-8 relative inline-block">
          <img 
            src="/logo_finesse.png" 
            alt="Finesse Overseas Education" 
            loading="lazy" 
            decoding="async" 
            class="h-12 md:h-16 w-auto object-contain" 
          />
        </div>
        
        <p class={`${textClass} text-base md:text-lg font-medium leading-[1.8] max-w-sm mb-10 transition-colors`}>
          Kolhapur's most trusted study abroad & overseas education consultants with 22+ years of on-ground expertise. We navigate the complex European education systems so you don't have to.
        </p>
        
        <div class="flex flex-wrap gap-3 mb-8">
          <span class={`inline-flex items-center px-4 py-2 ${badgeClass} rounded-xl text-[10px] font-black uppercase tracking-widest transition-colors`}>
            On-Ground Expertise
          </span>
          <span class={`inline-flex items-center px-4 py-2 ${badgeClass} rounded-xl text-[10px] font-black uppercase tracking-widest transition-colors`}>
            EST. 2004
          </span>
        </div>

        {/* 🌟 PREMIUM SOCIAL MEDIA ICONS INTEGRATION */}
        <div class="flex gap-4 items-center">
          <a href="https://www.facebook.com/FinesseOverseasEducation" target="_blank" rel="noopener noreferrer" class={`group flex items-center justify-center w-10 h-10 rounded-full transition-all duration-300 ${theme === 'light' ? 'bg-white border border-slate-200/60 text-slate-500 hover:text-teal-600 hover:border-teal-200 shadow-sm hover:scale-105 active:scale-95' : 'bg-white/5 border border-white/10 text-slate-400 hover:text-teal-400 hover:border-white/20 hover:scale-105 active:scale-95'}`} aria-label="Facebook">
            <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24">
              <path d="M22 12c0-5.52-4.48-10-10-10S2 6.48 2 12c0 4.84 3.44 8.87 8 9.8V15H8v-3h2V9.5C10 7.57 11.57 6 13.5 6H16v3h-2c-.55 0-1 .45-1 1v2h3v3h-3v6.95c4.56-.93 8-4.96 8-9.75z"/>
            </svg>
          </a>
          <a href="https://www.instagram.com/finesseoverseaseducation/" target="_blank" rel="noopener noreferrer" class={`group flex items-center justify-center w-10 h-10 rounded-full transition-all duration-300 ${theme === 'light' ? 'bg-white border border-slate-200/60 text-slate-500 hover:text-teal-600 hover:border-teal-200 shadow-sm hover:scale-105 active:scale-95' : 'bg-white/5 border border-white/10 text-slate-400 hover:text-teal-400 hover:border-white/20 hover:scale-105 active:scale-95'}`} aria-label="Instagram">
            <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.051.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
            </svg>
          </a>
          <a href="https://youtube.com/@finesseoverseaseducation1272?si=BCKfbpbBlf8PM86L" target="_blank" rel="noopener noreferrer" class={`group flex items-center justify-center w-10 h-10 rounded-full transition-all duration-300 ${theme === 'light' ? 'bg-white border border-slate-200/60 text-slate-500 hover:text-teal-600 hover:border-teal-200 shadow-sm hover:scale-105 active:scale-95' : 'bg-white/5 border border-white/10 text-slate-400 hover:text-teal-400 hover:border-white/20 hover:scale-105 active:scale-95'}`} aria-label="YouTube">
            <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24">
              <path d="M23.498 6.163a3.003 3.003 0 00-2.11-2.107C19.53 3.5 12 3.5 12 3.5s-7.53 0-9.388.556a3.003 3.003 0 00-2.11 2.107C0 8.028 0 12 0 12s0 3.972.502 5.837a3.003 3.003 0 002.11 2.107C4.47 20.5 12 20.5 12 20.5s7.53 0 9.388-.556a3.003 3.003 0 002.11-2.107C24 15.972 24 12 24 12s0-3.972-.502-5.837zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
            </svg>
          </a>
        </div>
      </div>

      {/* 2. Destinations Column (Takes 2 columns) */}
      <div class="lg:col-span-2">
        <h4 class={`${headingClass} font-black mb-8 uppercase tracking-[0.2em] text-[11px] transition-colors opacity-80`}>Destinations</h4>
        <ul class="space-y-5">
          {destinations.map((item) => (
            <li class="group flex">
              <a href={item.href} class="flex items-center text-base font-bold transition-all duration-300">
                <span class={`w-0 overflow-hidden group-hover:w-5 transition-all duration-300 ease-out ${iconClass} flex items-center`}>
                  <span class="block -translate-x-full group-hover:translate-x-0 transition-transform duration-300">→</span>
                </span>
                <span class={`${textClass} ${linkHoverClass} transition-colors duration-300 group-hover:translate-x-1 whitespace-nowrap`}>{item.name}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>

      {/* 3. Expertise Column (Takes 2 columns) */}
      <div class="lg:col-span-2">
        <h4 class={`${headingClass} font-black mb-8 uppercase tracking-[0.2em] text-[11px] transition-colors opacity-80`}>Our Expertise</h4>
        <ul class="space-y-5">
          {expertise.map((item) => (
            <li class="group flex">
              <a href={item.href} class="flex items-center text-base font-bold transition-all duration-300">
                <span class={`w-0 overflow-hidden group-hover:w-5 transition-all duration-300 ease-out ${iconClass} flex items-center`}>
                  <span class="block -translate-x-full group-hover:translate-x-0 transition-transform duration-300">→</span>
                </span>
                <span class={`${textClass} ${linkHoverClass} transition-colors duration-300 group-hover:translate-x-1 whitespace-nowrap`}>{item.name}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>

      {/* 4. Headquarters Column (Takes 4 columns) 
          Math: 4 + 2 + 2 + 4 = 12. Perfect Fit. */}
      <div class="lg:col-span-4">
        <h4 class={`${headingClass} font-black mb-8 uppercase tracking-[0.2em] text-[11px] transition-colors opacity-80`}>Headquarters</h4>
        
        <div class="space-y-4">
          <div class={`p-5 rounded-2xl ${theme === 'light' ? 'bg-white border border-slate-200/60 shadow-sm' : 'bg-white/5 border border-white/10'} transition-colors`}>
            <div class="flex items-start gap-4">
              <div class={`p-3 rounded-xl shrink-0 ${theme === 'light' ? 'bg-slate-50 text-slate-700' : 'bg-white/10 text-white'}`}>
                <svg class={`w-5 h-5 ${iconClass}`} fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
              </div>
              <p class={`${textClass} text-sm font-bold leading-relaxed`}>
                Sakshi Samarth Plaza, First Floor, Above Sohala Showroom, 4th Lane, Rajarampuri, Kolhapur.
              </p>
            </div>
          </div>

          <div class="flex flex-col sm:flex-row gap-4">
            <a href="tel:+919850069600" class={`flex-1 group flex items-center justify-center sm:justify-start gap-3 p-4 rounded-2xl ${theme === 'light' ? 'bg-white border border-slate-200/60 hover:border-teal-300' : 'bg-white/5 border border-white/10 hover:border-white/20'} transition-all duration-300`}>
              <svg class={`w-5 h-5 ${iconClass} group-hover:scale-110 transition-transform`} fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
              <span class={`${headingClass} text-sm font-black tracking-wide`}>+91 98500 69600</span>
            </a>
          </div>
        </div>
      </div>

    </div>

    {/* --- BOTTOM BAR --- */}
    <div class={`pt-8 border-t ${borderClass} flex flex-col md:flex-row justify-between items-center gap-6 transition-colors`}>
      <div class="flex flex-col md:flex-row items-center gap-4 text-[11px] font-bold uppercase tracking-widest text-slate-500">
        <p>© {year} Finesse Overseas Education.</p>
        <div class="hidden md:block w-1 h-1 rounded-full bg-slate-300/50"></div>
        <div class="flex gap-4">
          <a href="/privacy-policy" class={`hover:text-slate-800 ${theme !== 'light' ? 'hover:text-white' : ''} transition-colors`}>Privacy Policy</a>
          <a href="/terms-and-conditions" class={`hover:text-slate-800 ${theme !== 'light' ? 'hover:text-white' : ''} transition-colors`}>Terms</a>
        </div>
      </div>
      
      <div class="flex items-center gap-2 text-[11px] font-black uppercase tracking-[0.2em] text-slate-500 bg-black/5 px-4 py-2 rounded-full backdrop-blur-sm">
        <span>Engineered by</span>
        <a href="https://www.skadas.com" class="hover:scale-110 transition-transform"><svg class="w-4 h-4 text-red-500 fill-current" viewBox="0 0 20 20"><path d="M3.172 5.172a4 4 0 015.656 0L10 6.343l1.172-1.171a4 4 0 115.656 5.656L10 17.657l-6.828-6.829a4 4 0 010-5.656z"></path></svg></a>
        <span class={`${headingClass}`}>Finesse Overseas Education</span>
      </div>
    </div>

  </div>
</footer>