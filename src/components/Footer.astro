---
// src/components/Footer.astro
const year = new Date().getFullYear();

// 🌟 The 3-Theme Architecture
const { hideCTA = false, theme = 'light' } = Astro.props;

let bgClass = 'bg-slate-50';
let textClass = 'text-slate-500';
let headingClass = 'text-slate-900';
let borderClass = 'border-slate-200/60';
let badgeClass = 'bg-slate-200 text-slate-700';
let iconClass = 'text-teal-500';
let linkHoverClass = 'hover:text-teal-600';

if (theme === 'dark') { // For Italy
  bgClass = 'bg-[#050B14]';
  textClass = 'text-slate-400';
  headingClass = 'text-white';
  borderClass = 'border-slate-800/50';
  badgeClass = 'bg-white/5 text-slate-300';
  iconClass = 'text-amber-500';
  linkHoverClass = 'hover:text-amber-400';
} else if (theme === 'blue') { // For Germany
  bgClass = 'bg-slate-950';
  textClass = 'text-slate-400';
  headingClass = 'text-white';
  borderClass = 'border-slate-800/50';
  badgeClass = 'bg-white/5 text-slate-300';
  iconClass = 'text-blue-500';
  linkHoverClass = 'hover:text-blue-400';
} else if (theme === 'red') { // 🇦🇹 For Austria
  bgClass = 'bg-[#050505]'; // matching Austria's deep dark background
  textClass = 'text-slate-400';
  headingClass = 'text-white';
  borderClass = 'border-white/5'; // matching the subtle borders of Austria page
  badgeClass = 'bg-white/5 text-slate-300';
  iconClass = 'text-red-500';
  linkHoverClass = 'hover:text-red-400';
}
---

<footer class={`${bgClass} pt-12 pb-6 relative overflow-hidden transition-colors duration-500`} id="footer">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    
    {!hideCTA && (
      <div class="bg-teal-600 rounded-[2.5rem] p-10 md:p-16 mb-20 relative overflow-hidden shadow-[0_30px_60px_-15px_rgba(13,148,136,0.3)]">
        <div class="absolute top-0 right-0 -mr-20 -mt-20 w-[400px] h-[400px] rounded-full bg-teal-400 blur-3xl opacity-50 mix-blend-screen pointer-events-none"></div>
        <div class="absolute bottom-0 left-0 -ml-20 -mb-20 w-[300px] h-[300px] rounded-full bg-teal-800 blur-3xl opacity-40 mix-blend-multiply pointer-events-none"></div>
        
        <div class="relative z-10 flex flex-col lg:flex-row justify-between items-center gap-10 text-white">
          <div class="max-w-2xl text-center lg:text-left">
            <span class="inline-block px-4 py-1.5 bg-white/10 backdrop-blur-md rounded-full text-xs font-black uppercase tracking-widest border border-white/20 mb-6">
              Your Global Journey
            </span>
            <h2 class="text-4xl md:text-5xl font-black mb-4 leading-tight tracking-tight">
              Stop worrying about the paperwork.
            </h2>
            <p class="text-teal-50 text-lg font-medium max-w-xl mx-auto lg:mx-0">
              Let our experts build a frictionless pathway to your dream university in Germany or Italy.
            </p>
          </div>
          
          <a href="/contact" class="group relative z-20 inline-flex items-center justify-center px-8 py-5 font-bold text-teal-900 bg-white rounded-full overflow-hidden transition-all hover:scale-105 hover:shadow-2xl duration-300 shrink-0">
            <span class="relative flex items-center gap-2">
              Book Free Consultation
              <svg class="w-5 h-5 transform group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
            </span>
          </a>
        </div>
      </div>
    )}

    <div class={`grid grid-cols-1 md:grid-cols-2 lg:grid-cols-12 gap-12 lg:gap-8 ${hideCTA ? 'mt-8' : ''} mb-20 px-4 md:px-8`}>
      
      <div class="lg:col-span-4 flex flex-col justify-between">
        <div>
          <img 
  src="/logo_finesse.png" 
  alt="Finesse Overseas Education" 
  width="200" 
  height="40" 
  loading="lazy" 
  decoding="async" 
  class="h-10 w-auto mb-8 bg-white/80 rounded-lg p-1" 
/>
          <p class={`${textClass} text-sm font-medium leading-relaxed max-w-xs mb-8 transition-colors`}>
            Empowering the youth with 22+ years of on-ground expertise. We navigate the complex European education systems so you don't have to.
          </p>
        </div>
        <div class="flex gap-3">
          <span class={`px-3 py-1.5 ${badgeClass} rounded-lg text-[10px] font-bold uppercase tracking-widest shadow-sm transition-colors`}>on-ground expertise</span>
          <span class={`px-3 py-1.5 ${badgeClass} rounded-lg text-[10px] font-bold uppercase tracking-widest shadow-sm transition-colors`}>22+ Years EXP</span>
        </div>
      </div>

      <div class="lg:col-span-2 lg:col-start-6">
        <h4 class={`${headingClass} font-black mb-6 uppercase tracking-widest text-xs transition-colors`}>Destinations</h4>
        <ul class={`space-y-4 text-sm font-bold ${textClass} transition-colors`}>
          <li><a href="/study-in-germany" class={`${linkHoverClass} transition-colors flex items-center gap-2`}>Study in Germany</a></li>
          <li><a href="/study-in-italy" class={`${linkHoverClass} transition-colors flex items-center gap-2`}>Study in Italy</a></li>
          <li><a href="#" class={`${linkHoverClass} transition-colors flex items-center gap-2`}>Study in Austria</a></li>
        </ul>
      </div>

      <div class="lg:col-span-2">
        <h4 class={`${headingClass} font-black mb-6 uppercase tracking-widest text-xs transition-colors`}>Expertise</h4>
        <ul class={`space-y-4 text-sm font-bold ${textClass} transition-colors`}>
          <li><a href="#" class={`${linkHoverClass} transition-colors`}>University Strategy</a></li>
          <li><a href="#" class={`${linkHoverClass} transition-colors`}>APS & Visa Processing</a></li>
          <li><a href="#" class={`${linkHoverClass} transition-colors`}>Scholarship Filing</a></li>
        </ul>
      </div>

      <div class="lg:col-span-3">
        <h4 class={`${headingClass} font-black mb-6 uppercase tracking-widest text-xs transition-colors`}>Headquarters</h4>
        <ul class={`space-y-4 text-sm font-bold ${textClass} transition-colors`}>
          <li class="flex items-start gap-3">
            <svg class={`w-5 h-5 ${iconClass} shrink-0 mt-0.5 transition-colors`} fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
            <span class="leading-relaxed">Sakshi Samarth Plaza, First Floor, Above Sohala Showroom, Beside Lenskart, 4th Lane, Rajarampuri, Kolhapur.</span>
          </li>
          <li class="flex items-center gap-3 pt-2">
            <svg class={`w-4 h-4 ${iconClass} shrink-0 transition-colors`} fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
            <a href="tel:+919850069600" class={`${linkHoverClass} transition-colors ${theme === 'dark' || theme === 'blue' ? 'text-slate-300' : 'text-slate-800'}`}>+91 98500 69600</a>
          </li>
          <li class="flex items-center gap-3">
            <svg class={`w-4 h-4 ${iconClass} shrink-0 transition-colors`} fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
            <a href="mailto:contact@finesseoverseas.com" class={`${linkHoverClass} transition-colors break-words ${theme === 'dark' || theme === 'blue' ? 'text-slate-300' : 'text-slate-800'}`}>contact@finesse.com</a>
          </li>
        </ul>
      </div>

    </div>

    <div class={`pt-8 border-t ${borderClass} flex flex-col md:flex-row justify-between items-center gap-4 px-4 md:px-8 transition-colors`}>
      <p class="text-[10px] uppercase tracking-widest font-bold text-slate-500 text-center md:text-left">
        © {year} Finesse Overseas Education. All rights reserved.
        <span class="hidden md:inline mx-2">|</span>
        <a href="/terms-and-conditions" class={`${linkHoverClass} mt-2 md:mt-0 block md:inline transition-colors`}>Terms & Conditions</a>
      </p>
      
      <div class="flex items-center gap-2 text-[10px] font-bold uppercase tracking-widest text-slate-500">
        <span>Made with</span>
        <a href="https://www.skadas.com" class="hover:scale-110 transition-transform"><svg class="w-3 h-3 text-red-500 fill-current" viewBox="0 0 20 20"><path d="M3.172 5.172a4 4 0 015.656 0L10 6.343l1.172-1.171a4 4 0 115.656 5.656L10 17.657l-6.828-6.829a4 4 0 010-5.656z"></path></svg></a>
        <span>in Kolhapur</span>
      </div>
    </div>

  </div>
</footer>