---
// src/components/RedNoticeAlert.astro
// THE CONVERSION ENGINE: High-urgency lead capture box for the Intelligence Hub
---

<section class="w-full py-16 bg-[#030712] relative z-20">
  <div class="container mx-auto px-4 lg:px-8 max-w-5xl">
    
    <div class="relative bg-gradient-to-br from-rose-950 to-[#0a0f1c] border border-rose-500/40 rounded-[2.5rem] p-8 md:p-12 lg:p-16 overflow-hidden shadow-[0_20px_50px_rgba(225,29,72,0.15),_inset_0_1px_0_rgba(255,255,255,0.05)]">
      
      <div class="absolute -top-24 -right-24 w-64 h-64 bg-rose-600/20 blur-[80px] rounded-full pointer-events-none"></div>
      <div class="absolute -bottom-24 -left-24 w-64 h-64 bg-rose-800/20 blur-[80px] rounded-full pointer-events-none"></div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16 items-center relative z-10">
        
        <div>
          <div class="inline-flex items-center gap-2.5 px-4 py-1.5 rounded-full bg-rose-500/10 border border-rose-500/30 text-[10px] font-black uppercase tracking-[0.2em] mb-6 shadow-sm">
            <span class="w-2 h-2 rounded-full bg-rose-500 animate-pulse shadow-[0_0_8px_rgba(225,29,72,0.8)]"></span>
            <span class="text-rose-400">Classified Red Notice</span>
          </div>
          
          <h2 class="text-3xl md:text-4xl lg:text-5xl font-serif text-white font-medium leading-[1.1] tracking-tight mb-5 drop-shadow-md">
            Agents won't tell you when the <span class="text-transparent bg-clip-text bg-gradient-to-r from-rose-400 to-rose-200 font-bold italic">rules change.</span>
          </h2>
          
          <p class="text-slate-300 text-sm md:text-base font-medium leading-relaxed mb-8 opacity-90 max-w-lg">
            Get instant, unedited NMC gazette updates, university blacklist alerts, and financial trap warnings delivered straight to your WhatsApp.
          </p>
          
          <div class="flex items-center gap-4 border-t border-rose-500/20 pt-6">
            <div class="flex -space-x-3">
              <div class="w-10 h-10 rounded-full border-2 border-rose-950 bg-slate-800 overflow-hidden"><img src="https://images.unsplash.com/photo-1534528741775-53994a69daeb?q=80&w=100&auto=format&fit=crop" class="w-full h-full object-cover opacity-80" /></div>
              <div class="w-10 h-10 rounded-full border-2 border-rose-950 bg-slate-800 overflow-hidden"><img src="https://images.unsplash.com/photo-1506794778202-cad84cf45f1d?q=80&w=100&auto=format&fit=crop" class="w-full h-full object-cover opacity-80" /></div>
              <div class="w-10 h-10 rounded-full border-2 border-rose-950 bg-slate-800 flex items-center justify-center text-[10px] font-bold text-white shadow-inner">+</div>
            </div>
            <div>
              <p class="text-white text-sm font-bold tracking-wide">Join 5,200+ Parents</p>
              <p class="text-rose-400 text-[9px] font-mono uppercase tracking-widest mt-0.5">100% Free • No Spam Ever</p>
            </div>
          </div>
        </div>

        <div class="bg-[#050b14]/80 backdrop-blur-xl border border-rose-500/30 p-6 md:p-8 rounded-3xl shadow-[0_10px_30px_rgba(0,0,0,0.5)]">
          <form id="red-notice-form" class="flex flex-col gap-5">
            
            <div class="flex flex-col gap-1.5">
              <label for="parentName" class="text-[10px] font-black uppercase tracking-widest text-slate-400">Parent / Student Name</label>
              <div class="relative">
                <input type="text" id="parentName" placeholder="e.g. Rahul Sharma" class="w-full bg-slate-900/80 border border-slate-700 rounded-xl pl-10 pr-4 py-3.5 text-white text-sm focus:outline-none focus:border-rose-500/50 focus:ring-1 focus:ring-rose-500/50 transition-all placeholder:text-slate-600 shadow-inner" required />
                <svg class="absolute left-4 top-1/2 -translate-y-1/2 w-4 h-4 text-slate-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" /></svg>
              </div>
            </div>

            <div class="flex flex-col gap-1.5">
              <label for="whatsappNum" class="text-[10px] font-black uppercase tracking-widest text-slate-400">WhatsApp Number</label>
              <div class="relative">
                <input type="tel" id="whatsappNum" placeholder="+91 00000 00000" class="w-full bg-slate-900/80 border border-slate-700 rounded-xl pl-10 pr-4 py-3.5 text-white text-sm focus:outline-none focus:border-rose-500/50 focus:ring-1 focus:ring-rose-500/50 transition-all placeholder:text-slate-600 shadow-inner" required />
                <svg class="absolute left-4 top-1/2 -translate-y-1/2 w-4 h-4 text-emerald-500" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" clip-rule="evenodd" d="M12 2C6.48 2 2 6.48 2 12c0 1.76.46 3.4 1.25 4.85L2 22l5.31-1.22A9.974 9.974 0 0012 22c5.52 0 10-4.48 10-10S17.52 2 12 2zm5.45 14.5c-.24.67-1.39 1.28-1.92 1.35-.5.06-1.15.15-3.32-.75-2.61-1.08-4.29-3.75-4.42-3.92-.13-.17-1.05-1.41-1.05-2.69 0-1.28.66-1.91.89-2.15.22-.24.49-.3.65-.3.17 0 .33 0 .48.01.16.01.38-.06.58.42.21.51.72 1.78.78 1.91.06.13.1.28.02.45-.08.17-.12.28-.24.42-.12.14-.25.32-.36.43-.13.14-.26.3-.11.56.15.26.68 1.13 1.47 1.83.99.89 1.83 1.16 2.09 1.3.26.14.41.12.56-.05.15-.17.65-.75.82-1.01.17-.26.34-.22.58-.13.24.09 1.53.72 1.8 86.26.13.38.19.58.28.89.09z"/></svg>
              </div>
            </div>

            <button type="submit" class="w-full bg-rose-600 hover:bg-rose-500 text-white text-xs font-black uppercase tracking-widest py-4 rounded-xl transition-all shadow-[0_0_20px_rgba(225,29,72,0.4)] mt-2 flex items-center justify-center gap-2 group">
              Activate Red Notice Alerts
              <svg class="w-4 h-4 transform group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" /></svg>
            </button>
            
            <p class="text-center text-[9px] font-mono uppercase tracking-widest text-slate-500 mt-1">
              Protected by Finesse Legal Data Protocols.
            </p>
          </form>
        </div>

      </div>
    </div>
  </div>
</section>