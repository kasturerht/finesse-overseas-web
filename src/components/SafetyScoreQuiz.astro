---
// src/components/SafetyScoreQuiz.astro
// The Ultimate Retention Tool: Interactive NMC Safety Score Engine
---

<section class="relative w-full py-24 bg-[#030712] border-t border-slate-800/50 font-sans overflow-hidden" id="safety-quiz-section">
  
  <div class="absolute top-1/2 left-0 -translate-y-1/2 w-96 h-96 bg-emerald-500/5 blur-[100px] rounded-full pointer-events-none"></div>
  <div class="absolute bottom-0 right-0 w-[500px] h-[500px] bg-blue-500/5 blur-[120px] rounded-full pointer-events-none"></div>

  <div class="container mx-auto px-4 lg:px-8 max-w-7xl relative z-10">
    
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-center">
      
      <div class="lg:col-span-5 text-center lg:text-left">
        <div class="inline-flex items-center gap-3 px-4 py-1.5 rounded-full bg-slate-900/80 border border-emerald-500/30 text-[10px] font-bold uppercase tracking-[0.2em] mb-6 shadow-lg">
          <span class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></span>
          <span class="text-emerald-400">Interactive Audit Tool</span>
        </div>
        <h2 class="text-3xl lg:text-5xl font-serif text-white font-medium leading-[1.15] tracking-tight mb-6">
          Is your agent selling you a <br class="hidden lg:block"/>
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-rose-400 to-rose-200 font-bold">Blacklisted University?</span>
        </h2>
        <p class="text-slate-400 text-lg font-medium leading-relaxed mb-8 max-w-xl mx-auto lg:mx-0">
          Don't trust WhatsApp PDFs. Use our proprietary 3-point NMC filtration matrix to instantly calculate the legal and clinical safety score of any university before you pay a single rupee.
        </p>
        
        <div class="hidden lg:flex items-center gap-4 border-l-2 border-slate-700 pl-6 opacity-80">
          <div class="text-3xl font-black text-slate-300 font-mono">15K+</div>
          <p class="text-xs text-slate-500 uppercase tracking-widest font-bold leading-relaxed">Universities Audited <br/> by Indian Parents</p>
        </div>
      </div>

      <div class="lg:col-span-7">
        <div class="bg-[#0a0f1c]/80 backdrop-blur-xl border border-slate-700/80 rounded-[2rem] p-6 lg:p-10 shadow-[0_20px_50px_rgba(0,0,0,0.5),_inset_0_1px_0_rgba(255,255,255,0.05)] relative overflow-hidden">
          
          <div class="absolute top-0 left-0 w-full h-1.5 bg-gradient-to-r from-rose-500 via-amber-500 to-emerald-500"></div>

          <div id="quiz-form-stage" class="transition-all duration-500 opacity-100 translate-x-0">
            <h3 class="text-xl font-bold text-white mb-8 font-serif">Enter University Parameters</h3>
            
            <div class="space-y-6">
              <div>
                <label class="block text-[10px] font-black uppercase tracking-widest text-slate-500 mb-2">Target University Name</label>
                <input type="text" id="univ-name" placeholder="e.g. Tbilisi State Medical University" class="w-full bg-slate-900 border border-slate-700 rounded-xl px-5 py-3.5 text-white text-sm focus:outline-none focus:border-emerald-500 focus:ring-1 focus:ring-emerald-500 transition-all placeholder:text-slate-600" />
              </div>

              <div>
                <label class="block text-[10px] font-black uppercase tracking-widest text-slate-500 mb-2">Hospital Bed Capacity (Clinical Volume)</label>
                <div class="grid grid-cols-3 gap-3">
                  <button type="button" class="quiz-btn bg-slate-900 border border-slate-700 text-slate-400 text-xs font-bold py-3 rounded-xl hover:bg-slate-800 transition-all" data-group="beds" data-val="10">Under 500</button>
                  <button type="button" class="quiz-btn bg-slate-900 border border-slate-700 text-slate-400 text-xs font-bold py-3 rounded-xl hover:bg-slate-800 transition-all" data-group="beds" data-val="20">500 - 800</button>
                  <button type="button" class="quiz-btn bg-slate-900 border border-slate-700 text-slate-400 text-xs font-bold py-3 rounded-xl hover:bg-slate-800 transition-all" data-group="beds" data-val="35">800+ Beds</button>
                </div>
              </div>

              <div>
                <label class="block text-[10px] font-black uppercase tracking-widest text-slate-500 mb-2">Sovereign Ownership</label>
                <div class="grid grid-cols-2 gap-3">
                  <button type="button" class="quiz-btn bg-slate-900 border border-slate-700 text-slate-400 text-xs font-bold py-3 rounded-xl hover:bg-slate-800 transition-all" data-group="owner" data-val="10">Private / Semi-Private</button>
                  <button type="button" class="quiz-btn bg-slate-900 border border-slate-700 text-slate-400 text-xs font-bold py-3 rounded-xl hover:bg-slate-800 transition-all" data-group="owner" data-val="35">100% Government Owned</button>
                </div>
              </div>

              <div>
                <label class="block text-[10px] font-black uppercase tracking-widest text-slate-500 mb-2">Medium of Instruction</label>
                <div class="grid grid-cols-2 gap-3">
                  <button type="button" class="quiz-btn bg-slate-900 border border-slate-700 text-slate-400 text-xs font-bold py-3 rounded-xl hover:bg-slate-800 transition-all" data-group="lang" data-val="0">Bilingual (English + Local)</button>
                  <button type="button" class="quiz-btn bg-slate-900 border border-slate-700 text-slate-400 text-xs font-bold py-3 rounded-xl hover:bg-slate-800 transition-all" data-group="lang" data-val="30">100% English Mandated</button>
                </div>
              </div>
            </div>

            <div class="mt-8">
              <button id="calculate-btn" class="w-full bg-white text-slate-900 hover:bg-emerald-400 hover:text-white text-sm font-black uppercase tracking-widest py-4 rounded-xl transition-all duration-300 shadow-[0_0_20px_rgba(255,255,255,0.1)] flex items-center justify-center gap-2 group opacity-50 cursor-not-allowed" disabled>
                <svg class="w-5 h-5 text-emerald-500 group-hover:text-white transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                Initiate System Audit
              </button>
            </div>
          </div>

          <div id="quiz-loader-stage" class="hidden flex-col items-center justify-center py-16 text-center transition-all duration-500">
            <div class="relative w-20 h-20 mb-6">
              <div class="absolute inset-0 rounded-full border-t-2 border-emerald-500 animate-spin"></div>
              <div class="absolute inset-2 rounded-full border-r-2 border-amber-500 animate-spin direction-reverse"></div>
              <div class="absolute inset-0 flex items-center justify-center text-emerald-500">
                <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
              </div>
            </div>
            <h3 class="text-white font-mono text-lg uppercase tracking-widest mb-2">Scanning Matrix...</h3>
            <p class="text-slate-500 text-xs font-mono">Cross-referencing NMC 2021 Gazette parameters.</p>
          </div>

          <div id="quiz-result-stage" class="hidden flex-col items-center text-center transition-all duration-500 py-6">
            <span id="result-badge" class="px-3 py-1 rounded text-[10px] font-black uppercase tracking-widest mb-6 border bg-slate-900 border-slate-700 text-slate-400">Analysis Complete</span>
            
            <div class="relative w-40 h-40 flex items-center justify-center mb-6">
              <svg class="w-full h-full transform -rotate-90" viewBox="0 0 100 100">
                <circle cx="50" cy="50" r="45" fill="none" class="stroke-slate-800" stroke-width="8" />
                <circle id="score-circle" cx="50" cy="50" r="45" fill="none" class="stroke-emerald-500 transition-all duration-1000 ease-out" stroke-width="8" stroke-dasharray="283" stroke-dashoffset="283" />
              </svg>
              <div class="absolute inset-0 flex flex-col items-center justify-center">
                <span id="final-score" class="text-5xl font-black font-serif text-white tracking-tighter">0</span>
                <span class="text-[10px] text-slate-400 font-mono uppercase tracking-widest mt-1">/ 100</span>
              </div>
            </div>

            <h3 id="result-title" class="text-2xl font-serif text-white mb-2">Checking...</h3>
            <p id="result-desc" class="text-sm text-slate-400 mb-8 max-w-sm px-4">Analyzing...</p>

            <div class="w-full flex flex-col sm:flex-row gap-4">
              <button id="reset-btn" class="flex-1 bg-slate-800 hover:bg-slate-700 text-slate-300 text-xs font-bold uppercase tracking-widest py-3.5 rounded-xl transition-all">
                Audit Another
              </button>
              <a href="/contact" class="flex-[2] bg-emerald-600 hover:bg-emerald-500 text-white text-xs font-black uppercase tracking-widest py-3.5 rounded-xl transition-all shadow-[0_0_15px_rgba(16,185,129,0.3)] flex items-center justify-center gap-2">
                Download Full Dossier
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" /></svg>
              </a>
            </div>
          </div>

        </div>
      </div>

    </div>
  </div>
</section>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const btns = document.querySelectorAll('.quiz-btn');
    const calcBtn = document.getElementById('calculate-btn');
    const univInput = document.getElementById('univ-name');
    
    let state = { beds: null, owner: null, lang: null };

    // Function to check if form is ready to submit
    const checkReady = () => {
      if(state.beds && state.owner && state.lang && univInput.value.trim() !== '') {
        calcBtn.classList.remove('opacity-50', 'cursor-not-allowed');
        calcBtn.removeAttribute('disabled');
      } else {
        calcBtn.classList.add('opacity-50', 'cursor-not-allowed');
        calcBtn.setAttribute('disabled', 'true');
      }
    };

    univInput.addEventListener('input', checkReady);

    // Button Selection Logic
    btns.forEach(btn => {
      btn.addEventListener('click', (e) => {
        const group = e.target.getAttribute('data-group');
        const val = parseInt(e.target.getAttribute('data-val'));
        
        // Deselect others in group
        document.querySelectorAll(`.quiz-btn[data-group="${group}"]`).forEach(b => {
          b.classList.remove('bg-emerald-500/20', 'border-emerald-500', 'text-emerald-400');
          b.classList.add('bg-slate-900', 'border-slate-700', 'text-slate-400');
        });

        // Select clicked
        e.target.classList.remove('bg-slate-900', 'border-slate-700', 'text-slate-400');
        e.target.classList.add('bg-emerald-500/20', 'border-emerald-500', 'text-emerald-400');

        state[group] = val;
        checkReady();
      });
    });

    // Calculate Logic
    calcBtn.addEventListener('click', () => {
      const totalScore = state.beds + state.owner + state.lang;
      
      const formStage = document.getElementById('quiz-form-stage');
      const loaderStage = document.getElementById('quiz-loader-stage');
      const resultStage = document.getElementById('quiz-result-stage');
      
      // Hide Form, Show Loader
      formStage.classList.add('hidden');
      loaderStage.classList.remove('hidden');
      loaderStage.classList.add('flex');

      // Fake API Delay (Psychology of computing)
      setTimeout(() => {
        loaderStage.classList.remove('flex');
        loaderStage.classList.add('hidden');
        resultStage.classList.remove('hidden');
        resultStage.classList.add('flex');

        // Animate Circle
        const circle = document.getElementById('score-circle');
        const offset = 283 - (283 * totalScore) / 100;
        
        setTimeout(() => {
          circle.style.strokeDashoffset = offset;
          animateValue("final-score", 0, totalScore, 1000);
        }, 100);

        // Update UI based on score
        const badge = document.getElementById('result-badge');
        const title = document.getElementById('result-title');
        const desc = document.getElementById('result-desc');

        if(totalScore >= 90) {
          circle.classList.replace('stroke-emerald-500', 'stroke-emerald-500');
          badge.className = "px-3 py-1 rounded text-[10px] font-black uppercase tracking-widest mb-6 border bg-emerald-500/10 border-emerald-500/30 text-emerald-400";
          badge.innerText = "NMC Verified Safe Zone";
          title.innerHTML = "Highly Recommended";
          desc.innerHTML = `Based on our matrix, <span class="text-white">${univInput.value}</span> meets all crucial clinical and legal parameters.`;
        } else if (totalScore >= 50) {
          circle.classList.replace('stroke-emerald-500', 'stroke-amber-500');
          badge.className = "px-3 py-1 rounded text-[10px] font-black uppercase tracking-widest mb-6 border bg-amber-500/10 border-amber-500/30 text-amber-400";
          badge.innerText = "High Risk Alert";
          title.innerHTML = "Proceed with Caution";
          desc.innerHTML = `Contractors might push <span class="text-white">${univInput.value}</span>, but it fails some Finesse safety protocols. Review dossier carefully.`;
        } else {
          circle.classList.replace('stroke-emerald-500', 'stroke-rose-500');
          badge.className = "px-3 py-1 rounded text-[10px] font-black uppercase tracking-widest mb-6 border bg-rose-500/10 border-rose-500/30 text-rose-400";
          badge.innerText = "Strictly Blacklisted";
          title.innerHTML = "Do Not Invest Here";
          desc.innerHTML = `Warning! <span class="text-white">${univInput.value}</span> completely fails the NMC Gazette requirements. Your degree may be invalid in India.`;
        }
      }, 2000); // 2 second fake delay
    });

    // Reset Logic
    document.getElementById('reset-btn').addEventListener('click', () => {
      document.getElementById('quiz-result-stage').classList.add('hidden');
      document.getElementById('quiz-result-stage').classList.remove('flex');
      document.getElementById('quiz-form-stage').classList.remove('hidden');
      
      // Reset circle and score
      document.getElementById('score-circle').style.strokeDashoffset = 283;
      document.getElementById('final-score').innerText = '0';
      document.getElementById('score-circle').classList.remove('stroke-amber-500', 'stroke-rose-500');
      document.getElementById('score-circle').classList.add('stroke-emerald-500');
      
      // Clear inputs
      univInput.value = '';
      state = { beds: null, owner: null, lang: null };
      btns.forEach(b => {
        b.classList.remove('bg-emerald-500/20', 'border-emerald-500', 'text-emerald-400');
        b.classList.add('bg-slate-900', 'border-slate-700', 'text-slate-400');
      });
      checkReady();
    });

    // Number Counter Animation
    function animateValue(id, start, end, duration) {
      if (start === end) return;
      var range = end - start;
      var current = start;
      var increment = end > start ? 1 : -1;
      var stepTime = Math.abs(Math.floor(duration / range));
      var obj = document.getElementById(id);
      var timer = setInterval(function() {
          current += increment;
          obj.innerHTML = current;
          if (current == end) { clearInterval(timer); }
      }, stepTime);
    }
  });
</script>

<style>
  .direction-reverse { animation-direction: reverse; }
</style>