<section id="truth-lens-container" class="relative w-full py-24 lg:py-32 bg-[#030712] flex flex-col items-center justify-center font-sans border-t border-white/5">
  
  <div class="relative z-30 flex flex-col items-center text-center w-full px-6 mb-16 pointer-events-auto">
    
    <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-emerald-500/10 border border-emerald-500/20 text-xs font-bold uppercase tracking-[0.2em] mb-6 shadow-2xl">
