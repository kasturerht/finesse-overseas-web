---
// src/pages/mbbs-abroad.astro (The 100% Complete 'God-Level' Version)
import Layout from '../layouts/Layout.astro';

const seoTitle = "Elite Medical Pathways | NMC-Compliant MBBS Abroad | Finesse Overseas";
const seoDescription = "Secure your child's Doctor dream with 100% NMC-compliant MBBS pathways abroad. Government universities, zero advance policy, and high FMGE passing rates.";
---

<Layout title={seoTitle} description={seoDescription}>
  
  <main id="main-content" class="w-full overflow-hidden">

    <section class="relative w-full min-h-[calc(100vh-90px)] flex items-center bg-slate-950 font-sans py-12 lg:py-0">
      <div class="absolute inset-0 z-0 pointer-events-none flex items-center justify-center">
        <div class="absolute w-[800px] h-[800px] rounded-full bg-emerald-900/10 blur-[150px] animate-pulse-slow will-change-transform"></div>
        <div class="absolute inset-0 bg-[linear-gradient(rgba(255,255,255,0.02)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.02)_1px,transparent_1px)] bg-[size:64px_64px] opacity-50"></div>
      </div>

      <div class="container mx-auto px-6 lg:px-12 relative z-10 w-full mt-8 lg:mt-0">
        <div class="grid lg:grid-cols-12 gap-12 lg:gap-16 items-center">
          
          <div class="lg:col-span-7 flex flex-col justify-center text-left">
            <div class="inline-flex items-center gap-3 px-4 py-2 rounded-full bg-slate-900/80 border border-emerald-900/50 mb-8 w-max shadow-inner">
              <span class="w-2 h-2 rounded-full bg-emerald-500 shadow-[0_0_10px_rgba(16,185,129,0.8)] animate-pulse"></span>
              <span class="text-[10px] font-bold tracking-[0.2em] text-emerald-100 uppercase">Finesse Elite Medical Desk</span>
            </div>

            <h1 class="text-5xl lg:text-7xl font-extrabold text-white leading-[1.05] tracking-tight mb-6">
              Your Child’s Doctor Dream, <br/>
              <span class="text-transparent bg-clip-text bg-gradient-to-r from-emerald-400 to-emerald-200">Secured.</span>
            </h1>
            
            <h2 class="font-serif italic text-2xl lg:text-3xl text-slate-300 font-light mb-8 flex flex-wrap items-center gap-3">
              100% NMC-Compliant MBBS in 
              <span class="inline-block bg-amber-500/10 border border-amber-500/20 px-4 py-1.5 rounded-xl shadow-inner">
                <span id="country-rotator" class="inline-block text-amber-400 font-bold transition-all duration-500 opacity-100">
                  Georgia
                </span>
              </span>
            </h2>

            <p class="text-base lg:text-lg text-slate-400 mb-10 leading-relaxed max-w-2xl font-medium">
              We bypass the chaos of random agents. We execute <strong class="text-white">Strategic Institutional Mapping</strong> for high-ticket profiles, ensuring placement in globally-audited Government Medical Universities.
            </p>

            <div class="flex flex-col sm:flex-row items-center gap-6">
                <button class="w-full sm:w-auto group relative inline-flex items-center justify-center gap-3 px-8 py-4 bg-emerald-600 hover:bg-emerald-500 text-white text-sm font-black uppercase tracking-widest rounded-xl transition-all duration-300 shadow-[0_0_20px_rgba(16,185,129,0.25)] hover:shadow-[0_0_35px_rgba(16,185,129,0.4)]">
                  <span>Initiate Profile Mapping</span>
                  <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M14 5l7 7m0 0l-7 7m7-7H3" /></svg>
                </button>
                <div class="flex items-center gap-3 text-sm text-slate-400 font-semibold tracking-wide">
                  <svg class="w-5 h-5 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
                  AES-256 Encrypted
                </div>
            </div>
          </div>

          <div class="lg:col-span-5 grid grid-cols-2 gap-4 relative mt-10 lg:mt-0 pt-6 lg:pt-0" aria-hidden="true">
            <div class="absolute -top-6 -left-6 z-20 bg-slate-900 border border-slate-700 p-4 rounded-2xl shadow-2xl flex items-center gap-4 animate-[bounce_4s_ease-in-out_infinite]">
              <div class="text-amber-400 font-black text-2xl tracking-tighter">500+</div>
              <div class="text-[10px] text-slate-300 leading-snug font-bold uppercase tracking-widest">Families<br/>Trusted Us</div>
            </div>

            <div class="col-span-2 relative h-[280px] lg:h-[320px] rounded-3xl bg-slate-900 border border-slate-700/50 shadow-2xl flex flex-col justify-between p-6 lg:p-8 transition-colors hover:border-emerald-700/50 overflow-hidden">
              <div class="absolute inset-0 bg-gradient-to-br from-slate-900 via-slate-900 to-emerald-950/20 pointer-events-none"></div>
              <div class="relative z-10 flex justify-between items-start mb-4">
                <div>
                  <h3 class="text-white font-bold text-xl lg:text-2xl tracking-tight">Profile Eligibility Scanner</h3>
                  <p class="text-xs text-slate-400 font-medium uppercase tracking-widest mt-1">Live NMC Matrix Audit</p>
                </div>
                <div class="bg-emerald-500/10 border border-emerald-500/20 px-3 py-1.5 rounded-lg flex items-center gap-2">
                  <span class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></span>
                  <span class="text-xs font-bold text-emerald-400">System Active</span>
                </div>
              </div>
              <div class="relative z-10 grid grid-cols-2 gap-6 lg:gap-8 my-auto">
                <div class="space-y-3">
                  <div class="flex justify-between items-end">
                    <label class="text-sm font-semibold text-slate-300">Expected NEET Score</label>
                    <span id="scoreValue" class="text-lg font-black text-white">400</span>
                  </div>
                  <input type="range" id="neetSlider" min="150" max="720" step="10" value="400" class="w-full h-1.5 bg-slate-700 rounded-lg appearance-none cursor-pointer accent-emerald-500 transition-all">
                </div>
                <div class="space-y-3">
                  <div class="flex justify-between items-end">
                    <label class="text-sm font-semibold text-slate-300">Total Budget</label>
                    <span id="budgetValue" class="text-lg font-black text-white">₹25L</span>
                  </div>
                  <input type="range" id="budgetSlider" min="15" max="60" step="5" value="25" class="w-full h-1.5 bg-slate-700 rounded-lg appearance-none cursor-pointer accent-amber-500 transition-all">
                </div>
              </div>
              <div class="relative z-10 mt-6 pt-5 border-t border-slate-700/50 flex items-center justify-between">
                
                <div class="flex gap-6">
                  <div>
                    <p class="text-xs text-slate-400 font-semibold uppercase tracking-wider mb-0.5">Approved Pathways</p>
                    <div class="flex items-baseline gap-1.5">
                      <span id="matchCount" class="text-2xl font-black text-emerald-400 transition-colors">12</span>
                      <span class="text-sm text-slate-500 font-medium">Univs</span>
                    </div>
                  </div>
                  
                  <div class="hidden sm:block">
                    <p class="text-xs text-slate-400 font-semibold uppercase tracking-wider mb-0.5">Avg. FMGE Pass</p>
                    <div class="flex items-baseline gap-1.5">
                      <span id="fmgeRate" class="text-2xl font-black text-amber-400">38%</span>
                    </div>
                  </div>
                </div>

                <button class="bg-white hover:bg-slate-200 text-slate-950 px-5 py-2.5 rounded-xl font-bold text-sm tracking-wide transition-colors flex items-center gap-2 shadow-[0_0_15px_rgba(255,255,255,0.1)]">
                  <svg class="w-4 h-4 text-slate-700" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
                  Unlock Names
                </button>

              </div>
            </div>

            <div class="col-span-1 bg-slate-900/90 backdrop-blur-sm border border-slate-700 rounded-3xl p-6 flex flex-col justify-between hover:border-emerald-700/50 transition-colors">
              <div class="w-14 h-14 rounded-2xl bg-emerald-900/40 border border-emerald-800 flex items-center justify-center mb-6 shadow-inner">
                <span class="text-emerald-400 font-black text-xl">₹0</span>
              </div>
              <div>
                <p class="text-white font-black text-xl">Advance</p>
                <p class="text-slate-400 text-[10px] font-bold uppercase tracking-widest mt-1.5">Direct to Univ.</p>
              </div>
            </div>

            <div class="col-span-1 relative bg-gradient-to-br from-slate-900 to-slate-950 border border-slate-700 rounded-3xl p-6 flex flex-col justify-between hover:border-amber-700/50 transition-colors overflow-hidden">
              <div class="absolute -right-4 -bottom-4 opacity-5 pointer-events-none transform rotate-12">
                <svg class="w-32 h-32 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
              </div>
              <div class="relative z-10 w-14 h-14 rounded-2xl bg-amber-500/10 border border-amber-500/30 flex items-center justify-center mb-6 shadow-inner">
                <span class="text-amber-400 text-sm font-black tracking-widest">NMC</span>
              </div>
              <div class="relative z-10">
                <p class="text-white font-black text-xl">2021 Gazette</p>
                <p class="text-amber-400/90 text-[10px] font-bold uppercase tracking-widest mt-1.5">100% Compliant</p>
              </div>
            </div>
          </div>

        </div>
      </div>
    </section>

    <section id="truth-lens-container" class="relative w-full py-24 lg:py-32 bg-[#030712] flex flex-col items-center justify-center font-sans border-t border-white/5">
      <div class="relative z-30 flex flex-col items-center text-center w-full px-6 mb-16 pointer-events-none">
        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-emerald-500/10 border border-emerald-500/20 text-xs font-bold uppercase tracking-[0.2em] mb-6 shadow-2xl pointer-events-auto">
          <span class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></span>
          <span class="text-emerald-400">The Finesse Philosophy</span>
        </div>
        <h2 class="text-3xl lg:text-5xl font-black text-white leading-[1.2] tracking-tight max-w-4xl pointer-events-auto">
          We refuse to sell the <br class="hidden lg:block"/>
          <span class="text-slate-500 line-through decoration-rose-500 decoration-4">"₹15 Lakh Guaranteed MBBS"</span> illusion.
        </h2>
        <p class="mt-6 text-lg lg:text-xl text-slate-400 font-medium max-w-2xl mx-auto leading-relaxed pointer-events-auto">
          Most agents trap Indian parents with fake budget promises. We expose them. 
          <span class="hidden lg:inline text-emerald-500 font-bold">Hover your mouse</span>
          <span class="inline lg:hidden text-emerald-500 font-bold">Tap and drag</span>
          below to uncover the dark reality.
        </p>
      </div>

      <div class="relative w-full max-w-5xl mx-auto px-6 cursor-none group">
        <div class="absolute -top-4 left-1/2 transform -translate-x-1/2 z-40 bg-rose-500 text-white text-[10px] font-black uppercase tracking-[0.3em] px-4 py-1.5 rounded-sm shadow-[0_0_20px_rgba(225,29,72,0.4)]">
          Simulating Traditional Agent Pitch
        </div>

        <div class="relative w-full rounded-2xl border border-slate-700/50 bg-[#0a0f1c] overflow-hidden shadow-2xl h-[400px] lg:h-[450px]" id="interactive-xray-box">
          
          <div class="relative z-0 flex items-center justify-center w-full h-full p-8 pointer-events-none">
            <div class="w-full text-center">
              <h4 class="text-rose-500 font-bold tracking-[0.3em] uppercase text-xs mb-6">What you actually get</h4>
              <h3 class="text-3xl lg:text-5xl font-black text-white leading-[1.2] tracking-tight">
                Hidden <span class="text-rose-500">₹12L Contractor Fees.</span> <br/>
                3rd-Year <span class="text-rose-500">Bilingual Clinicals.</span> <br/>
                <span class="text-rose-600 underline decoration-rose-900 decoration-4 underline-offset-8 mt-2 inline-block">Zero FMGE Guarantee.</span>
              </h3>
            </div>
            <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,rgba(225,29,72,0.1)_0%,transparent_60%)]"></div>
          </div>

          <div id="facade-layer" class="absolute inset-0 bg-[#0a0f1c] flex items-center justify-center p-8 z-10 pointer-events-none transition-opacity duration-1000 will-change-mask" aria-hidden="true">
            <div class="w-full text-center">
              <h4 class="text-amber-400/80 font-serif italic tracking-widest text-base mb-6">What they show you</h4>
              <h3 class="text-3xl lg:text-5xl font-serif text-slate-300 leading-[1.2] tracking-tight">
                "100% Guaranteed MBBS in a Top <br class="hidden lg:block"/>
                European Medical University <br/>
                <span class="text-amber-400 font-bold mt-2 inline-block">at just ₹15 Lakhs."</span>
              </h3>
            </div>
          </div>

          <div id="xray-lens" class="absolute top-0 left-0 w-[200px] lg:w-[350px] h-[200px] lg:h-[350px] rounded-full border border-white/20 z-20 pointer-events-none flex items-center justify-center opacity-0 transition-opacity duration-500 shadow-[0_0_50px_rgba(225,29,72,0.2)] will-change-transform backdrop-filter backdrop-blur-[2px]" style="transform: translate(-50%, -50%);">
            <div class="absolute w-full h-px bg-rose-500/40"></div>
            <div class="absolute h-full w-px bg-rose-500/40"></div>
            <div class="absolute w-4 h-4 border-2 border-rose-500/80 rounded-full"></div>
            <div class="absolute bottom-6 text-[8px] lg:text-[9px] font-mono text-white font-bold uppercase tracking-[0.3em] bg-rose-600 px-3 py-1 rounded">
              Reality Scanner
            </div>
          </div>

        </div>
      </div>
    </section>

    <section id="safety-matrix-section" class="relative w-full py-24 lg:py-32 bg-slate-50 border-t border-slate-200 font-sans">
      <div class="container mx-auto px-6 lg:px-12 relative w-full max-w-7xl">
        
        <div class="flex flex-col items-center lg:items-start text-center lg:text-left mb-16 border-b border-slate-200 pb-12">
          <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-slate-900 text-[10px] font-bold uppercase tracking-[0.2em] mb-6 shadow-md">
            <span class="w-2 h-2 rounded-full bg-emerald-400"></span>
            <span class="text-white">The Finesse Standard</span>
          </div>
          <h2 class="text-3xl lg:text-5xl xl:text-[4rem] font-serif text-slate-900 leading-[1.1] tracking-tight max-w-4xl">
            We don't sell random seats.<br class="hidden lg:block"/>
            We <span class="text-slate-500 italic">audit medical careers.</span>
          </h2>
          <p class="mt-8 text-lg text-slate-600 font-sans max-w-2xl leading-relaxed">
            Out of 150+ global medical universities, only a select few survive our brutal filtration matrix. Here is exactly how we protect your child's future.
          </p>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-16">
          <div class="w-full lg:col-span-7 bg-white border border-slate-200 rounded-2xl p-8 lg:p-12 shadow-[0_20px_50px_rgba(15,23,42,0.05)] relative overflow-hidden min-h-[450px] flex flex-col justify-center">
            <div class="absolute inset-0 bg-[radial-gradient(#e2e8f0_1px,transparent_1px)] [background-size:16px_16px] opacity-30 pointer-events-none"></div>

            <div id="data-state-1" class="matrix-data-state absolute inset-0 p-8 lg:p-12 flex flex-col justify-center transition-all duration-700 opacity-100 translate-y-0 will-change-transform">
              <span class="text-slate-300 font-serif text-6xl italic absolute top-8 right-8 pointer-events-none">01</span>
              <h3 class="text-3xl lg:text-4xl font-black text-slate-900 mb-6 leading-tight tracking-tight relative z-10">The Clinical Volume<br/>Mandate.</h3>
              <p class="text-lg text-slate-600 leading-relaxed font-medium mb-8 relative z-10">Many agents sell "beautiful campuses" that are essentially just empty buildings. Medicine cannot be learned from textbooks alone.</p>
              <div class="bg-slate-50 border-l-4 border-emerald-500 p-5 rounded-r-lg relative z-10">
                <p class="text-sm font-bold text-slate-800 uppercase tracking-widest mb-1">Finesse Protocol</p>
                <p class="text-slate-700 font-medium">We strictly mandate affiliated government hospitals with <strong class="text-emerald-600 text-lg">800+ beds</strong>. High patient inflow is the only empirical way to secure FMGE clinical skills.</p>
              </div>
            </div>

            <div id="data-state-2" class="matrix-data-state absolute inset-0 p-8 lg:p-12 flex flex-col justify-center transition-all duration-700 opacity-0 translate-y-8 pointer-events-none will-change-transform">
              <span class="text-slate-300 font-serif text-6xl italic absolute top-8 right-8 pointer-events-none">02</span>
              <h3 class="text-3xl lg:text-4xl font-black text-slate-900 mb-6 leading-tight tracking-tight relative z-10">Sovereign Security.<br/>Zero Private Risk.</h3>
              <p class="text-lg text-slate-600 leading-relaxed font-medium mb-8 relative z-10">Private universities or "contractor-run" campuses can shut down, increase fees arbitrarily, or vanish overnight. Your child's 6-year degree is at extreme financial risk.</p>
              <div class="bg-slate-50 border-l-4 border-emerald-500 p-5 rounded-r-lg relative z-10">
                <p class="text-sm font-bold text-slate-800 uppercase tracking-widest mb-1">Finesse Protocol</p>
                <p class="text-slate-700 font-medium">We only place students in <strong class="text-emerald-600 text-lg">100% State-Owned</strong> National Universities.</p>
              </div>
            </div>

            <div id="data-state-3" class="matrix-data-state absolute inset-0 p-8 lg:p-12 flex flex-col justify-center transition-all duration-700 opacity-0 translate-y-8 pointer-events-none will-change-transform">
              <span class="text-slate-300 font-serif text-6xl italic absolute top-8 right-8 pointer-events-none">03</span>
              <h3 class="text-3xl lg:text-4xl font-black text-slate-900 mb-6 leading-tight tracking-tight relative z-10">The Historical<br/>FMGE Filter.</h3>
              <p class="text-lg text-slate-600 leading-relaxed font-medium mb-8 relative z-10">A medical degree is just a piece of paper if the student cannot pass the screening test back in India. Some popular universities have a shocking 5% pass rate.</p>
              <div class="bg-slate-50 border-l-4 border-emerald-500 p-5 rounded-r-lg relative z-10">
                <p class="text-sm font-bold text-slate-800 uppercase tracking-widest mb-1">Finesse Protocol</p>
                <p class="text-slate-700 font-medium">We analyze the last 5 years of NBE/FMGE data. If alumni consistently fail, that institution is <strong class="text-rose-600 text-lg">permanently blacklisted</strong>.</p>
              </div>
            </div>
          </div>

          <div class="w-full lg:col-span-5 flex flex-col gap-4 justify-center" aria-label="Select parameter to audit">
            <p class="text-xs font-bold text-slate-400 uppercase tracking-[0.2em] mb-2 px-2">Select Parameter</p>

            <button class="matrix-trigger w-full text-left p-6 rounded-xl border-2 transition-all duration-300 bg-white border-slate-900 shadow-md group outline-none focus:ring-2 focus:ring-emerald-500" data-target="1">
              <div class="flex justify-between items-center pointer-events-none">
                <h4 class="text-xl font-bold text-slate-900 group-hover:text-emerald-600 transition-colors">01. Clinical Exposure</h4>
                <div class="w-6 h-6 rounded-full bg-emerald-100 text-emerald-600 flex items-center justify-center opacity-100 transition-opacity trigger-icon">
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M9 5l7 7-7 7"/></svg>
                </div>
              </div>
            </button>

            <button class="matrix-trigger w-full text-left p-6 rounded-xl border-2 transition-all duration-300 bg-slate-50 border-transparent hover:border-slate-300 hover:bg-white group outline-none focus:ring-2 focus:ring-emerald-500" data-target="2">
              <div class="flex justify-between items-center pointer-events-none">
                <h4 class="text-xl font-bold text-slate-700 group-hover:text-emerald-600 transition-colors">02. Sovereign Security</h4>
                <div class="w-6 h-6 rounded-full bg-emerald-100 text-emerald-600 flex items-center justify-center opacity-0 transition-opacity trigger-icon">
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M9 5l7 7-7 7"/></svg>
                </div>
              </div>
            </button>

            <button class="matrix-trigger w-full text-left p-6 rounded-xl border-2 transition-all duration-300 bg-slate-50 border-transparent hover:border-slate-300 hover:bg-white group outline-none focus:ring-2 focus:ring-emerald-500" data-target="3">
              <div class="flex justify-between items-center pointer-events-none">
                <h4 class="text-xl font-bold text-slate-700 group-hover:text-emerald-600 transition-colors">03. FMGE Proven Data</h4>
                <div class="w-6 h-6 rounded-full bg-emerald-100 text-emerald-600 flex items-center justify-center opacity-0 transition-opacity trigger-icon">
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M9 5l7 7-7 7"/></svg>
                </div>
              </div>
            </button>
          </div>
        </div>
      </div>
    </section>

    <section id="dynamic-dossier-index" class="relative w-full min-h-screen bg-[#030712] font-sans border-t border-slate-800/50 py-24 lg:py-32 flex flex-col justify-center selection:bg-amber-500/30 selection:text-amber-200">
      
      <div class="absolute inset-0 z-0 opacity-20 pointer-events-none mix-blend-overlay" style="background-image: url('data:image/svg+xml,%3Csvg viewBox=%220 0 200 200%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22noiseFilter%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.65%22 numOctaves=%223%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23noiseFilter)%22/%3E%3C/svg%3E');"></div>

      <div class="container mx-auto px-6 lg:px-12 w-full max-w-7xl relative z-10">
        
        <div class="max-w-4xl mb-16">
          <div class="inline-flex items-center gap-3 px-4 py-1.5 rounded-full bg-slate-900/80 border border-white/5 text-[10px] font-bold uppercase tracking-[0.2em] mb-6 shadow-2xl backdrop-blur-sm">
            <div class="w-1.5 h-1.5 bg-emerald-500 animate-pulse shadow-[0_0_8px_rgba(16,185,129,0.8)]"></div>
            <span class="text-slate-400">Live Global Audit Directory</span>
          </div>
          
          <h2 class="text-4xl lg:text-5xl font-serif text-slate-200 leading-[1.15] tracking-tight mb-6">
            We do not sell 195 countries. <br/>
            <span class="text-slate-500 italic">We strictly place in verified Safe Zones.</span>
          </h2>
          <p class="text-lg text-slate-400 font-medium leading-relaxed max-w-2xl">
