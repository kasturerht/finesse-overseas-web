<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const triggers = document.querySelectorAll('.matrix-trigger');
    const states = document.querySelectorAll('.matrix-data-state');

    triggers.forEach(trigger => {
      
      // Changed to 'mouseenter' for an even faster, click-free experience.
      // (Can change back to 'click' if you prefer parents to explicitly click)
      trigger.addEventListener('mouseenter', function() {
        const targetId = this.getAttribute('data-target');

        // 1. Reset all triggers
        triggers.forEach(t => {
          t.classList.remove('bg-white', 'border-slate-900', 'shadow-md');
          t.classList.add('bg-slate-50', 'border-transparent');
          t.querySelector('h4').classList.remove('text-slate-900');
          t.querySelector('h4').classList.add('text-slate-700');
          t.querySelector('.trigger-icon').classList.remove('opacity-100');
          t.querySelector('.trigger-icon').classList.add('opacity-0');
        });

        // 2. Activate the hovered trigger
        this.classList.remove('bg-slate-50', 'border-transparent');
        this.classList.add('bg-white', 'border-slate-900', 'shadow-md');
        this.querySelector('h4').classList.remove('text-slate-700');
        this.querySelector('h4').classList.add('text-slate-900');
        this.querySelector('.trigger-icon').classList.remove('opacity-0');
        this.querySelector('.trigger-icon').classList.add('opacity-100');

        // 3. Switch the Data Canvas State
        states.forEach(state => {
          if (state.id === `data-state-${targetId}`) {
            state.classList.remove('opacity-0', 'translate-y-8', 'pointer-events-none');
            state.classList.add('opacity-100', 'translate-y-0');
          } else {
            state.classList.remove('opacity-100', 'translate-y-0');
            state.classList.add('opacity-0', 'translate-y-8', 'pointer-events-none');
          }
        });
      });
    });
  });
</script>





