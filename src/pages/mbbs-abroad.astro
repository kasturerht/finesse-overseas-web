<style is:global>
  /* A11y & Performance enhancements */
  .will-change-mask {
    will-change: mask-image, -webkit-mask-image;
  }
  .will-change-transform {
    will-change: transform, opacity;
  }
  
  /* X-Ray Engine Mask variables */
  #facade-layer {
    --mouse-x: 50%;
    --mouse-y: 50%;
    --mask-size: 0px; 
    -webkit-mask-image: radial-gradient(circle var(--mask-size) at var(--mouse-x) var(--mouse-y), transparent 0%, transparent 80%, black 100%);
    mask-image: radial-gradient(circle var(--mask-size) at var(--mouse-x) var(--mouse-y), transparent 0%, transparent 80%, black 100%);
  }
  
  /* Shared Custom Scrollbar */
  .custom-scrollbar::-webkit-scrollbar { width: 4px; }
  .custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
  .custom-scrollbar::-webkit-scrollbar-thumb { background: #1e293b; border-radius: 4px; }
  .custom-scrollbar::-webkit-scrollbar-thumb:hover { background: #334155; }
</style>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    
    // --- 1. HERO SLIDERS LOGIC ---
    const neetSlider = document.getElementById('neetSlider');
    const budgetSlider = document.getElementById('budgetSlider');
    const matchCount = document.getElementById('matchCount');
    const fmgeRate = document.getElementById('fmgeRate');

    if(neetSlider && budgetSlider) {
      function updateLogic() {
        let score = parseInt(neetSlider.value);
        let budget = parseInt(budgetSlider.value);

        document.getElementById('scoreValue').innerText = score;
        document.getElementById('budgetValue').innerText = '₹' + budget + 'L';

        let baseMatches = 0;
        let baseFmge = 0;

        if(budget >= 15 && budget <= 20) { baseMatches += 3; baseFmge = 24; }
        else if(budget > 20 && budget <= 35) { baseMatches += 12; baseFmge = 38; }
        else if(budget > 35) { baseMatches += 24; baseFmge = 45; }

        if(score > 300) baseMatches += 2;
        if(score > 450) baseMatches += 4;

        matchCount.innerText = baseMatches;
        fmgeRate.innerText = baseFmge + '%';
      }
      neetSlider.addEventListener('input', updateLogic);
      budgetSlider.addEventListener('input', updateLogic);
    }

    // --- 2. X-RAY SCANNER (TOUCH & MOUSE ENABLED) ---
    const interactiveBox = document.getElementById('interactive-xray-box');
    const facadeLayer = document.getElementById('facade-layer');
    const lens = document.getElementById('xray-lens');

    if (interactiveBox && facadeLayer && lens) {
      let targetX = interactiveBox.offsetWidth / 2;
      let targetY = interactiveBox.offsetHeight / 2;
      let currentX = targetX;
      let currentY = targetY;
      let targetMaskSize = 0;
      let currentMaskSize = 0;
      const maxMaskSize = window.innerWidth < 1024 ? 110 : 175;

      const updateCoordinates = (clientX, clientY) => {
        const rect = interactiveBox.getBoundingClientRect();
        targetX = clientX - rect.left;
        targetY = clientY - rect.top;
      };

      // Desktop Events
      interactiveBox.addEventListener('mousemove', (e) => updateCoordinates(e.clientX, e.clientY));
      interactiveBox.addEventListener('mouseenter', () => { lens.style.opacity = '1'; targetMaskSize = maxMaskSize; });
      interactiveBox.addEventListener('mouseleave', () => { lens.style.opacity = '0'; targetMaskSize = 0; });

      // Mobile Touch Events
      interactiveBox.addEventListener('touchstart', (e) => {
        lens.style.opacity = '1';
        targetMaskSize = maxMaskSize;
        if(e.touches.length > 0) updateCoordinates(e.touches[0].clientX, e.touches[0].clientY);
      }, { passive: true });

      interactiveBox.addEventListener('touchmove', (e) => {
        if (e.cancelable) e.preventDefault(); // Lock screen scroll when scanning
        if(e.touches.length > 0) updateCoordinates(e.touches[0].clientX, e.touches[0].clientY);
      }, { passive: false });

      interactiveBox.addEventListener('touchend', () => {
        lens.style.opacity = '0';
        targetMaskSize = 0;
      });

      function animateXRay() {
        currentX += (targetX - currentX) * 0.15;
        currentY += (targetY - currentY) * 0.15;
        currentMaskSize += (targetMaskSize - currentMaskSize) * 0.15;

        lens.style.transform = `translate(calc(${currentX}px - 50%), calc(${currentY}px - 50%))`;
        facadeLayer.style.setProperty('--mouse-x', `${currentX}px`);
        facadeLayer.style.setProperty('--mouse-y', `${currentY}px`);
        facadeLayer.style.setProperty('--mask-size', `${currentMaskSize}px`);

        requestAnimationFrame(animateXRay);
      }
      animateXRay();
    }

    // --- 3. SAFETY MATRIX LOGIC (TOUCH & MOUSE) ---
    const matrixTriggers = document.querySelectorAll('.matrix-trigger');
    const matrixStates = document.querySelectorAll('.matrix-data-state');

    function activateMatrixState(triggerElement) {
      const targetId = triggerElement.getAttribute('data-target');

      matrixTriggers.forEach(t => {
        t.classList.remove('bg-white', 'border-slate-900', 'shadow-md');
        t.classList.add('bg-slate-50', 'border-transparent');
        t.querySelector('h4').classList.remove('text-slate-900');
        t.querySelector('h4').classList.add('text-slate-700');
        t.querySelector('.trigger-icon').classList.remove('opacity-100');
        t.querySelector('.trigger-icon').classList.add('opacity-0');
      });

      triggerElement.classList.remove('bg-slate-50', 'border-transparent');
      triggerElement.classList.add('bg-white', 'border-slate-900', 'shadow-md');
      triggerElement.querySelector('h4').classList.remove('text-slate-700');
      triggerElement.querySelector('h4').classList.add('text-slate-900');
      triggerElement.querySelector('.trigger-icon').classList.remove('opacity-0');
      triggerElement.querySelector('.trigger-icon').classList.add('opacity-100');

      matrixStates.forEach(state => {
        if (state.id === `data-state-${targetId}`) {
          state.classList.remove('opacity-0', 'translate-y-8', 'pointer-events-none');
          state.classList.add('opacity-100', 'translate-y-0');
        } else {
          state.classList.remove('opacity-100', 'translate-y-0');
          state.classList.add('opacity-0', 'translate-y-8', 'pointer-events-none');
        }
      });
    }

    matrixTriggers.forEach(trigger => {
      trigger.addEventListener('mouseenter', function() { activateMatrixState(this); });
      trigger.addEventListener('click', function(e) { e.preventDefault(); activateMatrixState(this); }); 
    });

    // --- 4. DYNAMIC DOSSIER LEDGER LOGIC ---
    const dossierRows = document.querySelectorAll('.country-row');
    const outputPanel = document.getElementById('dossier-output');
    const vaultGlow = document.getElementById('vault-glow');
    
    const outCountry = document.getElementById('out-country');
    const outUniv = document.getElementById('out-univ');
    const outFmge = document.getElementById('out-fmge');
    const outBeds = document.getElementById('out-beds');
    const outOwnership = document.getElementById('out-ownership');
    const outMedium = document.getElementById('out-medium');

    function activateDossierRow(rowElement) {
      dossierRows.forEach(r => {
        r.querySelector('.row-title').classList.remove('text-emerald-400', 'translate-x-2');
        r.querySelector('.row-title').classList.add('text-slate-500');
        r.querySelector('.row-subtitle').classList.remove('text-emerald-500/80');
        r.querySelector('.row-subtitle').classList.add('text-slate-600');
        r.querySelector('.indicator-line').classList.remove('h-3/4', 'opacity-100');
        r.querySelector('.indicator-line').classList.add('h-0', 'opacity-0');
        r.querySelector('.active-bg').classList.remove('opacity-100');
        r.querySelector('.active-bg').classList.add('opacity-0');
      });

      rowElement.querySelector('.row-title').classList.remove('text-slate-500');
      rowElement.querySelector('.row-title').classList.add('text-emerald-400', 'translate-x-2');
      rowElement.querySelector('.row-subtitle').classList.remove('text-slate-600');
      rowElement.querySelector('.row-subtitle').classList.add('text-emerald-500/80');
      rowElement.querySelector('.indicator-line').classList.remove('h-0', 'opacity-0');
      rowElement.querySelector('.indicator-line').classList.add('h-3/4', 'opacity-100');
      rowElement.querySelector('.active-bg').classList.remove('opacity-0');
      rowElement.querySelector('.active-bg').classList.add('opacity-100');

      const data = {
        country: rowElement.getAttribute('data-country'),
        univ: rowElement.getAttribute('data-univ'),
        fmge: rowElement.getAttribute('data-fmge'),
        beds: rowElement.getAttribute('data-beds'),
        ownership: rowElement.getAttribute('data-ownership'),
        medium: rowElement.getAttribute('data-medium')
      };

      outputPanel.style.opacity = '0';
      outputPanel.style.transform = 'translateY(15px)';
      vaultGlow.style.opacity = '0.3'; 

      setTimeout(() => {
        outCountry.textContent = data.country;
        outUniv.textContent = data.univ;
        outFmge.textContent = data.fmge;
        outBeds.textContent = data.beds;
        outOwnership.textContent = data.ownership;
        
        outMedium.innerHTML = `<span class="w-1.5 h-1.5 rounded-full ${data.medium.includes('Alert') ? 'bg-amber-400' : 'bg-emerald-400'}"></span>${data.medium}`;
        if(data.medium.includes('Alert')) {
          outMedium.className = "inline-flex items-center gap-2 text-amber-400 font-mono text-xs uppercase tracking-widest border border-amber-500/30 bg-amber-500/10 px-4 py-2 rounded-md shadow-[0_0_15px_rgba(245,158,11,0.1)]";
        } else {
          outMedium.className = "inline-flex items-center gap-2 text-emerald-400 font-mono text-xs uppercase tracking-widest border border-emerald-500/30 bg-emerald-500/10 px-4 py-2 rounded-md shadow-[0_0_15px_rgba(16,185,129,0.1)]";
        }

        outputPanel.style.opacity = '1';
        outputPanel.style.transform = 'translateY(0)';
        vaultGlow.style.opacity = '1';
      }, 350); 
    }

    dossierRows.forEach(row => {
      row.addEventListener('mouseenter', function() { activateDossierRow(this); });
      row.addEventListener('click', function(e) { e.preventDefault(); activateDossierRow(this); }); 
    });

    if(dossierRows.length > 0) {
      activateDossierRow(dossierRows[0]);
    }

  });
</script>