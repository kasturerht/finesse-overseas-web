---
// src/pages/study-in-germany.astro
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Study in Germany for FREE | 2026 Intake | Finesse Overseas">
  
  <main class="pt-20 flex-grow">

<section class="relative bg-slate-950 pt-16 pb-24 lg:pt-24 lg:pb-32 overflow-hidden border-b border-slate-800">
  
  <div class="absolute inset-0 z-0 overflow-hidden pointer-events-none">
    <div class="absolute top-[-10%] right-[-5%] w-[600px] h-[600px] bg-teal-500/10 rounded-full blur-[120px] hidden md:block hidden md:block"></div>
    <div class="absolute bottom-[-10%] left-[-5%] w-[500px] h-[500px] bg-blue-600/10 rounded-full blur-[120px] hidden md:block hidden md:block"></div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-12 border-b border-slate-800/60 pb-6">
      <nav class="flex text-xs font-bold tracking-widest uppercase text-slate-400">
        <a href="/" class="hover:text-teal-400 transition-colors">Home</a>
        <span class="mx-2">/</span>
        <span class="text-slate-500">Destinations</span>
        <span class="mx-2">/</span>
        <span class="text-white">Germany</span>
      </nav>
      
      <div class="inline-flex items-center gap-2 bg-slate-900/80 border border-slate-700/50 rounded-full px-4 py-1.5 backdrop-blur-md shadow-sm">
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
        </span>
        <span class="text-[10px] font-bold text-slate-300 uppercase tracking-wider">Verified by Jayant Patil | Feb 2026</span>
      </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-center">
      
      <div class="lg:col-span-7">
        
        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-lg bg-teal-500/10 border border-teal-500/20 text-teal-400 font-bold tracking-widest uppercase mb-6 text-xs shadow-inner">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
          2026 Intake is Open
        </div>
        
        <h1 class="text-5xl md:text-6xl lg:text-[4.5rem] font-black text-white mb-6 tracking-tighter leading-[1.05]">
          Study in Germany for <span class="text-transparent bg-clip-text bg-gradient-to-r from-teal-400 to-emerald-300">FREE</span>
        </h1>
        
        <p class="text-xl md:text-2xl text-slate-300 font-medium mb-5 leading-relaxed max-w-2xl">
          Join 1000+ Students from Maharashtra in Top Public Universities. <span class="text-white font-bold">World-Class Engineering & Management at 0 Cost.</span>
        </p>
        
        <p class="text-lg text-slate-400 mb-10 flex items-center gap-3">
          <span class="w-6 h-6 rounded-full bg-teal-500/20 flex items-center justify-center shrink-0 border border-teal-500/30">
            <svg class="w-3.5 h-3.5 text-teal-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
          </span>
          Includes 18-Month Post Study Job Seeker Visa.
        </p>

        <div class="flex flex-col sm:flex-row gap-4 mb-14">
          <a href="/contact" class="flex justify-center items-center gap-2 bg-gradient-to-r from-teal-500 to-emerald-400 hover:from-teal-400 hover:to-emerald-300 text-slate-950 px-8 py-4.5 rounded-xl text-lg font-black transition-all shadow-[0_0_30px_rgba(20,184,166,0.25)] active:scale-95 group">
            Check My Eligibility
            <svg class="w-5 h-5 transform group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
          </a>
          
          <a href="#process-guide" class="flex justify-center items-center gap-2 bg-slate-900 hover:bg-slate-800 text-white border border-slate-700 hover:border-slate-500 px-8 py-4.5 rounded-xl text-lg font-bold transition-all active:scale-95 group shadow-sm">
            <svg class="w-5 h-5 text-slate-400 group-hover:text-white transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path></svg>
            Download 2026 Guide
          </a>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-8 pt-8 border-t border-slate-800/60">
          <div class="flex items-start gap-3.5">
            <div class="w-10 h-10 rounded-lg bg-slate-900 border border-slate-700/50 flex items-center justify-center shrink-0 shadow-inner">
              <svg class="w-5 h-5 text-teal-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138z"></path></svg>
            </div>
            <div>
              <p class="text-white font-bold text-sm tracking-wide">Authorized APS Partner</p>
              <p class="text-slate-500 text-xs mt-1 font-medium">We handle complex paperwork.</p>
            </div>
          </div>
          
          <div class="flex items-start gap-3.5">
            <div class="w-10 h-10 rounded-lg bg-slate-900 border border-slate-700/50 flex items-center justify-center shrink-0 shadow-inner">
              <svg class="w-5 h-5 text-teal-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path></svg>
            </div>
            <div>
              <p class="text-white font-bold text-sm tracking-wide">100% Visa Success</p>
              <p class="text-slate-500 text-xs mt-1 font-medium">Recorded for 2025 intake.</p>
            </div>
          </div>
        </div>

      </div>

      <div class="lg:col-span-5 hidden lg:block relative z-20">
        
        <div class="absolute -inset-2 bg-gradient-to-tr from-teal-500/20 to-emerald-400/20 blur-2xl rounded-[3rem] opacity-70"></div>

        <div class="relative w-full aspect-[4/5] rounded-[2.5rem] p-3 bg-slate-800/30 border border-slate-700/50 backdrop-blur-xl shadow-2xl">
          
          <div class="relative w-full h-full rounded-[2rem] overflow-hidden group">
            
            <img 
  src="/germany-hero.avif" 
  alt="Premium German University Campus" 
  width="1920"
  height="1080"
  fetchpriority="high"
  loading="eager"
  decoding="sync"
  class="absolute inset-0 w-full h-full object-cover object-center transform group-hover:scale-110 transition-transform duration-[2000ms] ease-out"
/>
            
            <div class="absolute inset-0 bg-gradient-to-t from-slate-950 via-slate-900/20 to-transparent opacity-90"></div>

            <div class="absolute bottom-6 left-6 right-auto bg-white/10 backdrop-blur-2xl border border-white/20 p-3.5 pr-6 rounded-2xl flex items-center gap-4 shadow-[0_8px_32px_rgba(0,0,0,0.5)] transform translate-y-1 group-hover:translate-y-0 transition-all duration-500">
              
              <div class="w-12 h-12 bg-teal-500/20 rounded-xl border border-teal-500/30 flex items-center justify-center text-teal-400 font-black text-xl shadow-inner shrink-0">
                €0
              </div>
              
              <div>
                <p class="text-white font-bold text-sm tracking-wide">Public Universities</p>
                <p class="text-teal-300 font-medium text-[11px] uppercase tracking-wider mt-1">100% Tuition Waived</p>
              </div>

            </div>

            <div class="absolute top-6 right-6 bg-slate-900/60 backdrop-blur-md border border-white/10 px-3 py-1.5 rounded-full flex items-center gap-2">
              <span class="w-1.5 h-1.5 rounded-full bg-emerald-400"></span>
              <span class="text-white text-[9px] font-bold tracking-widest uppercase">Premium Education</span>
            </div>

          </div>
        </div>
      </div>

    </div>
  </div>
</section>


<section class="py-24 bg-slate-50 relative overflow-hidden" id="advantage">
      
      <div class="absolute inset-0 opacity-[0.03] pointer-events-none" style="background-image: radial-gradient(#000 1px, transparent 1px); background-size: 32px 32px;"></div>

      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">

        <div class="max-w-2xl mb-16">
          <span class="text-teal-600 font-bold tracking-widest uppercase mb-3 block text-sm">Why Germany?</span>
          <h2 class="text-4xl md:text-5xl font-extrabold text-slate-900 tracking-tight mb-5 leading-tight">
            Not Just Free Education.<br/>A <span class="text-transparent bg-clip-text bg-gradient-to-r from-teal-600 to-emerald-500">Career Launchpad.</span>
          </h2>
          <p class="text-slate-600 text-lg leading-relaxed font-medium">
            Germany is the economic engine of Europe. It needs <span class="text-slate-900 font-bold">400,000 skilled workers every year</span>. Here is why it is the #1 choice for Indian students.
          </p>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

          <div class="lg:col-span-2 bg-slate-950 rounded-[2.5rem] p-8 md:p-12 relative overflow-hidden group shadow-xl">
            <div class="absolute top-0 right-0 w-80 h-80 bg-teal-500/10 rounded-full blur-[80px] hidden md:block group-hover:bg-teal-500/20 transition-colors duration-700 pointer-events-none"></div>

            <div class="relative z-10 flex flex-col h-full justify-between">
              <div>
                <div class="w-14 h-14 bg-slate-800/80 rounded-2xl border border-slate-700/50 flex items-center justify-center mb-8 shadow-inner">
                  <svg class="w-7 h-7 text-teal-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path></svg>
                </div>
                <h3 class="text-3xl md:text-4xl font-black text-white mb-4 tracking-tight">3 Million Jobs by 2030</h3>
                <p class="text-slate-400 text-lg leading-relaxed max-w-md">
                  With an aging population, Germany has a massive shortage of <span class="text-slate-200 font-bold">Engineers, IT Professionals, and Managers.</span>
                </p>
              </div>

              <div class="mt-16 flex items-end gap-3 h-32 md:h-40 relative">
                <div class="absolute inset-0 flex flex-col justify-between opacity-10 pointer-events-none">
                  <div class="w-full h-px bg-white"></div>
                  <div class="w-full h-px bg-white"></div>
                  <div class="w-full h-px bg-white"></div>
                </div>

                <div class="w-full bg-slate-800 rounded-t-xl relative group-hover:bg-slate-700 transition-colors duration-500 h-[40%] flex justify-center">
                  <span class="absolute -top-7 text-xs font-bold text-slate-500">2024</span>
                </div>
                <div class="w-full bg-slate-800 rounded-t-xl relative group-hover:bg-slate-700 transition-colors duration-500 delay-75 h-[65%] flex justify-center">
                  <span class="absolute -top-7 text-xs font-bold text-slate-500">2026</span>
                </div>
                <div class="w-full bg-gradient-to-t from-teal-500/40 to-emerald-400/80 border-t-2 border-emerald-300 rounded-t-xl relative h-[100%] shadow-[0_-10px_30px_rgba(52,211,153,0.3)] transform origin-bottom group-hover:scale-y-105 transition-transform duration-700">
                  <span class="absolute -top-8 text-sm font-black text-teal-300 drop-shadow-md">2030</span>
                </div>
              </div>
            </div>
          </div>

          <div class="flex flex-col gap-6">

            <div class="bg-white rounded-[2.5rem] p-8 border border-slate-200 hover:border-teal-300 transition-all duration-500 shadow-sm hover:shadow-xl flex-1 flex flex-col justify-center relative overflow-hidden group">
               <div class="absolute -right-8 -top-8 w-32 h-32 bg-teal-50 rounded-full blur-3xl group-hover:bg-teal-100 transition-colors duration-500"></div>
               
               <h3 class="text-2xl font-black text-slate-900 mb-3 relative z-10">Public vs Private</h3>
               <p class="text-slate-600 mb-8 font-medium leading-relaxed relative z-10">In Germany, Public Universities are prestigious and free. Private universities charge high fees.</p>
               
               <div class="bg-teal-50/80 border border-teal-100 rounded-2xl p-5 flex items-start gap-4 relative z-10 shadow-inner group-hover:bg-teal-50 transition-colors">
                 <div class="w-10 h-10 bg-teal-500 rounded-full flex items-center justify-center shrink-0 shadow-md">
                    <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
                 </div>
                 <p class="font-extrabold text-teal-900 text-sm leading-snug pt-0.5">We target ONLY Public Universities for you.</p>
               </div>
            </div>

            <div class="bg-slate-900 rounded-[2.5rem] p-8 border border-slate-800 hover:border-slate-700 transition-all duration-500 shadow-sm flex-1 flex flex-col justify-center relative overflow-hidden group">
               <div class="absolute right-0 bottom-0 opacity-[0.03] transform translate-x-4 translate-y-4 group-hover:scale-110 transition-transform duration-1000 pointer-events-none">
                  <svg class="w-48 h-48 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
               </div>
               
               <div class="flex items-center gap-3 mb-4 relative z-10">
                 <span class="px-3 py-1 bg-blue-500/20 text-blue-300 text-[10px] font-black tracking-widest uppercase rounded-md border border-blue-500/30">Visa Power</span>
               </div>
               
               <h3 class="text-2xl font-black text-white mb-3 relative z-10 tracking-tight">Schengen Access</h3>
               <p class="text-slate-400 font-medium text-sm leading-relaxed relative z-10">
                 Your student visa unlocks travel across <span class="text-teal-400 font-bold">29 European countries</span> including France, Italy, and Switzerland.
               </p>
            </div>

          </div>

        </div>
      </div>
    </section>


    <section class="py-24 bg-slate-950 relative overflow-hidden border-t border-slate-800" id="cost-roi">
      
      <div class="absolute inset-0 z-0 overflow-hidden pointer-events-none">
        <div class="absolute top-[20%] left-[-10%] w-[500px] h-[500px] bg-teal-500/5 rounded-full blur-[100px] hidden md:block"></div>
        <div class="absolute bottom-[-20%] right-[-10%] w-[600px] h-[600px] bg-emerald-500/5 rounded-full blur-[120px] hidden md:block"></div>
        <div class="absolute inset-0 bg-[url('data:image/svg+xml;base64,PHN2ZyB3aWR0aD0iNjAiIGhlaWdodD0iNjAiIHhtbG5zPSJodHRwOi8vd3d3LnczLm9yZy8yMDAwL3N2ZyI+CgkJPGcgc3Ryb2tlPSIjMWUyOTNiIiBzdHJva2Utd2lkdGg9IjEiIGZpbGw9Im5vbmUiIGZpbGwtcnVsZT0iZXZlbm9kZCI+CgkJCTxwb2x5Z29uIHBvaW50cz0iMCw2MCA2MCwwIDYwLDYwIiBvcGFjaXR5PSIwLjE1Ii8+CgkJPC9nPgoJPC9zdmc+')] opacity-20"></div>
      </div>

      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">

        <div class="text-center max-w-3xl mx-auto mb-20">
          <span class="inline-block px-4 py-1.5 rounded-full bg-slate-900 border border-slate-700 text-teal-400 font-bold tracking-widest uppercase mb-6 text-xs shadow-sm">Financial Transparency</span>
          <h2 class="text-4xl md:text-5xl lg:text-6xl font-black text-white tracking-tighter mb-6 leading-tight">
            Is it Really Free?<br/>
            <span class="text-transparent bg-clip-text bg-gradient-to-r from-slate-400 to-slate-200">The Honest Breakdown.</span>
          </h2>
          <p class="text-slate-400 text-lg md:text-xl font-medium leading-relaxed">
            Many students ask: "If tuition is zero, what do I actually pay?" We don't hide the facts. Here is exactly what you need to plan for.
          </p>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-16 items-start">
          
          <div class="lg:col-span-6 space-y-4">
            
            <div class="bg-slate-900/50 backdrop-blur-md border border-teal-500/30 rounded-3xl p-6 md:p-8 flex items-center justify-between group hover:bg-slate-900/80 transition-colors shadow-[0_0_30px_rgba(20,184,166,0.05)] relative overflow-hidden">
              <div class="absolute left-0 top-0 bottom-0 w-1 bg-teal-500"></div>
              <div>
                <h4 class="text-xl font-bold text-white mb-1">Tuition Fee</h4>
                <p class="text-sm text-slate-400 font-medium">100% Waived in Public Universities.</p>
              </div>
              <div class="text-right">
                <span class="text-4xl font-black text-transparent bg-clip-text bg-gradient-to-br from-teal-400 to-emerald-300">€0</span>
              </div>
            </div>

            <div class="bg-slate-900/40 backdrop-blur-md border border-slate-800 rounded-3xl p-6 md:p-8 flex items-center justify-between group hover:border-slate-700 transition-colors">
              <div>
                <h4 class="text-xl font-bold text-white mb-1">Semester Contribution</h4>
                <p class="text-sm text-slate-400 font-medium max-w-[200px] md:max-w-xs">Paid every 6 months. Includes Free Public Transport (Bus/Train).</p>
              </div>
              <div class="text-right shrink-0">
                <span class="text-2xl font-black text-white">€250</span>
                <span class="text-sm text-slate-500 block font-bold">- €300</span>
              </div>
            </div>

            <div class="bg-slate-900/40 backdrop-blur-md border border-slate-800 rounded-3xl p-6 md:p-8 flex items-center justify-between group hover:border-slate-700 transition-colors">
              <div>
                <h4 class="text-xl font-bold text-white mb-1 flex items-center gap-2">
                  Living Cost 
                  <span class="px-2 py-0.5 rounded text-[10px] uppercase tracking-wider font-bold bg-slate-800 text-slate-300 border border-slate-700">Required for Visa</span>
                </h4>
                <p class="text-sm text-slate-400 font-medium max-w-[200px] md:max-w-xs">Mandatory Blocked Account deposit. Comes back to you monthly.</p>
              </div>
              <div class="text-right shrink-0">
                <span class="text-2xl font-black text-white">€934</span>
                <span class="text-sm text-slate-500 block font-bold">/ Month</span>
              </div>
            </div>

          </div>

          <div class="lg:col-span-6 flex flex-col h-full gap-8">
            
            <div class="bg-gradient-to-br from-slate-900 to-slate-950 border border-slate-800 rounded-[2.5rem] p-8 md:p-10 shadow-2xl relative overflow-hidden group">
              <div class="absolute top-0 right-0 w-64 h-64 bg-emerald-500/10 rounded-full blur-[80px] hidden md:block pointer-events-none"></div>

              <div class="relative z-10">
                <div class="inline-flex items-center gap-2 px-3 py-1 rounded-md bg-emerald-500/10 border border-emerald-500/20 text-emerald-400 font-bold tracking-widest uppercase mb-6 text-[10px]">
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path></svg>
                  Your ROI Power
                </div>
                
                <h3 class="text-3xl font-black text-white mb-2 tracking-tight">Part-time Earnings</h3>
                <p class="text-slate-400 font-medium mb-10">You can legally work 20 hours/week. Your earnings easily cover your living costs!</p>

                <div class="space-y-6">
                  <div>
                    <div class="flex justify-between text-sm font-bold mb-2">
                      <span class="text-emerald-400">Estimated Income</span>
                      <span class="text-white">€1,000 - €1,200 /mo</span>
                    </div>
                    <div class="w-full h-3 bg-slate-800 rounded-full overflow-hidden">
                      <div class="h-full bg-gradient-to-r from-emerald-500 to-teal-400 rounded-full w-[100%]"></div>
                    </div>
                  </div>

                  <div>
                    <div class="flex justify-between text-sm font-bold mb-2">
                      <span class="text-slate-400">Living Expense (Blocked A/c)</span>
                      <span class="text-slate-300">€934 /mo</span>
                    </div>
                    <div class="w-full h-3 bg-slate-800 rounded-full overflow-hidden">
                      <div class="h-full bg-slate-500 rounded-full w-[78%] relative">
                         <div class="absolute right-0 top-0 bottom-0 w-0.5 bg-slate-900"></div>
                      </div>
                    </div>
                  </div>
                </div>
                
                <div class="mt-8 pt-6 border-t border-slate-800/80 flex items-center justify-between">
                  <span class="text-sm font-bold text-slate-400 uppercase tracking-widest">Result</span>
                  <span class="text-lg font-black text-emerald-400">Positive Cashflow</span>
                </div>

              </div>
            </div>

            <div class="bg-slate-800/30 backdrop-blur-md border border-slate-700/50 rounded-3xl p-6 md:p-8 relative">
              <svg class="absolute top-6 left-6 w-10 h-10 text-slate-700/50 transform -scale-x-100" fill="currentColor" viewBox="0 0 24 24"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/></svg>
              
              <div class="relative z-10 pl-14">
                <span class="text-teal-400 font-bold tracking-widest uppercase mb-2 block text-[10px]">Expert Note</span>
                <p class="text-white text-lg font-medium leading-relaxed italic mb-4">
                  "You don't need an education loan for tuition. You only need living expenses for the first year. After that, your part-time job covers everything."
