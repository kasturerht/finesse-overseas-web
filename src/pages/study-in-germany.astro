    <script>
  const initFaqs = () => {
    const faqItems = document.querySelectorAll('.faq-item');

    faqItems.forEach(item => {
      const button = item.querySelector('.faq-button');
      const answer = item.querySelector('.faq-answer');
      const icon = item.querySelector('.faq-icon');
      const iconSvg = icon?.querySelector('svg');

      // Check if event listener is already attached to prevent double-firing
      if (button && answer && icon && iconSvg && !button.hasAttribute('data-faq-initialized')) {
        
        // Mark as initialized
        button.setAttribute('data-faq-initialized', 'true');

        button.addEventListener('click', () => {
          const isExpanded = button.getAttribute('aria-expanded') === 'true';
          
          // Auto-close others
          faqItems.forEach(otherItem => {
            if (otherItem !== item) {
              const otherBtn = otherItem.querySelector('.faq-button');
              const otherAns = otherItem.querySelector('.faq-answer');
              const otherIc = otherItem.querySelector('.faq-icon');
              const otherSvg = otherIc?.querySelector('svg');
              
              if (otherBtn && otherAns && otherIc && otherSvg) {
                otherBtn.setAttribute('aria-expanded', 'false');
                otherAns.classList.remove('grid-rows-[1fr]', 'opacity-100');
                otherAns.classList.add('grid-rows-[0fr]', 'opacity-50');
                otherIc.classList.remove('bg-teal-500', 'text-white', 'border-teal-500');
                otherSvg.classList.remove('rotate-45');
                otherItem.classList.remove('border-teal-500', 'shadow-md');
              }
            }
          });

          // Toggle Current
          button.setAttribute('aria-expanded', (!isExpanded).toString());
          
          if (!isExpanded) {
            answer.classList.remove('grid-rows-[0fr]', 'opacity-50');
            answer.classList.add('grid-rows-[1fr]', 'opacity-100');
            icon.classList.add('bg-teal-500', 'text-white', 'border-teal-500');
            iconSvg.classList.add('rotate-45'); // Magic trick: '+' becomes 'x'
            item.classList.add('border-teal-500', 'shadow-md');
          } else {
            answer.classList.remove('grid-rows-[1fr]', 'opacity-100');
            answer.classList.add('grid-rows-[0fr]', 'opacity-50');
            icon.classList.remove('bg-teal-500', 'text-white', 'border-teal-500');
            iconSvg.classList.remove('rotate-45');
            item.classList.remove('border-teal-500', 'shadow-md');
          }
        });
      }
    });
  };

  // Run on initial page load
  initFaqs();
  
  // Run when navigating between pages (Astro View Transitions support)
  document.addEventListener('astro:page-load', initFaqs);
</script>


