---
import Layout from '../layouts/Layout.astro';
---

<style is:global>
  /* 🚨 POINT 10: The "No-Escape" Funnel */
  header, nav, #top-bar, .navbar, .header-main,
  [class*="Header"], [class*="Navbar"], [id*="topbar"] { 
    display: none !important; visibility: hidden !important;
    opacity: 0 !important; pointer-events: none !important;
    height: 0 !important; overflow: hidden !important;
  }
  
  /* Luxury Form Input Autofill Fix */
  input:-webkit-autofill {
    -webkit-box-shadow: 0 0 0 50px white inset;
    -webkit-text-fill-color: #0f172a;
  }

  /* Remove arrows from number input */
  input[type="number"]::-webkit-inner-spin-button,
  input[type="number"]::-webkit-outer-spin-button {
    -webkit-appearance: none; margin: 0;
  }
</style>

<Layout 
  title="Stop Being Misled by Agents | Finesse Overseas Education"
  description="Don't let agents push you into private universities for commissions. Get 100% transparent guidance for Germany."
>

  <div class="w-full bg-white/95 backdrop-blur-xl border-b border-slate-100 fixed top-0 z-[100] transition-all duration-300">
    <div class="container mx-auto px-6 max-w-[85rem] h-20 flex justify-between items-center">
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 bg-slate-900 rounded-none flex items-center justify-center text-white font-bold text-xl font-jakarta shadow-[0_4px_10px_rgba(0,0,0,0.1)]">F</div>
        <span class="font-jakarta font-extrabold text-xl text-slate-900 tracking-tighter uppercase">Finesse</span>
      </div>
      <div class="flex items-center gap-8">
        <a href="tel:+919850069600" class="flex items-center gap-2 text-[10px] font-extrabold text-slate-900 uppercase tracking-[0.25em] hover:text-teal-600 transition-colors font-jakarta group p-2">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4 sm:hidden"><path fill-rule="evenodd" d="M1.5 4.5a3 3 0 013-3h1.372c.86 0 1.61.586 1.819 1.42l1.105 4.423a1.875 1.875 0 01-.694 1.955l-1.293.97c-.135.101-.164.249-.126.352a11.285 11.285 0 006.697 6.697c.103.038.25.009.352-.126l.97-1.293a1.875 1.875 0 011.955-.694l4.423 1.105c.834.209 1.42.959 1.42 1.82V19.5a3 3 0 01-3 3h-2.25C8.552 22.5 1.5 15.448 1.5 6.75V4.5z" clip-rule="evenodd" /></svg>
          <span class="hidden sm:inline">Need Help? Call Us</span>
        </a>
      </div>
    </div>
  </div>

  <section class="relative bg-white pt-32 pb-16 lg:pt-44 lg:pb-32 selection:bg-teal-600 selection:text-white overflow-hidden">
    <div class="container mx-auto px-6 max-w-[85rem] relative z-10">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-24 items-start">
        
        <div class="lg:col-span-7 flex flex-col pt-2">
          
          <div class="flex items-center gap-4 mb-8">
            <span class="text-[10px] font-jakarta font-extrabold uppercase tracking-[0.25em] text-teal-600 bg-teal-50 px-3 py-1 border border-teal-100">Zero Tuition Fees</span>
            <div class="h-px bg-slate-200 w-8"></div>
            <span class="text-[10px] font-jakarta font-extrabold uppercase tracking-[0.2em] text-slate-400">For B.E. / M.Com Students</span>
          </div>

          <h1 class="font-jakarta text-5xl sm:text-6xl lg:text-[5.5rem] font-extrabold text-slate-900 leading-[1.02] tracking-tighter mb-8">
            Has Your Agent Kept You <span class="text-slate-400">In The Dark?</span>
          </h1>

          <p class="font-inter text-lg lg:text-xl text-slate-600 max-w-xl leading-relaxed mb-12">
            Don't settle for private universities just for agent commissions. Demand <span class="font-semibold text-slate-900 border-b-2 border-teal-200">100% transparent admission guidance</span> for Germany's top Public Universities.
          </p>

          <div class="relative w-full aspect-video bg-slate-100 border border-slate-200 overflow-hidden group mb-12">
            <img src="/germany-hero.avif" alt="Yash vs Hitesh Story" class="absolute inset-0 w-full h-full object-cover opacity-90 mix-blend-multiply grayscale-[20%] group-hover:grayscale-0 transition-all duration-700" onerror="this.src='https://images.unsplash.com/photo-1523240795612-9a054b0db644?q=80&w=1000&auto=format&fit=crop';">
            <div class="absolute inset-0 flex items-center justify-center">
              <div class="w-20 h-20 bg-slate-900/90 backdrop-blur-sm flex items-center justify-center cursor-pointer hover:bg-teal-600 transition-colors duration-300">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="white" class="w-8 h-8 ml-1"><path fill-rule="evenodd" d="M4.5 5.653c0-1.426 1.529-2.33 2.779-1.643l11.54 6.348c1.295.712 1.295 2.573 0 3.285L7.28 19.991c-1.25.687-2.779-.217-2.779-1.643V5.653z" clip-rule="evenodd" /></svg>
              </div>
            </div>
          </div>

          <div class="flex flex-wrap items-center gap-x-10 gap-y-6 border-t border-slate-200 pt-8">
            <div class="flex flex-col">
              <span class="text-2xl font-jakarta font-extrabold text-slate-900">4.9/5</span>
              <span class="text-[10px] font-jakarta font-bold uppercase tracking-widest text-slate-500">Google Rating</span>
            </div>
            <div class="w-px h-10 bg-slate-200 hidden sm:block"></div>
            <div class="flex flex-col">
              <span class="text-2xl font-jakarta font-extrabold text-slate-900">5000+</span>
              <span class="text-[10px] font-jakarta font-bold uppercase tracking-widest text-slate-500">Students Trusted</span>
            </div>
          </div>

        </div>

        <div class="lg:col-span-5 w-full relative pb-32 lg:pb-0" id="consultation-form">
          <div class="bg-white border border-slate-200 p-8 lg:p-12 shadow-[0_20px_60px_-15px_rgba(0,0,0,0.05)] relative overflow-hidden">
            
            <div class="mb-8">
              <p class="text-[10px] font-extrabold text-slate-400 uppercase tracking-[0.2em] font-jakarta mb-4">Step 1: Check Eligibility</p>
              <h3 class="text-3xl font-extrabold font-jakarta text-slate-900 tracking-tight leading-tight mb-3">Claim Your <br/><span class="text-teal-600">Free</span> Session.</h3>
              
              <p class="text-xs font-inter font-medium text-slate-500 flex items-center gap-2">
                <svg class="w-4 h-4 text-teal-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                Takes only 30 seconds. No commitments.
              </p>
            </div>

            <form class="space-y-6">
              <div class="relative">
                <label class="block text-[10px] font-extrabold text-slate-900 mb-2 font-jakarta uppercase tracking-widest">Full Name</label>
                <input type="text" placeholder="e.g. Yash Patil" class="w-full px-0 py-3 bg-transparent border-b-2 border-slate-200 focus:outline-none focus:border-slate-900 transition-colors font-inter text-[16px] sm:text-sm text-slate-900 placeholder:text-slate-300 rounded-none" required>
              </div>
              
              <div class="relative">
                <label class="block text-[10px] font-extrabold text-slate-900 mb-2 font-jakarta uppercase tracking-widest">WhatsApp Number</label>
                <input type="tel" pattern="[0-9]*" placeholder="+91" class="w-full px-0 py-3 bg-transparent border-b-2 border-slate-200 focus:outline-none focus:border-slate-900 transition-colors font-inter text-[16px] sm:text-sm text-slate-900 placeholder:text-slate-300 rounded-none" required>
              </div>
              
              <div class="relative">
                <label class="block text-[10px] font-extrabold text-slate-900 mb-2 font-jakarta uppercase tracking-widest">Current Education</label>
                <select class="w-full px-0 py-3 bg-transparent border-b-2 border-slate-200 focus:outline-none focus:border-slate-900 transition-colors font-inter text-[16px] sm:text-sm text-slate-900 cursor-pointer rounded-none appearance-none" required>
                  <option value="" disabled selected>Select Degree...</option>
                  <option value="Bachelors">B.E. / B.Tech / B.Com</option>
                  <option value="Masters">M.E. / M.Tech / M.Com</option>
                </select>
                <div class="absolute right-0 bottom-4 pointer-events-none">
                  <svg class="w-4 h-4 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                </div>
              </div>
              
              <div class="mt-6 p-4 bg-slate-50 border border-slate-100 flex items-start gap-3">
                <div class="mt-0.5 text-lg">🎁</div>
                <div>
                  <p class="text-[10px] font-extrabold text-slate-900 uppercase tracking-widest font-jakarta">Exclusive Bonus</p>
                  <p class="text-xs text-slate-500 font-inter mt-1 leading-relaxed">Book today to unlock a <span class="font-bold text-slate-700">Free University Shortlist Audit</span> (Worth ₹5000).</p>
                </div>
              </div>

              <button type="submit" class="w-full bg-slate-900 text-white font-extrabold py-5 mt-2 hover:bg-teal-600 transition-colors duration-300">
                <span class="font-jakarta tracking-[0.15em] text-xs uppercase">Claim My Free Session</span>
              </button>
              
              <p class="text-[10px] text-center text-slate-400 mt-4 font-inter uppercase tracking-wider">
                Data is AES-256 Encrypted
              </p>
            </form>
          </div>
        </div>

      </div>
    </div>
  </section>

  <section class="bg-white pb-20 pt-10 border-t border-slate-100">
    <div class="container mx-auto px-6 max-w-[85rem]">
      <div class="flex flex-col mb-12">
        <p class="text-[10px] font-extrabold text-slate-400 uppercase tracking-[0.2em] font-jakarta mb-2">The Reality Check</p>
        <h2 class="text-3xl lg:text-4xl font-jakarta font-extrabold text-slate-900 tracking-tight">Typical Agents vs <span class="text-teal-600">Finesse Standard</span></h2>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 border border-slate-200">
        <div class="p-8 md:p-12 border-b md:border-b-0 md:border-r border-slate-200 bg-slate-50">
          <h3 class="font-jakarta font-bold text-red-500 mb-8 uppercase tracking-widest text-[11px]">Typical Local Agents</h3>
          <ul class="space-y-5">
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-red-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
              <span class="text-sm font-inter text-slate-600">Push you towards low-ranking Private Universities for commissions.</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-red-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
              <span class="text-sm font-inter text-slate-600">Hide application passwords and rejection emails.</span>
            </li>
          </ul>
        </div>
        
        <div class="p-8 md:p-12 bg-slate-900">
          <h3 class="font-jakarta font-bold text-teal-400 mb-8 uppercase tracking-widest text-[11px]">Finesse Standard</h3>
          <ul class="space-y-5">
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-teal-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
              <span class="text-sm font-inter text-slate-300">Target top-tier German Public Universities with <strong class="text-white">Zero Tuition Fees</strong>.</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-teal-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
              <span class="text-sm font-inter text-slate-300">100% transparent. Direct access to university portals.</span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>
  
  <a href="https://wa.me/919850069600?text=Hi, I want transparent guidance for Germany." target="_blank" class="fixed bottom-[100px] lg:bottom-8 right-6 lg:right-8 z-[95] flex items-center justify-center w-14 h-14 bg-[#25d366] rounded-full shadow-[0_10px_30px_-10px_rgba(37,211,102,0.6)] hover:-translate-y-1 transition-transform group">
    <svg class="w-7 h-7 text-white" fill="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/>
    </svg>
  </a>  

  <div id="live-toast" class="fixed bottom-[100px] lg:bottom-8 left-6 lg:left-8 z-[95] bg-slate-900 border border-slate-800 px-4 py-3 shadow-2xl flex items-center gap-3 transform translate-y-10 opacity-0 transition-all duration-700 pointer-events-none">
    <div class="w-2 h-2 rounded-full bg-teal-500 animate-pulse"></div>
    <div>
      <p class="text-[10px] font-bold text-white font-jakarta uppercase tracking-widest"><span id="toast-name">Aniket</span> (<span id="toast-city">Pune</span>)</p>
      <p class="text-[10px] text-slate-400 font-inter">Secured a session</p>
    </div>
  </div>

  <div class="fixed bottom-0 left-0 w-full bg-white/90 backdrop-blur-xl border-t border-slate-200/60 p-4 pb-6 z-[100] lg:hidden flex justify-between items-center shadow-[0_-10px_40px_rgba(0,0,0,0.08)]">
    <div class="flex flex-col">
      <span class="text-[10px] font-extrabold text-red-500 uppercase tracking-widest">3 Slots Left</span>
      <span class="text-xs font-jakarta font-extrabold text-slate-900 uppercase tracking-widest">Free Session</span>
    </div>
    <a href="#consultation-form" class="bg-slate-900 text-white font-extrabold py-3.5 px-7 text-[10px] uppercase tracking-widest font-jakarta hover:bg-teal-600 transition-colors">
      Book Now
    </a>
  </div>

  <style is:global>
    .toast-show { transform: translateY(0) !important; opacity: 1 !important; }
  </style>

  <script is:inline>
    document.addEventListener("DOMContentLoaded", () => {
      const names = ["Aniket", "Priya", "Rahul", "Neha", "Saurabh", "Pooja", "Aditya"];
      const cities = ["Pune", "Mumbai", "Kolhapur", "Nashik", "Nagpur", "Satara"];
      const toast = document.getElementById('live-toast');
      const nameEl = document.getElementById('toast-name');
      const cityEl = document.getElementById('toast-city');

      function showToast() {
        if(!toast) return;
        nameEl.innerText = names[Math.floor(Math.random() * names.length)];
        cityEl.innerText = cities[Math.floor(Math.random() * cities.length)];
        toast.classList.add('toast-show');
        setTimeout(() => { toast.classList.remove('toast-show'); }, 4000);
      }

      setTimeout(() => {
        showToast();
        setInterval(showToast, 15000);
      }, 5000);
    });
  </script>
</Layout>