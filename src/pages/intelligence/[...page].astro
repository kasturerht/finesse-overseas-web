---
// src/pages/intelligence/[...page].astro
// 👑 MASTERPIECE EDITION: 100% Original Ultra-Luxury Layout Preserved with Advanced Semantic Node Schema & Bulletproof GTM DataLayer

import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import IntelligenceRadar from '../../components/IntelligenceRadar.astro';
import Footer from '../../components/Footer.astro';
import SafetyScoreQuiz from '../../components/SafetyScoreQuiz.astro';
import MythBusterFlip from '../../components/MythBusterFlip.astro';
import RedNoticeAlert from '../../components/RedNoticeAlert.astro';
import LeadCaptureModal from '../../components/LeadCaptureModal';

export const prerender = true;

export async function getStaticPaths({ paginate }) {
  const allPosts = await getCollection('intelligence');
  const sortedPosts = allPosts.sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());
  return paginate(sortedPosts, { pageSize: 9 });
}

const { page = { data: [], url: {}, currentPage: 1, lastPage: 1 } } = Astro.props;

const seoTitle = "Finesse Intelligence Hub | NMC Alerts & MBBS Abroad Audits";
const seoDescription = "Deep-dive research, NMC compliance updates, and financial exposes for Indian students planning to study MBBS in Europe.";

// 🧠 May-2026 Semantic Knowledge Graph: Enhanced ItemList Matrix for AI Search Overviews
const itemListElement = page.data.map((post, index) => ({
  "@type": "ListItem",
  "position": index + 1,
  "url": `${Astro.site}intelligence/${post.id.split('.')[0]}`,
  "name": post.data.title
}));

const listSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": seoTitle,
  "description": seoDescription,
  "itemListElement": itemListElement
});
---

<Layout title={seoTitle} description={seoDescription} schema={listSchema}>
  
  <IntelligenceRadar />

  <section class="py-24 bg-[#030712] relative overflow-hidden" id="audit-vaults">
    <div class="container mx-auto px-4 lg:px-8 max-w-7xl relative z-10">
      
      <div class="mb-16">
        <h2 class="text-3xl md:text-5xl font-serif text-white font-medium mb-6">The Audit Vaults</h2>
        <p class="text-slate-400 max-w-2xl text-lg">Unfiltered research, leaked institutional data, and financial truths that conventional agents hide from Indian students.</p>
      </div>

      {/* 📣 Filter Container with Complete Categories */}
      <div class="flex flex-wrap gap-2 lg:gap-3 justify-center md:justify-start mb-12" id="filter-container">
        {['All Data', 'NMC Alerts', 'Financial Truths', 'FMGE Data', 'Exposé', 'Myth Buster'].map((cat) => (
          <button
            data-filter={cat}
            class={`filter-btn px-5 py-2.5 rounded-full text-xs font-bold uppercase tracking-widest transition-all duration-300 cursor-pointer ${
              cat === 'All Data' 
              ? 'bg-emerald-500/20 text-emerald-400 border border-emerald-500/50 shadow-[0_0_15px_rgba(16,185,129,0.2)]' 
              : 'bg-[#0a0f1c] text-slate-400 border border-slate-800/80 hover:border-emerald-500/30 hover:text-emerald-300'
            }`}
          >
            {cat}
          </button>
        ))}
      </div>

      {/* 👑 The 8:4 Luxury Grid Split */}
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-12">
        
        {/* Left Column: Audits Matrix Grid (8 Columns) */}
        <div class="lg:col-span-8 w-full">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6 lg:gap-8" id="audit-grid">
            {page.data.map((post) => {
              const slug = post.id.split('.')[0];
              
              {/* 🛡️ Safe Reading Time Protection Protocol (Astro v5/v6 Native Body Fallback) */}
              const bodyRawText = post.body || "";
              const totalWords = bodyRawText.trim().split(/\s+/).filter(Boolean).length;
              const readTime = Math.max(3, Math.ceil(totalWords / 200));

              return (
                <article 
                  data-category={post.data.category}
                  class="audit-card group relative bg-[#0a0f1c] border border-slate-800/80 rounded-3xl overflow-hidden hover:border-emerald-500/40 transition-all duration-500 hover:shadow-[0_20px_40px_rgba(16,185,129,0.08)] hover:-translate-y-2 flex flex-col"
                >
                  <a href={`/intelligence/${slug}`} class="block relative h-56 w-full overflow-hidden bg-[#0a0f1c] finesse-grid-anchor" data-gtm-title={post.data.title} data-gtm-slug={slug}>
                    
                    {post.data.coverImage ? (
                      <img 
                        src={post.data.coverImage.src} 
                        alt={post.data.coverImageAlt || post.data.title} 
                        class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 ease-in-out group-hover:scale-105 origin-center"
                        loading="lazy"
                        decoding="async"
                      />
                    ) : (
                      <div class="absolute inset-0 w-full h-full bg-slate-900"></div>
                    )}

                    <div class="absolute inset-0 bg-gradient-to-t from-[#0a0f1c] from-2% via-[#0a0f1c]/50 to-transparent z-10 pointer-events-none"></div>
                    
                    <span class="absolute top-5 left-5 z-20 bg-black/50 backdrop-blur-md border border-emerald-500/30 text-emerald-400 text-[9px] font-black uppercase tracking-widest px-3 py-1.5 rounded-full shadow-[0_0_15px_rgba(16,185,129,0.2)]">
                      {post.data.category}
                    </span>
                  </a>

                  <div class="p-6 md:p-8 flex flex-col flex-grow relative z-20 bg-[#0a0f1c]">
                    <a href={`/intelligence/${slug}`} class="block flex-grow finesse-grid-anchor" data-gtm-title={post.data.title} data-gtm-slug={slug}>
                      <h3 class="text-xl md:text-2xl font-serif text-white font-medium leading-[1.3] mb-4 group-hover:text-emerald-300 transition-colors line-clamp-3">
                        {post.data.title}
                      </h3>
                      <p class="text-sm text-slate-400 line-clamp-3 leading-relaxed mb-8">
                        {post.data.excerpt}
                      </p>
                    </a>

                    <div class="flex items-center justify-between pt-5 border-t border-slate-800/60 mt-auto">
                      <div class="flex items-center gap-3">
                        <div class="w-7 h-7 rounded-full bg-emerald-950 flex items-center justify-center border border-emerald-500/30 text-emerald-400 text-[11px] font-black shadow-[0_0_10px_rgba(16,185,129,0.1)] font-sans">
                          {post.data.author ? post.data.author.charAt(0) : 'R'}
                        </div>
                        <div class="flex flex-col font-sans">
                          <span class="text-[9px] text-slate-500 font-bold uppercase tracking-widest leading-none mb-1">Audited By</span>
                          <span class="text-[11px] text-slate-300 font-medium tracking-wide leading-none">{post.data.author || 'Rohit Kasture'}</span>
                        </div>
                      </div>
                      <div class="flex items-center gap-1.5 text-[10px] text-slate-500 font-bold uppercase tracking-widest font-mono">
                        <svg class="w-3.5 h-3.5 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                        {readTime} Min
                      </div>
                    </div>
                  </div>
                </article>
              );
            })}
          </div>

          {/* Luxury Pagination Matrix */}
          <div class="mt-16 pt-8 border-t border-slate-800/50 flex flex-col md:flex-row items-center justify-between gap-6">
            {page?.url?.prev ? (
              <a href={page?.url?.prev} class="px-6 py-3 bg-slate-900 hover:bg-emerald-500/10 text-slate-300 hover:text-emerald-400 border border-slate-800 hover:border-emerald-500/50 rounded-xl transition-all font-bold text-sm tracking-wide flex items-center gap-2 group font-sans">
                <svg class="w-4 h-4 -translate-x-1 group-hover:-translate-x-2 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
                Newer Audits
              </a>
            ) : (
              <div class="w-32 hidden md:block"></div>
            )}

            <span class="text-slate-500 text-xs font-mono font-bold uppercase tracking-[0.2em] bg-[#0a0f1c] px-4 py-2 rounded-lg border border-slate-800/50">
              Page {page?.currentPage} <span class="text-slate-700 mx-1">/</span> {page?.lastPage}
            </span>

            {page?.url?.next ? (
              <a href={page?.url?.next} class="px-6 py-3 bg-slate-900 hover:bg-emerald-500/10 text-slate-300 hover:text-emerald-400 border border-slate-800 hover:border-emerald-500/50 rounded-xl transition-all font-bold text-sm tracking-wide flex items-center gap-2 group font-sans">
                Older Audits
                <svg class="w-4 h-4 translate-x-1 group-hover:translate-x-2 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
              </a>
            ) : (
              <div class="w-32 hidden md:block"></div>
            )}
          </div>
        </div>

        {/* Right Column: Sticky Sidebar Layout (4 Columns) */}
        <div class="lg:col-span-4 w-full mt-10 lg:mt-0">
          <div class="sticky top-32 space-y-8">
            <div class="p-8 bg-gradient-to-b from-[#0a0f1c] to-[#030712] border border-slate-800 rounded-[2rem] shadow-2xl relative overflow-hidden group font-sans">
              <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-emerald-900/20 via-transparent to-transparent opacity-50 group-hover:opacity-100 transition-opacity duration-700"></div>
              
              <div class="relative z-10">
                <span class="inline-block px-3 py-1 bg-emerald-500/10 text-emerald-400 text-[10px] font-black uppercase tracking-widest rounded-md border border-emerald-500/20 mb-6">
                  Free Resource
                </span>
                <h3 class="text-2xl font-serif text-white font-medium leading-tight mb-4">The Official NMC Guidelines Checklist</h3>
                <p class="text-slate-400 text-sm leading-relaxed mb-8">Before paying any consultant, cross-verify your chosen university against these 7 mandatory NMC rules to ensure your degree is valid in India.</p>
                <LeadCaptureModal client:load pdfUrl="/finesse-nmc-guidelines-checklist.pdf" />
              </div>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <SafetyScoreQuiz />
  <MythBusterFlip />
  <RedNoticeAlert />
  <Footer theme="dark" hideCTA={true} />

</Layout>

<script>
  // ⚡ PURE VANILLA SWISS-UI PROTOCOL: High-Performance Filtering + Synchronous GTM Injection
  document.addEventListener('DOMContentLoaded', () => {
    const filterBtns = document.querySelectorAll('.filter-btn');
    const cards = document.querySelectorAll('.audit-card');
    const gridLinks = document.querySelectorAll('.finesse-grid-anchor');

    filterBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const selectedCategory = btn.getAttribute('data-filter');

        // 💰 GTM SYNCHRONOUS INJECTION: Push category click data before animation frames
        if (typeof window !== 'undefined' && (window as any).dataLayer) {
          (window as any).dataLayer.push({
            'event': 'blog_filter_click',
            'filter_category': selectedCategory
          });
        }
        
        // 1. Reset all buttons
        filterBtns.forEach(b => {
          b.classList.remove('bg-emerald-500/20', 'text-emerald-400', 'border-emerald-500/50', 'shadow-[0_0_15px_rgba(16,185,129,0.2)]');
          b.classList.add('bg-[#0a0f1c]', 'text-slate-400', 'border-slate-800/80');
        });
        
        // 2. Activate clicked button
        btn.classList.add('bg-emerald-500/20', 'text-emerald-400', 'border-emerald-500/50', 'shadow-[0_0_15px_rgba(16,185,129,0.2)]');
        btn.classList.remove('bg-[#0a0f1c]', 'text-slate-400', 'border-slate-800/80');

        // 3. Filter the cards with Hardware Accelerated Performance
        cards.forEach(card => {
          const cardEl = card as HTMLElement;
          if (selectedCategory === 'All Data' || card.getAttribute('data-category') === selectedCategory) {
            cardEl.style.display = 'flex';
            cardEl.animate([
              { opacity: 0, transform: 'translateY(12px)' }, 
              { opacity: 1, transform: 'translateY(0)' }
            ], { duration: 350, easing: 'cubic-bezier(0.16, 1, 0.3, 1)' });
          } else {
            cardEl.style.display = 'none';
          }
        });
      });
    });

    // 💰 GTM INTERACTION PROTOCOL: Tracks exactly which luxury report card was selected
    gridLinks.forEach(anchor => {
      anchor.addEventListener('click', () => {
        const auditTitle = anchor.getAttribute('data-gtm-title');
        const auditSlug = anchor.getAttribute('data-gtm-slug');

        if (typeof window !== 'undefined' && (window as any).dataLayer) {
          (window as any).dataLayer.push({
            'event': 'blog_card_click',
            'blog_title': auditTitle,
            'blog_slug': auditSlug
          });
        }
      });
    });
  });
</script>