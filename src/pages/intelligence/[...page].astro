---
// src/pages/intelligence/[...page].astro
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Footer from '../../components/Footer.astro';

export const prerender = true;

export async function getStaticPaths({ paginate }) {
  const allPosts = await getCollection('intelligence');
  const sortedPosts = allPosts.sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());
  return paginate(sortedPosts, { pageSize: 9 });
}

const { page } = Astro.props;

const seoTitle = "Finesse Intelligence Hub | NMC Alerts & MBBS Abroad Audits";
const seoDescription = "Deep-dive research, NMC compliance updates, and financial exposes for Indian students planning to study MBBS in Europe.";

// 🧠 God-Level GEO: Generate ItemList Schema for AI Search Bots
const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": seoTitle,
  "description": seoDescription,
  "url": Astro.url.href,
  "itemListElement": page.data.map((post, index) => ({
    "@type": "ListItem",
    "position": index + 1,
    "url": `${Astro.url.origin}/intelligence/${post.id.split('.')[0]}`,
    "name": post.data.title
  }))
};
---

<Layout title={seoTitle} description={seoDescription}>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(itemListSchema)} />

  <main class="min-h-screen bg-[#030712] text-white pt-24 pb-16">
    <div class="max-w-7xl px-4 mx-auto sm:px-6 lg:px-8">
      
      <div class="text-center max-w-3xl mx-auto mb-16">
        <h1 class="text-4xl md:text-6xl font-serif tracking-tight text-white mb-6">
          Intelligence <span class="text-emerald-400">Hub</span>
        </h1>
        <p class="text-slate-400 text-lg md:text-xl">
          Data-driven, un-filtered audits on medical education abroad, NMC compliance, and hidden institutional traps.
        </p>
      </div>

      <div class="flex flex-wrap justify-center gap-3 mb-12" id="filter-container">
        {['All Data', 'NMC Alerts', 'Financial Truths', 'FMGE Data', 'Exposé', 'Myth Buster'].map((cat) => (
          <button
            data-filter={cat}
            class="filter-btn px-5 py-2.5 rounded-full border text-sm font-medium transition-all duration-300 cursor-pointer bg-[#0a0f1c] text-slate-400 border-slate-800 hover:border-emerald-500/50 hover:text-emerald-400"
          >
            {cat}
          </button>
        ))}
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8" id="audit-grid">
        {page.data.map((post) => {
          const slug = post.id.split('.')[0];
          return (
            <article 
              data-category={post.data.category}
              class="audit-card group relative bg-[#0a0f1c] border border-slate-900 rounded-2xl overflow-hidden hover:border-slate-800 transition-all duration-500 flex flex-col h-full"
            >
              <div class="aspect-video w-full overflow-hidden relative bg-slate-950">
                <img 
                  src={post.data.coverImage.src} 
                  alt={post.data.coverImageAlt}
                  loading="lazy"
                  decoding="async"
                  class="object-cover w-full h-full group-hover:scale-105 transition-transform duration-700 opacity-80 group-hover:opacity-100"
                />
                <span class="absolute top-4 left-4 bg-emerald-500/10 text-emerald-400 border border-emerald-500/20 text-xs font-mono uppercase tracking-widest px-3 py-1 rounded-md backdrop-blur-md">
                  {post.data.category}
                </span>
              </div>

              <div class="p-6 md:p-8 flex flex-col flex-grow">
                <div class="text-xs text-slate-500 font-mono mb-3">
                  {post.data.publishDate.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
                </div>
                <h2 class="text-xl md:text-2xl font-serif text-white group-hover:text-emerald-400 transition-colors duration-300 mb-4 line-clamp-2">
                  <a href={`/intelligence/${slug}`} class="audit-link" data-title={post.data.title} data-slug={slug}>
                    {post.data.title}
                  </a>
                </h2>
                <p class="text-slate-400 text-sm md:text-base line-clamp-3 mb-6 flex-grow">
                  {post.data.excerpt}
                </p>
                <div class="flex items-center justify-between pt-4 border-t border-slate-900 mt-auto">
                  <span class="text-xs font-mono text-slate-400">By {post.data.author}</span>
                  <span class="text-emerald-400 text-sm font-medium inline-flex items-center group-hover:translate-x-1 transition-transform duration-300">
                    Access Audit &rarr;
                  </span>
                </div>
              </div>
            </article>
          );
        })}
      </div>

    </div>
  </main>
  <Footer />
</Layout>

<script>
  // ⚡ GTM & Dynamic Interactions Layer
  document.addEventListener('DOMContentLoaded', () => {
    const filterBtns = document.querySelectorAll('.filter-btn');
    const cards = document.querySelectorAll('.audit-card');
    const auditLinks = document.querySelectorAll('.audit-link');

    // 1. Initial State: Set 'All Data' as Active
    const allBtn = document.querySelector('[data-filter="All Data"]');
    if(allBtn) {
      allBtn.classList.add('bg-emerald-500/20', 'text-emerald-400', 'border-emerald-500/50');
    }

    // 2. Filter Click Action Matrix + GTM DataLayer Push
    filterBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const selectedCategory = btn.getAttribute('data-filter');

        // GTM Event Triggering
        if (typeof window !== 'undefined' && (window as any).dataLayer) {
          (window as any).dataLayer.push({
            'event': 'blog_filter_click',
            'filter_category': selectedCategory
          });
        }

        // Active UI Toggle
        filterBtns.forEach(b => b.classList.remove('bg-emerald-500/20', 'text-emerald-400', 'border-emerald-500/50'));
        btn.classList.add('bg-emerald-500/20', 'text-emerald-400', 'border-emerald-500/50');

        // Hide/Show Logic
        cards.forEach(card => {
          const cardEl = card as HTMLElement;
          if (selectedCategory === 'All Data' || card.getAttribute('data-category') === selectedCategory) {
            cardEl.style.display = 'flex';
          } else {
            cardEl.style.display = 'none';
          }
        });
      });
    });

    // 3. Card Click GTM Tracking Loop
    auditLinks.forEach(link => {
      link.addEventListener('click', (e) => {
        const title = link.getAttribute('data-title');
        const slug = link.getAttribute('data-slug');
        
        if (typeof window !== 'undefined' && (window as any).dataLayer) {
          (window as any).dataLayer.push({
            'event': 'blog_card_click',
            'blog_title': title,
            'blog_slug': slug
          });
        }
      });
    });
  });
</script>