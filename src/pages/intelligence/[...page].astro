---
// src/pages/intelligence/[...page].astro

import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import IntelligenceRadar from '../../components/IntelligenceRadar.astro';
import Footer from '../../components/Footer.astro';
import SafetyScoreQuiz from '../../components/SafetyScoreQuiz.astro';
import MythBusterFlip from '../../components/MythBusterFlip.astro';
import RedNoticeAlert from '../../components/RedNoticeAlert.astro';
import LeadCaptureModal from '../../components/LeadCaptureModal';
import DynamicAuditBoard from '../../components/DynamicAuditBoard.tsx';

export const prerender = true;

export async function getStaticPaths({ paginate }) {
  // १. सर्व लेख ओढून आणा
  const allPosts = await getCollection('intelligence');
  
  // २. त्यांना तारखेनुसार सॉर्ट करा (नवीन आधी)
  const sortedPosts = allPosts.sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());

  // ३. Pagination मॅजिक: एका पेजवर फक्त ९ कार्ड्स दाखवा
  return paginate(sortedPosts, { pageSize: 9 });
}

// Astro आता आपल्याला 'page' नावाचा एक तयार ऑब्जेक्ट देईल
const { page = { data: [], url: {}, currentPage: 1, lastPage: 1 } } = Astro.props;


const seoTitle = "Finesse Intelligence Hub | NMC Alerts & MBBS Abroad Audits";
const seoDescription = "Deep-dive research, NMC compliance updates, and verified ground-reality audits of global medical universities. Stop guessing, start auditing.";

const allIntelligence = await getCollection('intelligence');

const sortedIntelligence = allIntelligence.sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
);

const featuredPosts = allIntelligence
  .filter((post) => post.data.isFeatured)
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
  .slice(0, 3);

const categoryColors: Record<string, string> = {
  'NMC Alerts':       'text-emerald-500',
  'Financial Truths': 'text-amber-400',
  'FMGE Data':        'text-blue-400',
  'Exposé':           'text-red-400',
  'Myth Buster':      'text-purple-400',
};
---

<Layout title={seoTitle} description={seoDescription}>
  <main class="w-full bg-[#030712] min-h-screen selection:bg-emerald-500/30 selection:text-emerald-200">

    <IntelligenceRadar />

    <section class="relative w-full py-20 font-sans border-t border-slate-800/50">
      <div class="container mx-auto px-4 lg:px-8 max-w-7xl">

        <div class="flex flex-col md:flex-row items-center justify-between border-b border-slate-800 pb-6 mb-12 gap-6">
          <div class="text-center md:text-left">
            <h2 class="text-3xl lg:text-4xl font-serif text-white tracking-tight">The Audit Vaults</h2>
            <p class="text-sm text-slate-500 font-mono uppercase tracking-widest mt-2">Classified by Scrutiny Parameters</p>
          </div>

          <div class="flex flex-wrap gap-2 lg:gap-3 justify-center">
            <button class="px-4 py-2 rounded-lg bg-emerald-500/10 text-emerald-400 text-[10px] font-bold uppercase tracking-widest border border-emerald-500/30 shadow-sm">All Data</button>
            <button class="px-4 py-2 rounded-lg bg-slate-900/80 hover:bg-slate-800 border border-slate-800 text-slate-400 text-[10px] font-bold uppercase tracking-widest transition-colors">NMC Alerts</button>
            <button class="px-4 py-2 rounded-lg bg-slate-900/80 hover:bg-slate-800 border border-slate-800 text-slate-400 text-[10px] font-bold uppercase tracking-widest transition-colors">Financial Truths</button>
          </div>
        </div>

        <!--
          Mobile: flex-col so `order-first` on the aside renders it above the post grid.
          Desktop (lg+): switches to a 12-col CSS grid; aside uses lg:order-last (right column).
        -->
        <div class="flex flex-col lg:grid lg:grid-cols-12 gap-10 lg:gap-12 lg:items-start">

          <!-- SIDEBAR — top on mobile (order-first), right column on desktop (lg:order-last) -->
          <aside class="order-first lg:order-last lg:col-span-4 lg:sticky lg:top-10 flex flex-col gap-8 w-full">

            <!-- Lead Magnet: NMC 2026 Checklist -->
            <div class="bg-gradient-to-br from-emerald-950/40 to-[#0a0f1c] border border-emerald-500/30 rounded-3xl p-8 relative overflow-hidden shadow-[inset_0_1px_0_rgba(255,255,255,0.1),_0_20px_40px_rgba(0,0,0,0.4)]">
              <div class="absolute -right-10 -bottom-10 w-40 h-40 bg-emerald-500/20 blur-[50px] rounded-full pointer-events-none"></div>
              <div class="relative z-10 flex flex-col items-center text-center">
                <div class="w-16 h-16 rounded-full bg-emerald-500/10 border border-emerald-500/40 flex items-center justify-center text-emerald-400 mb-6 shadow-[0_0_20px_rgba(16,185,129,0.2)]">
                  <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                  </svg>
                </div>
                <h4 class="text-xl font-serif text-white font-bold mb-3">NMC 2026 Checklist</h4>
                <p class="text-sm text-slate-300 font-medium mb-6">Download the exact 15-point matrix our auditors use to blacklist fake universities.</p>
                <LeadCaptureModal
                  client:load
                  pdfUrl="/downloads/NMC-2026-Checklist.pdf"
                />
                <p class="text-[9px] text-slate-500 uppercase tracking-widest font-mono mt-4">100% Free & Secure</p>
              </div>
            </div>

            <!-- Trending Intel: top 3 featured posts -->
            <div class="bg-[#0a0f1c] border border-slate-700/80 rounded-3xl p-8 shadow-xl">
              <h4 class="text-[10px] font-black text-slate-400 uppercase tracking-[0.2em] border-b border-slate-800 pb-4 mb-6">Trending Intel</h4>
              <ul class="space-y-6">
                {featuredPosts.map((post, i) => {
                  const colorClass = categoryColors[post.data.category] ?? 'text-slate-400';
                  return (
                    <li class={`group${i > 0 ? ' border-t border-slate-800 pt-6' : ''}`}>
                      <a href={`/intelligence/${post.slug}`} class="block">
                        <p class={`${colorClass} text-[9px] font-mono font-bold uppercase tracking-widest mb-1.5`}>
                          {post.data.category}
                        </p>
                        <h5 class="text-sm font-serif text-slate-200 font-medium leading-snug group-hover:text-white transition-colors">
                          {post.data.title}
                        </h5>
                      </a>
                    </li>
                  );
                })}
              </ul>
            </div>

          </aside>

          <!-- MAIN GRID — bottom on mobile (order-last), left column on desktop (lg:order-first) -->
          <div class="order-last lg:order-first lg:col-span-8">
            <DynamicAuditBoard client:load posts={page?.data} />

            {/* 🛠️ FIX 1: Pagination चा डबा 'col-span-8' च्या आत घेतला आहे! */}
            <div class="flex items-center justify-between mt-16 pt-8 border-t border-slate-800/50">
              
              {/* Previous Button */}
              {page?.url?.prev ? (
                <a href={page?.url.prev} class="px-6 py-3 bg-slate-900 hover:bg-emerald-500/10 text-slate-300 hover:text-emerald-400 border border-slate-800 hover:border-emerald-500/50 rounded-xl transition-all font-bold text-sm tracking-wide flex items-center gap-2 group">
                  <svg class="w-4 h-4 -translate-x-1 group-hover:-translate-x-2 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
                  Newer Audits
                </a>
              ) : (
                <div class="w-32"></div>
              )}

              {/* Page Indicator */}
              <span class="text-slate-500 text-xs font-mono font-bold uppercase tracking-[0.2em] bg-[#0a0f1c] px-4 py-2 rounded-lg border border-slate-800/50">
                Page {page?.currentPage} <span class="text-slate-700 mx-1">/</span> {page?.lastPage}
              </span>

              {/* Next Button */}
              {page?.url?.next ? (
                <a href={page?.url?.next} class="px-6 py-3 bg-slate-900 hover:bg-emerald-500/10 text-slate-300 hover:text-emerald-400 border border-slate-800 hover:border-emerald-500/50 rounded-xl transition-all font-bold text-sm tracking-wide flex items-center gap-2 group">
                  Older Audits
                  <svg class="w-4 h-4 translate-x-1 group-hover:translate-x-2 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
                </a>
              ) : (
                <div class="w-32"></div>
              )}
              
            </div>
            
          </div>

        </div>

      </div>
    </section>
    

    <SafetyScoreQuiz />
    <MythBusterFlip />
    <RedNoticeAlert />
  </main>

  <Footer theme="dark" hideCTA={true} />
</Layout>
