---
// src/pages/study-in-austria.astro
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';

const seoTitle = "Study in Austria | Zero Blocked Account | Finesse Overseas";
const seoDescription = "Keep your 15 Lakhs in your bank. Study in premium Austrian public universities for just €726/semester with no blocked account required.";

const austriaFaqs = [
  {
    question: "Do I need to deposit €11,208 in a Blocked Account like Germany?",
    answer: "No, absolutely not. This is Austria's biggest advantage. You do not need a mandatory blocked account. You simply have to show the required living expenses in your or your sponsor's regular local bank account."
  },
  {
    question: "Is it mandatory to learn the German language?",
    answer: "For your visa and university admission into English-taught Master's programs, German is NOT required. However, we highly recommend learning basic A1/A2 German while studying there, as it makes finding part-time jobs and daily life much easier."
  },
  {
    question: "How much is the actual tuition fee?",
    answer: "Unlike private universities that charge thousands of euros, Austria's elite public universities charge a standardized low fee of just €726.72 per semester for international students from non-EU countries."
  },
  {
    question: "What is the stay-back period after graduation?",
    answer: "Indian students are officially granted a 12-month stay-back period after graduation. During this time, you can legally stay in Austria to find a full-time job related to your field of study, which then converts into a Red-White-Red card."
  },
  {
    question: "Can I manage my living expenses with a part-time job?",
    answer: "Yes. International students are legally allowed to work up to 20 hours per week. Given the current labor shortage and high minimum wages, students easily earn around €1,000+ per month, which comfortably covers rent, food, and insurance."
  }
];

const austriaFaqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": austriaFaqs.map(faq => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.answer
    }
  }))
};

const austriaSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": "https://finesseoverseas.com/study-in-austria",
      "url": "https://finesseoverseas.com/study-in-austria",
      "name": seoTitle,
      "description": seoDescription,
      "inLanguage": "en",
      "isPartOf": { "@id": "https://finesseoverseas.com" },
      "breadcrumb": {
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://finesseoverseas.com" },
          { "@type": "ListItem", "position": 2, "name": "Study in Austria", "item": "https://finesseoverseas.com/study-in-austria" }
        ]
      }
    },
    austriaFaqSchema
  ]
});
---

<Layout title={seoTitle} description={seoDescription} schema={austriaSchema}>
  <main class="pt-20 flex-grow bg-[#050505]">

    <section class="relative flex flex-col justify-center items-center overflow-hidden border-b border-white/5 pt-20 pb-40 lg:pt-32 lg:pb-48 xl:pt-40 xl:pb-56">
      
      <div class="absolute inset-0 z-0 pointer-events-none">
        <div class="absolute inset-0 bg-[url('data:image/svg+xml;base64,PHN2ZyB3aWR0aD0iMjAiIGhlaWdodD0iMjAiIHhtbG5zPSJodHRwOi8vd3d3LnczLm9yZy8yMDAwL3N2ZyI+CgkJPGNpcmNsZSBjeD0iMSIgY3k9IjEiIHI9IjEiIGZpbGw9InJnYmEoMjU1LDI1NSwyNTUsMC4wNSkiLz4KCTwvc3ZnPg==')] opacity-50"></div>
        <div class="absolute top-1/4 left-1/4 -translate-x-1/2 -translate-y-1/2 w-[500px] h-[500px] bg-red-600/20 rounded-full blur-[120px]"></div>
        <div class="absolute bottom-1/4 right-1/4 translate-x-1/4 translate-y-1/4 w-[600px] h-[600px] bg-rose-500/10 rounded-full blur-[150px]"></div>
        <div class="absolute bottom-0 left-0 w-full h-1/2 bg-gradient-to-t from-[#050505] to-transparent"></div>
      </div>

      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 text-center flex flex-col items-center w-full">
        
        <div class="inline-flex items-center gap-2.5 px-4 py-2 rounded-full bg-red-500/10 border border-red-500/20 backdrop-blur-md mb-8 shadow-[0_0_20px_rgba(239,68,68,0.15)] mt-10 md:mt-0">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-red-400 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-red-500"></span>
          </span>
          <span class="text-xs font-black text-red-400 uppercase tracking-widest">
            Verified for 2026 | Zero Blocked Funds Required
          </span>
        </div>

        <h1 class="text-5xl sm:text-6xl md:text-7xl lg:text-[4.5rem] xl:text-[5.5rem] font-black text-white tracking-tighter leading-[1.1] mb-6">
          Keep your <span class="text-transparent bg-clip-text bg-gradient-to-br from-red-500 via-rose-500 to-orange-400 drop-shadow-sm">15 Lakhs</span> <br class="hidden md:block" />
          in your bank.
        </h1>
        
        <h2 class="text-lg sm:text-xl md:text-2xl text-slate-400 font-medium mb-10 max-w-3xl leading-relaxed px-2">
          Unlock premium European education in Austria. No blocked accounts. No hidden financial traps. Just pure merit and a minimal <strong class="text-white">€726/semester</strong> fee.
        </h2>

        <div class="flex flex-wrap justify-center items-center gap-3 sm:gap-4 md:gap-8 mb-12 px-2">
          <div class="flex items-center gap-2 text-slate-300 font-bold text-xs sm:text-sm bg-white/5 border border-white/10 px-3 sm:px-4 py-2 rounded-xl backdrop-blur-sm">
            <svg aria-hidden="true" class="w-4 h-4 sm:w-5 sm:h-5 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
            Accessible Bank Funds
          </div>
          <div class="flex items-center gap-2 text-slate-300 font-bold text-xs sm:text-sm bg-white/5 border border-white/10 px-3 sm:px-4 py-2 rounded-xl backdrop-blur-sm">
            <svg aria-hidden="true" class="w-4 h-4 sm:w-5 sm:h-5 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
            World's #1 Livable City
          </div>
          <div class="flex items-center gap-2 text-slate-300 font-bold text-xs sm:text-sm bg-white/5 border border-white/10 px-3 sm:px-4 py-2 rounded-xl backdrop-blur-sm">
            <svg aria-hidden="true" class="w-4 h-4 sm:w-5 sm:h-5 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
            29 Schengen Countries
          </div>
        </div>

        <div class="flex flex-col sm:flex-row gap-4 sm:gap-5 w-full sm:w-auto relative z-20">
          <a href="/contact" class="group relative z-20 flex justify-center items-center gap-2 bg-gradient-to-r from-red-600 to-rose-500 hover:from-red-500 hover:to-rose-400 text-white px-8 sm:px-9 py-4 rounded-xl text-base sm:text-lg font-black transition-all shadow-[0_0_30px_rgba(225,29,72,0.3)] active:scale-95 overflow-hidden w-full sm:w-auto">
            <div class="absolute inset-0 bg-white/20 translate-y-full group-hover:translate-y-0 transition-transform duration-300 ease-out"></div>
            <span class="relative z-10">Check Your Eligibility</span>
            <svg aria-hidden="true" class="w-5 h-5 relative z-10 transform group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
          </a>
          
          <a href="#guide" class="flex justify-center items-center gap-2 bg-[#0a0a0a] sm:bg-transparent hover:bg-white/5 text-white border border-white/20 hover:border-white/40 px-8 sm:px-9 py-4 rounded-xl text-base sm:text-lg font-bold transition-all active:scale-95 group w-full sm:w-auto z-20 shadow-md">
            <svg aria-hidden="true" class="w-5 h-5 text-slate-400 group-hover:text-white transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path></svg>
            Download Austria Guide
          </a>
        </div>

      </div>
    </section>

    <section class="py-20 md:py-28 bg-white relative rounded-t-[3rem] -mt-10 z-20 shadow-[0_-20px_60px_rgba(0,0,0,0.2)]" id="lifestyle">
      
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        
        <div class="max-w-3xl mb-12 md:mb-16">
          <span class="inline-block px-4 py-1.5 rounded-full bg-red-50 text-red-600 font-black tracking-widest uppercase mb-6 text-[10px] shadow-sm border border-red-100">
            The Lifestyle Upgrade
          </span>
          <h2 class="text-3xl md:text-5xl lg:text-5xl xl:text-6xl font-black text-slate-900 tracking-tighter mb-6 leading-[1.1]">
            Not just a degree.<br/>
            <span class="text-transparent bg-clip-text bg-gradient-to-r from-red-600 to-orange-500">A profound shift in reality.</span>
          </h2>
          <p class="text-slate-500 text-lg md:text-xl font-medium leading-relaxed">
            Hover over the cards below to discover why Vienna isn't just a city, but the ultimate hack for international students.
          </p>
        </div>

        <div class="flex flex-col lg:flex-row w-full min-h-[700px] lg:min-h-[450px] xl:min-h-[550px] gap-4 lg:gap-6">

          <div class="group relative flex-1 hover:flex-[3] lg:hover:flex-[4] transition-all duration-[800ms] ease-[cubic-bezier(0.25,1,0.5,1)] rounded-[2.5rem] overflow-hidden cursor-pointer shadow-md hover:shadow-2xl">
            <img 
              src="https://images.unsplash.com/photo-1516550893923-42d28e5677af?auto=format&fit=crop&q=80&w=1200" 
              alt="Vienna Architecture" 
              loading="lazy" decoding="async"
              class="absolute inset-0 w-full h-full object-cover object-center grayscale-[30%] group-hover:grayscale-0 group-hover:scale-110 transition-all duration-[2000ms]"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-[#050505] via-[#050505]/40 to-transparent opacity-80 group-hover:opacity-90 transition-opacity"></div>
            
            <div class="absolute inset-0 p-8 flex flex-col justify-end lg:items-center lg:justify-end opacity-100 lg:group-hover:opacity-0 transition-opacity duration-500 lg:group-hover:duration-150 delay-300 lg:group-hover:delay-0">
              <h3 class="text-white font-black text-2xl lg:-rotate-90 lg:whitespace-nowrap lg:translate-y-[-100px] tracking-widest uppercase drop-shadow-md">#1 Livable City</h3>
            </div>

            <div class="absolute inset-x-0 bottom-0 p-8 flex flex-col justify-end h-full pointer-events-none group-hover:pointer-events-auto">
              <div class="w-full sm:w-[320px] lg:w-[380px]">
                <div class="w-12 h-12 bg-red-600 rounded-full flex items-center justify-center text-white mb-4 shadow-[0_0_30px_rgba(220,38,38,0.5)] opacity-0 group-hover:opacity-100 scale-50 group-hover:scale-100 transition-all duration-150 group-hover:duration-500 delay-0 group-hover:delay-200">
                  <svg aria-hidden="true" class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path></svg>
                </div>
                <h3 class="text-3xl lg:text-4xl font-black text-white tracking-tight mb-3 leading-none opacity-0 group-hover:opacity-100 translate-y-8 group-hover:translate-y-0 transition-all duration-150 group-hover:duration-700 delay-0 group-hover:delay-300">
                  Global #1<br/><span class="text-red-400">Quality of Life</span>
                </h3>
                <p class="text-slate-300 font-medium text-sm lg:text-base opacity-0 group-hover:opacity-100 transition-opacity duration-150 group-hover:duration-700 delay-0 group-hover:delay-400">
                  Voted the most livable city in the world for over a decade. Experience royal architecture, spotless streets, and an environment that nurtures success.
                </p>
              </div>
            </div>
          </div>

          <div class="group relative flex-1 hover:flex-[3] lg:hover:flex-[4] transition-all duration-[800ms] ease-[cubic-bezier(0.25,1,0.5,1)] rounded-[2.5rem] overflow-hidden cursor-pointer shadow-md hover:shadow-2xl">
            <img 
              src="https://images.unsplash.com/photo-1541427468627-a89a96e5ca1d?auto=format&fit=crop&q=80&w=1200" 
              alt="Vienna Public Transport" 
              loading="lazy" decoding="async"
              class="absolute inset-0 w-full h-full object-cover object-center grayscale-[30%] group-hover:grayscale-0 group-hover:scale-110 transition-all duration-[2000ms]"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-[#050505] via-[#050505]/40 to-transparent opacity-80 group-hover:opacity-90 transition-opacity"></div>
            
            <div class="absolute inset-0 p-8 flex flex-col justify-end lg:items-center lg:justify-end opacity-100 lg:group-hover:opacity-0 transition-opacity duration-500 lg:group-hover:duration-150 delay-300 lg:group-hover:delay-0">
              <h3 class="text-white font-black text-2xl lg:-rotate-90 lg:whitespace-nowrap lg:translate-y-[-100px] tracking-widest uppercase drop-shadow-md">€1/Day Travel</h3>
            </div>

            <div class="absolute inset-x-0 bottom-0 p-8 flex flex-col justify-end h-full pointer-events-none group-hover:pointer-events-auto">
              <div class="w-full sm:w-[320px] lg:w-[380px]">
                <div class="w-12 h-12 bg-red-600 rounded-full flex items-center justify-center text-white mb-4 shadow-[0_0_30px_rgba(220,38,38,0.5)] opacity-0 group-hover:opacity-100 scale-50 group-hover:scale-100 transition-all duration-150 group-hover:duration-500 delay-0 group-hover:delay-200">
                  <svg aria-hidden="true" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path></svg>
                </div>
                <h3 class="text-3xl lg:text-4xl font-black text-white tracking-tight mb-3 leading-none opacity-0 group-hover:opacity-100 translate-y-8 group-hover:translate-y-0 transition-all duration-150 group-hover:duration-700 delay-0 group-hover:delay-300">
                  Unlimited<br/><span class="text-red-400">Transit Pass</span>
                </h3>
                <p class="text-slate-300 font-medium text-sm lg:text-base opacity-0 group-hover:opacity-100 transition-opacity duration-150 group-hover:duration-700 delay-0 group-hover:delay-400">
                  Forget Uber or cabs. As a student, you get an annual pass covering all buses, ultra-modern trams, and underground trains for virtually nothing.
                </p>
              </div>
            </div>
          </div>

          <div class="group relative flex-1 hover:flex-[3] lg:hover:flex-[4] transition-all duration-[800ms] ease-[cubic-bezier(0.25,1,0.5,1)] rounded-[2.5rem] overflow-hidden cursor-pointer shadow-md hover:shadow-2xl">
            <img 
              src="https://images.unsplash.com/photo-1599839619722-39751411ea63?auto=format&fit=crop&q=80&w=1200" 
              alt="Safe Vienna Streets" 
              loading="lazy" decoding="async"
              class="absolute inset-0 w-full h-full object-cover object-center grayscale-[30%] group-hover:grayscale-0 group-hover:scale-110 transition-all duration-[2000ms]"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-[#050505] via-[#050505]/40 to-transparent opacity-80 group-hover:opacity-90 transition-opacity"></div>
            
            <div class="absolute inset-0 p-8 flex flex-col justify-end lg:items-center lg:justify-end opacity-100 lg:group-hover:opacity-0 transition-opacity duration-500 lg:group-hover:duration-150 delay-300 lg:group-hover:delay-0">
              <h3 class="text-white font-black text-2xl lg:-rotate-90 lg:whitespace-nowrap lg:translate-y-[-100px] tracking-widest uppercase drop-shadow-md">100% Safe</h3>
            </div>

            <div class="absolute inset-x-0 bottom-0 p-8 flex flex-col justify-end h-full pointer-events-none group-hover:pointer-events-auto">
              <div class="w-full sm:w-[320px] lg:w-[380px]">
                <div class="w-12 h-12 bg-red-600 rounded-full flex items-center justify-center text-white mb-4 shadow-[0_0_30px_rgba(220,38,38,0.5)] opacity-0 group-hover:opacity-100 scale-50 group-hover:scale-100 transition-all duration-150 group-hover:duration-500 delay-0 group-hover:delay-200">
                  <svg aria-hidden="true" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path></svg>
                </div>
                <h3 class="text-3xl lg:text-4xl font-black text-white tracking-tight mb-3 leading-none opacity-0 group-hover:opacity-100 translate-y-8 group-hover:translate-y-0 transition-all duration-150 group-hover:duration-700 delay-0 group-hover:delay-300">
                  Absolute<br/><span class="text-red-400">Peace of Mind</span>
                </h3>
                <p class="text-slate-300 font-medium text-sm lg:text-base opacity-0 group-hover:opacity-100 transition-opacity duration-150 group-hover:duration-700 delay-0 group-hover:delay-400">
                  Ranked in the top 5 safest countries globally. Whether you are returning from a late-night part-time job or a library session, you are always secure.
                </p>
              </div>
            </div>
          </div>

        </div>
      </div>
    </section>

    <section class="py-20 lg:py-32 bg-[#050505] relative overflow-hidden border-y border-white/5" id="finance">
      
      <div class="absolute inset-0 bg-[url('data:image/svg+xml;base64,PHN2ZyB3aWR0aD0iMjAiIGhlaWdodD0iMjAiIHhtbG5zPSJodHRwOi8vd3d3LnczLm9yZy8yMDAwL3N2ZyI+CgkJPGNpcmNsZSBjeD0iMSIgY3k9IjEiIHI9IjEiIGZpbGw9InJnYmEoMjU1LDI1NSwyNTUsMC4wMykiLz4KCTwvc3ZnPg==')] pointer-events-none"></div>
      <div class="absolute top-[-10%] right-[-5%] w-[500px] h-[500px] bg-red-600/10 rounded-full blur-[100px] pointer-events-none"></div>
      
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">

        <div class="text-center md:text-left mb-12 lg:mb-16 flex flex-col md:flex-row md:items-end justify-between gap-6 border-b border-white/10 pb-8 lg:pb-10">
          <div class="max-w-2xl">
            <span class="inline-flex items-center gap-2 px-3 py-1 rounded bg-white/5 border border-white/10 text-slate-400 font-bold tracking-widest uppercase mb-4 lg:mb-6 text-[10px]">
              <span class="w-1.5 h-1.5 rounded-full bg-red-500 animate-pulse"></span>
              Financial Clarity
            </span>
            <h2 class="text-3xl md:text-5xl lg:text-6xl font-black text-white tracking-tighter leading-[1.1]">
              Capital required to <br class="hidden md:block" />
              <span class="text-transparent bg-clip-text bg-gradient-to-r from-red-500 to-rose-400">start your journey.</span>
            </h2>
          </div>
          <div class="md:text-right">
            <p class="text-slate-400 text-sm md:text-base font-medium max-w-xs mx-auto md:ml-auto leading-relaxed">
              No hidden traps. No absurd locked funds. Just clear, manageable expenses that keep your savings safe.
            </p>
          </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-12 gap-6">

          <div class="lg:col-span-7 bg-gradient-to-br from-white/5 to-transparent rounded-[2.5rem] p-6 sm:p-8 lg:p-12 border border-white/10 shadow-2xl relative overflow-hidden group hover:border-red-500/30 transition-colors duration-500">
            <div class="absolute -right-20 -bottom-20 w-64 h-64 bg-red-600/20 rounded-full blur-[80px] group-hover:bg-red-500/30 transition-colors duration-500"></div>
            
            <div class="relative z-10 h-full flex flex-col justify-between">
              <div>
                <p class="text-slate-400 font-bold uppercase tracking-widest text-xs sm:text-sm mb-2">Mandatory Blocked Account</p>
                <div class="flex items-baseline gap-3">
                  <span class="text-6xl sm:text-7xl lg:text-[6rem] font-black text-transparent bg-clip-text bg-gradient-to-b from-white to-slate-400 tracking-tighter leading-none">
                    €0
                  </span>
                </div>
              </div>
              
              <div class="mt-8 lg:mt-12 pt-6 lg:pt-8 border-t border-white/10">
                <div class="flex flex-col sm:flex-row items-start gap-4">
                  <div class="w-10 h-10 sm:w-12 sm:h-12 rounded-xl bg-red-500/10 flex items-center justify-center shrink-0 border border-red-500/20 text-red-400 shadow-inner">
                    <svg aria-hidden="true" class="w-5 h-5 sm:w-6 sm:h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
                  </div>
                  <div>
