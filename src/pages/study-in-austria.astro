    <script>
      function initFixed3DCard() {
        const container = document.getElementById('rwr-container');
        const cardArea = document.querySelector('[style="perspective: 1500px;"]');
        const card = document.getElementById('rwr-card');
        const glare = document.getElementById('card-glare');

        if (!container || !cardArea || !card || !glare) return;

        container.addEventListener('mousemove', (e) => {
          if (window.innerWidth < 1024) return; // Prevent on mobile/tablets to avoid bugs

          const rect = cardArea.getBoundingClientRect(); 
          const x = e.clientX - rect.left - rect.width / 2;
          const y = e.clientY - rect.top - rect.height / 2;

          const rotateX = (y / (rect.height / 2)) * -10; 
          const rotateY = (x / (rect.width / 2)) * 10;

          card.style.transform = `perspective(1000px) rotateX(${rotateX}deg) rotateY(${rotateY}deg) scale3d(1.02, 1.02, 1.02)`;
          glare.style.opacity = '1';
          glare.style.transform = `translateX(${x * 0.5}px) translateY(${y * 0.5}px)`;
        });

        container.addEventListener('mouseleave', () => {
          if (window.innerWidth < 1024) return;
          card.style.transform = `perspective(1000px) rotateX(0deg) rotateY(0deg) scale3d(1, 1, 1)`;
          glare.style.opacity = '0';
        });
      }

      initFixed3DCard();
      document.addEventListener('astro:page-load', initFixed3DCard);
    </script>


