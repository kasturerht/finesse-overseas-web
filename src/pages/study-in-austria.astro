    <script>
      function initEligibilityConsole() {
        const btnUg = document.getElementById('btn-ug');
        const btnPg = document.getElementById('btn-pg');
        const slider = document.getElementById('eligibility-slider');
        
        const viewUg = document.getElementById('view-ug');
        const viewPg = document.getElementById('view-pg');

        if(!btnUg || !btnPg) return;

        slider.style.transitionTimingFunction = "cubic-bezier(0.34, 1.56, 0.64, 1)";

        btnUg.addEventListener('click', () => {
          if (viewUg.classList.contains('is-active')) return;

          slider.style.transform = 'translateX(0)';
          btnUg.classList.replace('text-slate-500', 'text-white');
          btnPg.classList.replace('text-white', 'text-slate-500');

          viewPg.classList.remove('is-active', 'z-10');
          viewPg.classList.add('z-0', 'pointer-events-none');
          
          setTimeout(() => {
            viewUg.classList.remove('z-0', 'pointer-events-none');
            viewUg.classList.add('is-active', 'z-10');
          }, 50);
        });

        btnPg.addEventListener('click', () => {
          if (viewPg.classList.contains('is-active')) return;

          slider.style.transform = 'translateX(100%)';
          btnPg.classList.replace('text-slate-500', 'text-white');
          btnUg.classList.replace('text-white', 'text-slate-500');

          viewUg.classList.remove('is-active', 'z-10');
          viewUg.classList.add('z-0', 'pointer-events-none');
          
          setTimeout(() => {
            viewPg.classList.remove('z-0', 'pointer-events-none');
            viewPg.classList.add('is-active', 'z-10');
          }, 50);
        });
      }

      initEligibilityConsole();
      document.addEventListener('astro:page-load', initEligibilityConsole);
    </script>


