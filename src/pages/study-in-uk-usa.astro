---
// src/pages/study-in-uk-usa.astro
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Study in UK & USA — Coming Soon | Finesse Overseas Education</title>
  <meta name="description" content="Finesse Overseas is engineering the most precise UK & USA pathway for Indian students. 1-Year Masters UK, 3-Year STEM OPT USA. Join the waitlist." />
  <link rel="icon" href="/favicon.ico" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      /* exact site palette */
      --bg:       #0f0f0f;
      --bg2:      #141414;
      --bg3:      #1a1a1a;
      --orange:   #e25822;
      --orange-h: #f07040;
      --white:    #ffffff;
      --muted:    rgba(255,255,255,.55);
      --muted2:   rgba(255,255,255,.25);
      --border:   rgba(255,255,255,.08);
      --border2:  rgba(255,255,255,.13);
    }

    html { scroll-behavior: smooth; }

    body {
      background: var(--bg);
      color: var(--white);
      font-family: 'Inter', sans-serif;
      min-height: 100svh;
      overflow-x: clip;
    }

    /* ─── NAV — matches site exactly ─── */
    .nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 200;
      display: flex; align-items: center; justify-content: space-between;
      padding: 0 clamp(1rem, 4vw, 2.5rem);
      height: 64px;
      background: rgba(15,15,15,.92);
      backdrop-filter: blur(20px);
      border-bottom: 1px solid var(--border);
    }
    .nav-logo img { height: 30px; }
    .nav-links {
      display: flex; align-items: center; gap: clamp(.8rem, 2.5vw, 2rem);
      list-style: none;
    }
    .nav-links a {
      font-size: 13.5px; font-weight: 400; color: var(--muted);
      text-decoration: none; transition: color .2s;
    }
    .nav-links a:hover { color: var(--white); }
    .nav-cta {
      background: var(--orange);
      color: var(--white) !important;
      font-weight: 500 !important;
      padding: .5rem 1.1rem;
      border-radius: 6px;
      font-size: 13px !important;
      transition: background .2s !important;
      white-space: nowrap;
    }
    .nav-cta:hover { background: var(--orange-h) !important; color: var(--white) !important; }
    .nav-mobile-cta {
      display: none;
      background: var(--orange); color: var(--white);
      font-size: 13px; font-weight: 500; padding: .45rem .9rem;
      border-radius: 6px; text-decoration: none; white-space: nowrap;
    }
    @media (max-width: 680px) {
      .nav-links { display: none; }
      .nav-mobile-cta { display: block; }
    }

    /* ─── BREADCRUMB ─── */
    .breadcrumb {
      position: relative; z-index: 2;
      padding: 5.5rem clamp(1rem,5vw,3rem) 0;
      display: flex; align-items: center; gap: .5rem;
      font-size: 12.5px; color: var(--muted2);
    }
    .breadcrumb a { color: var(--muted2); text-decoration: none; transition: color .2s; }
    .breadcrumb a:hover { color: var(--muted); }
    .breadcrumb span { color: var(--muted2); }

    /* ─── HERO ─── */
    .hero {
      position: relative; z-index: 2;
      padding: clamp(2rem,5vh,3.5rem) clamp(1rem,5vw,3rem) clamp(3rem,7vh,5rem);
      max-width: 1100px; margin: 0 auto;
    }

    /* top badge — matches site style */
    .hero-badge {
      display: inline-flex; align-items: center; gap: .5rem;
      font-size: 11px; font-weight: 600; letter-spacing: .1em; text-transform: uppercase;
      color: var(--orange);
      border: 1px solid rgba(226,88,34,.3);
      background: rgba(226,88,34,.08);
      padding: .35rem .9rem; border-radius: 4px;
      margin-bottom: clamp(1.2rem,3vh,1.8rem);
      animation: up .6s ease both;
    }
    .bdot { width: 5px; height: 5px; border-radius: 50%; background: var(--orange); animation: bl 2s ease-in-out infinite; }
    @keyframes bl { 0%,100%{opacity:1} 50%{opacity:.25} }

    /* headline */
    .hero-h1 {
      font-size: clamp(2rem, 4.5vw, 3.8rem);
      font-weight: 700; line-height: 1.12; letter-spacing: -.025em;
      color: var(--white);
      margin-bottom: clamp(.9rem,2.5vh,1.3rem);
      animation: up .6s .1s ease both;
      max-width: 700px;
    }
    .hero-h1 .accent { color: var(--orange); }

    .hero-sub {
      font-size: clamp(.9rem,1.8vw,1.05rem);
      color: var(--muted); line-height: 1.7; font-weight: 400;
      max-width: 560px;
      margin-bottom: clamp(1.5rem,4vh,2.5rem);
      animation: up .6s .2s ease both;
    }

    /* stats row — same as other pages */
    .hero-stats {
      display: flex; flex-wrap: wrap; gap: clamp(.6rem,2vw,1.2rem);
      margin-bottom: clamp(2rem,5vh,3rem);
      animation: up .6s .28s ease both;
    }
    .stat-chip {
      display: flex; align-items: center; gap: .5rem;
      background: var(--bg3); border: 1px solid var(--border2);
      border-radius: 6px; padding: .55rem 1rem;
      font-size: 13px; color: var(--muted);
    }
    .stat-chip strong { color: var(--white); font-weight: 600; }
    .stat-chip .flag { font-size: 16px; line-height: 1; }

    /* ─── TWO COLUMN LAYOUT ─── */
    .hero-body {
      display: grid;
      grid-template-columns: 1fr 380px;
      gap: clamp(1.5rem,4vw,3rem);
      align-items: start;
      animation: up .6s .35s ease both;
    }
    @media (max-width: 820px) { .hero-body { grid-template-columns: 1fr; } }

    /* left — program cards */
    .program-cards { display: flex; flex-direction: column; gap: .85rem; }
    .prog-card {
      background: var(--bg2);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 1.4rem 1.5rem;
      display: flex; align-items: flex-start; gap: 1rem;
      transition: border-color .25s, transform .2s;
    }
    .prog-card:hover { border-color: rgba(226,88,34,.35); transform: translateX(4px); }
    .prog-icon {
      width: 44px; height: 44px; border-radius: 10px; flex-shrink: 0;
      display: flex; align-items: center; justify-content: center;
      font-size: 20px;
      background: rgba(226,88,34,.1); border: 1px solid rgba(226,88,34,.2);
    }
    .prog-info {}
    .prog-label {
      font-size: 10.5px; font-weight: 600; letter-spacing: .1em; text-transform: uppercase;
      color: var(--orange); margin-bottom: .35rem;
    }
    .prog-title { font-size: 15px; font-weight: 600; color: var(--white); margin-bottom: .3rem; line-height: 1.3; }
    .prog-desc { font-size: 12.5px; color: var(--muted); line-height: 1.6; }
    .prog-tags { display: flex; flex-wrap: wrap; gap: .35rem; margin-top: .6rem; }
    .prog-tag {
      font-size: 11px; color: var(--muted2);
      border: 1px solid var(--border); border-radius: 4px;
      padding: .18rem .55rem;
    }

    /* right — waitlist box */
    .waitlist {
      background: var(--bg2);
      border: 1px solid var(--border2);
      border-radius: 12px;
      padding: 1.6rem;
      position: sticky; top: 80px;
    }
    .wl-head {
      font-size: 14px; font-weight: 600; color: var(--white);
      margin-bottom: .4rem;
    }
    .wl-sub { font-size: 12px; color: var(--muted); line-height: 1.5; margin-bottom: 1.1rem; }
    .wl-sub strong { color: var(--orange); }
    .wl-field {
      width: 100%;
      background: rgba(255,255,255,.05);
      border: 1px solid var(--border2);
      border-radius: 6px;
      color: var(--white); font-family: 'Inter', sans-serif; font-size: 13.5px;
      padding: .72rem .9rem; outline: none; margin-bottom: .6rem;
      transition: border-color .2s;
    }
    .wl-field::placeholder { color: var(--muted2); }
    .wl-field:focus { border-color: rgba(226,88,34,.5); }
    .wl-field.err { border-color: rgba(230,80,60,.5); animation: sh .3s ease; }
    @keyframes sh { 25%{transform:translateX(-4px)} 75%{transform:translateX(4px)} }
    .wl-btn {
      width: 100%; background: var(--orange); color: var(--white);
      font-family: 'Inter', sans-serif; font-size: 14px; font-weight: 600;
      padding: .8rem; border: none; border-radius: 6px; cursor: pointer;
      transition: background .2s, transform .15s;
    }
    .wl-btn:hover { background: var(--orange-h); transform: translateY(-1px); }
    .wl-btn:active { transform: translateY(0); }
    .wl-btn:disabled { opacity: .4; cursor: not-allowed; transform: none; }
    .wl-ok {
      display: none; align-items: center; justify-content: center; gap: .5rem;
      font-size: 12.5px; color: #6dbf88; margin-top: .7rem; text-align: center;
    }
    .wl-ok.show { display: flex; animation: up .3s ease both; }
    .wl-divider { border: none; border-top: 1px solid var(--border); margin: 1.1rem 0; }
    .wl-trust {
      display: flex; flex-direction: column; gap: .4rem;
    }
    .trust-row {
      display: flex; align-items: center; gap: .5rem;
      font-size: 12px; color: var(--muted);
    }
    .trust-row svg { flex-shrink: 0; }

    /* ─── COUNTDOWN ─── */
    .countdown-section {
      position: relative; z-index: 2;
      background: var(--bg2);
      border-top: 1px solid var(--border);
      border-bottom: 1px solid var(--border);
      padding: clamp(2rem,5vh,3rem) clamp(1rem,5vw,3rem);
      text-align: center;
    }
    .cd-eyebrow {
      font-size: 11px; font-weight: 600; letter-spacing: .12em; text-transform: uppercase;
      color: var(--orange); margin-bottom: .6rem;
    }
    .cd-title { font-size: clamp(1rem,2vw,1.15rem); font-weight: 500; color: var(--muted); margin-bottom: 1.5rem; }
    .cd-row {
      display: flex; align-items: flex-start; justify-content: center;
      gap: clamp(.8rem,3vw,2rem); flex-wrap: nowrap;
    }
    .cd-blk { text-align: center; min-width: clamp(52px,10vw,72px); }
    .cd-n {
      font-size: clamp(2rem,5vw,3.5rem); font-weight: 700;
      color: var(--white); line-height: 1; font-variant-numeric: tabular-nums; display: block;
    }
    .cd-u { font-size: 10px; letter-spacing: .1em; text-transform: uppercase; color: var(--muted2); margin-top: .3rem; }
    .cd-sep { font-size: clamp(1.6rem,4vw,2.8rem); font-weight: 700; color: var(--orange); line-height: 1; padding-top: .1rem; animation: bl 1s ease-in-out infinite; }

    /* ─── WHAT'S COMING ─── */
    .coming-section {
      position: relative; z-index: 2;
      padding: clamp(3rem,7vh,5rem) clamp(1rem,5vw,3rem);
      max-width: 1100px; margin: 0 auto;
    }
    .section-eyebrow {
      font-size: 11px; font-weight: 600; letter-spacing: .12em; text-transform: uppercase;
      color: var(--orange); margin-bottom: .5rem;
    }
    .section-title {
      font-size: clamp(1.4rem,3vw,2rem); font-weight: 700;
      color: var(--white); margin-bottom: clamp(1.5rem,4vh,2.5rem); line-height: 1.25;
    }
    .feat-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(min(230px,100%),1fr));
      gap: .85rem;
    }
    .feat {
      background: var(--bg2); border: 1px solid var(--border); border-radius: 10px;
      padding: 1.4rem;
      transition: border-color .25s, background .25s;
    }
    .feat:hover { border-color: rgba(226,88,34,.3); background: rgba(226,88,34,.04); }
    .feat-ico { font-size: 22px; margin-bottom: .8rem; display: block; }
    .feat-t { font-size: 14px; font-weight: 600; color: var(--white); margin-bottom: .4rem; line-height: 1.3; }
    .feat-d { font-size: 12.5px; color: var(--muted); line-height: 1.65; }

    /* ─── CTA BANNER — matches site ─── */
    .cta-banner {
      position: relative; z-index: 2;
      background: linear-gradient(135deg, rgba(226,88,34,.12) 0%, rgba(226,88,34,.04) 100%);
      border-top: 1px solid rgba(226,88,34,.2);
      border-bottom: 1px solid rgba(226,88,34,.2);
      padding: clamp(2.5rem,6vh,4rem) clamp(1rem,5vw,3rem);
      text-align: center;
    }
    .cta-banner h2 { font-size: clamp(1.3rem,3vw,1.9rem); font-weight: 700; color: var(--white); margin-bottom: .6rem; }
    .cta-banner p { font-size: clamp(.85rem,1.6vw,.98rem); color: var(--muted); margin-bottom: 1.5rem; max-width: 480px; margin-left: auto; margin-right: auto; }
    .cta-banner-btn {
      display: inline-flex; align-items: center; gap: .5rem;
      background: var(--orange); color: var(--white);
      font-family: 'Inter', sans-serif; font-size: 14px; font-weight: 600;
      padding: .85rem 1.8rem; border-radius: 6px; text-decoration: none;
      transition: background .2s, transform .15s;
    }
    .cta-banner-btn:hover { background: var(--orange-h); transform: translateY(-2px); }

    /* ─── FOOTER — matches site ─── */
    footer {
      background: #080808;
      border-top: 1px solid var(--border);
      position: relative; z-index: 2;
    }
    .footer-inner {
      max-width: 1100px; margin: 0 auto;
      padding: clamp(2.5rem,6vh,3.5rem) clamp(1rem,5vw,3rem) clamp(1.5rem,4vh,2rem);
      display: grid;
      grid-template-columns: 2fr 1fr 1fr 1.5fr;
      gap: 2rem;
    }
    @media (max-width: 700px) { .footer-inner { grid-template-columns: 1fr 1fr; } }
    @media (max-width: 440px) { .footer-inner { grid-template-columns: 1fr; } }
    .footer-brand img { height: 28px; margin-bottom: .75rem; }
    .footer-brand p { font-size: 12.5px; color: var(--muted2); line-height: 1.65; }
    .footer-col h4 { font-size: 12px; font-weight: 600; letter-spacing: .08em; text-transform: uppercase; color: var(--muted); margin-bottom: .75rem; }
    .footer-col ul { list-style: none; display: flex; flex-direction: column; gap: .4rem; }
    .footer-col ul li a { font-size: 13px; color: var(--muted2); text-decoration: none; transition: color .2s; }
    .footer-col ul li a:hover { color: var(--white); }
    .footer-col p { font-size: 12.5px; color: var(--muted2); line-height: 1.7; }
    .footer-bottom {
      border-top: 1px solid var(--border);
      padding: 1.1rem clamp(1rem,5vw,3rem);
      text-align: center; font-size: 12px; color: var(--muted2);
    }
    .footer-bottom a { color: var(--muted2); text-decoration: none; }
    .footer-bottom a:hover { color: var(--white); }

    /* subtle bg texture */
    .hero::before {
      content: '';
      position: absolute; inset: 0; pointer-events: none; z-index: -1;
      background: radial-gradient(ellipse 60% 50% at 50% 0%, rgba(226,88,34,.06) 0%, transparent 70%);
    }

    @keyframes up { from{opacity:0;transform:translateY(16px)} to{opacity:1;transform:translateY(0)} }

    @media (max-width: 480px) {
      .hero-stats { gap: .5rem; }
      .stat-chip { font-size: 12px; padding: .45rem .75rem; }
      .cd-row { gap: .6rem; }
      .feat-grid { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>

  <!-- NAV — exact match -->
  <nav class="nav">
    <a href="/"><img src="/logo.png" alt="Finesse Overseas Education" style="height:30px" /></a>
    <ul class="nav-links">
      <li><a href="/#destinations">Destinations</a></li>
      <li><a href="/#services">Services</a></li>
      <li><a href="/#faq">FAQ</a></li>
      <li><a href="/contact" class="nav-cta">Book Free Counseling</a></li>
    </ul>
    <a href="/contact" class="nav-mobile-cta">Book Free Counseling</a>
  </nav>

  <!-- BREADCRUMB -->
  <div class="breadcrumb">
    <a href="/">Home</a>
    <span>›</span>
    <span>Destinations</span>
    <span>›</span>
    <span style="color:var(--muted)">UK / USA</span>
  </div>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-badge"><span class="bdot"></span> Program Launching 2026</div>

    <h1 class="hero-h1">
      Study in UK & USA.<br/>
      <span class="accent">We're Building This.</span>
    </h1>
    <p class="hero-sub">
      The same expertise that placed 1000+ students in Germany & Italy — now being precision-engineered for UK and USA pathways. 1-Year Masters UK. 3-Year STEM OPT USA.
    </p>

    <div class="hero-stats">
      <div class="stat-chip"><span class="flag">🇬🇧</span> <strong>United Kingdom</strong> — 1-Year Masters</div>
      <div class="stat-chip"><span class="flag">🇺🇸</span> <strong>United States</strong> — 3-Year STEM OPT</div>
      <div class="stat-chip">🎓 <strong>Russell Group</strong> universities</div>
      <div class="stat-chip">💼 <strong>Top 50</strong> US universities</div>
    </div>

    <div class="hero-body">

      <!-- Program cards -->
      <div class="program-cards">
        <div class="prog-card">
          <div class="prog-icon">🇬🇧</div>
          <div class="prog-info">
            <div class="prog-label">UK Program</div>
            <div class="prog-title">1-Year Masters — Fast Track</div>
            <div class="prog-desc">Complete a full Masters degree in just 12 months at Russell Group universities. Graduate visa gives you 2 years of post-study work authorization to land a UK job.</div>
            <div class="prog-tags">
              <span class="prog-tag">IELTS 6.5+</span>
              <span class="prog-tag">60%+ CGPA</span>
              <span class="prog-tag">2-yr Graduate Visa</span>
              <span class="prog-tag">No Blocked Account</span>
            </div>
          </div>
        </div>

        <div class="prog-card">
          <div class="prog-icon">🇺🇸</div>
          <div class="prog-info">
            <div class="prog-label">USA Program</div>
            <div class="prog-title">STEM OPT — 3-Year Work Permit</div>
            <div class="prog-desc">STEM-designated MS programs unlock 3 full years of legal work authorization after graduation. Silicon Valley, New York, Seattle — direct access to global tech companies.</div>
            <div class="prog-tags">
              <span class="prog-tag">GRE Optional</span>
              <span class="prog-tag">F-1 Visa</span>
              <span class="prog-tag">3-yr STEM OPT</span>
              <span class="prog-tag">CPT Available</span>
            </div>
          </div>
        </div>

        <div class="prog-card">
          <div class="prog-icon">🎯</div>
          <div class="prog-info">
            <div class="prog-label">Our Approach</div>
            <div class="prog-title">Profile-First Shortlisting. Zero Commission Bias.</div>
            <div class="prog-desc">No shotgun applications. We shortlist universities purely on your CGPA, background, and career goals — the same approach that gave us 99% visa success in Germany.</div>
            <div class="prog-tags">
              <span class="prog-tag">SOP + LOR Drafting</span>
              <span class="prog-tag">Visa Interview Prep</span>
              <span class="prog-tag">End-to-End Support</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Waitlist box -->
      <div class="waitlist">
        <div class="wl-head">Get Early Access</div>
        <div class="wl-sub">Join <strong id="counter">247</strong> students already on the waitlist. We'll notify you the moment we launch.</div>

        <input class="wl-field" id="wl-name" type="text" placeholder="Your full name" />
        <input class="wl-field" id="wl-phone" type="tel" placeholder="WhatsApp number" maxlength="10" />
        <button class="wl-btn" id="wl-btn" onclick="joinWL()">Join the Waitlist →</button>
        <div class="wl-ok" id="wl-ok">
          <svg width="14" height="14" fill="none" viewBox="0 0 14 14"><path d="M2 7l3.5 3.5L12 3.5" stroke="#6dbf88" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
          You're on the list. We'll reach out first.
        </div>

        <hr class="wl-divider" />
        <div class="wl-trust">
          <div class="trust-row">
            <svg width="14" height="14" fill="none" viewBox="0 0 14 14"><path d="M7 1L8.8 5.2H13.4L9.6 7.9L11 12.1L7 9.5L3 12.1L4.4 7.9L.6 5.2H5.2Z" stroke="#e25822" stroke-width="1.2" fill="none"/></svg>
            22+ years of on-ground expertise
          </div>
          <div class="trust-row">
            <svg width="14" height="14" fill="none" viewBox="0 0 14 14"><circle cx="7" cy="7" r="5.5" stroke="#e25822" stroke-width="1.2"/><path d="M4.5 7l2 2 3-3.5" stroke="#e25822" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            99% visa success rate (Germany 2025)
          </div>
          <div class="trust-row">
            <svg width="14" height="14" fill="none" viewBox="0 0 14 14"><path d="M2 2h10v8H2z" stroke="#e25822" stroke-width="1.2" rx="1"/><path d="M5 10v2M9 10v2M3 12h8" stroke="#e25822" stroke-width="1.2" stroke-linecap="round"/></svg>
            Offices in Kolhapur & Pune
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- COUNTDOWN -->
  <div class="countdown-section">
    <div class="cd-eyebrow">Official Launch</div>
    <div class="cd-title">UK & USA program goes live in</div>
    <div class="cd-row">
      <div class="cd-blk"><span class="cd-n" id="cd-d">--</span><span class="cd-u">Days</span></div>
      <span class="cd-sep">:</span>
      <div class="cd-blk"><span class="cd-n" id="cd-h">--</span><span class="cd-u">Hours</span></div>
      <span class="cd-sep">:</span>
      <div class="cd-blk"><span class="cd-n" id="cd-m">--</span><span class="cd-u">Mins</span></div>
      <span class="cd-sep">:</span>
      <div class="cd-blk"><span class="cd-n" id="cd-s">--</span><span class="cd-u">Secs</span></div>
    </div>
  </div>

  <!-- WHAT'S COMING -->
  <section class="coming-section">
    <div class="section-eyebrow">What's Coming</div>
    <h2 class="section-title">The Finesse Blueprint — UK & USA Edition</h2>
    <div class="feat-grid">
      <div class="feat">
        <span class="feat-ico">📋</span>
