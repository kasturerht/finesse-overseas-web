  <script>
    /* countdown — Oct 1 2026 */
    const T = new Date('2026-10-01T00:00:00');
    function tick() {
      const d = T - Date.now();
      if (d <= 0) { document.querySelector('.countdown-section').style.display='none'; return; }
      const p = n => String(Math.floor(n)).padStart(2,'0');
      document.getElementById('cd-d').textContent = p(d/86400000);
      document.getElementById('cd-h').textContent = p(d%86400000/3600000);
      document.getElementById('cd-m').textContent = p(d%3600000/60000);
      document.getElementById('cd-s').textContent = p(d%60000/1000);
    }
    setInterval(tick,1000); tick();

    /* waitlist */
    let count = 247;
    function joinWL() {
      const name = document.getElementById('wl-name');
      const phone = document.getElementById('wl-phone');
      let ok = true;
      if (name.value.trim().length < 2) { name.classList.add('err'); setTimeout(()=>name.classList.remove('err'),700); ok=false; }
      if (phone.value.trim().length < 10) { phone.classList.add('err'); setTimeout(()=>phone.classList.remove('err'),700); ok=false; }
      if (!ok) return;
      count++;
      document.getElementById('counter').textContent = count;
      document.getElementById('wl-ok').classList.add('show');
      name.value=''; phone.value=''; name.disabled=true; phone.disabled=true;
      document.getElementById('wl-btn').disabled=true;
    }

    /* enter key on fields */
    ['wl-name','wl-phone'].forEach(id => {
      document.getElementById(id).addEventListener('keydown', e => { if(e.key==='Enter') joinWL(); });
    });
  </script>

