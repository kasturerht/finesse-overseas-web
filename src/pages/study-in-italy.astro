---
// src/pages/study-in-italy.astro
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';

// 🌟 CORRECTED: Image imported from assets folder
import { Picture } from 'astro:assets';
import heroImage from '../assets/italy-hero.avif'; 
---

<Layout title="Study in Italy with 100% Scholarship | Finesse Overseas" description="Get 100% tuition fee waiver and an annual stipend of up to €7,400 (8 Lakhs INR) in top Italian Public Universities.">
  
  <main class="pt-20 flex-grow">

    <section class="relative bg-slate-950 pt-16 pb-24 lg:pt-24 lg:pb-32 overflow-hidden border-b border-slate-800">
      
      <div class="absolute inset-0 z-0 overflow-hidden pointer-events-none">
        <div class="absolute top-[-10%] right-[-5%] w-[600px] h-[600px] bg-blue-600/10 rounded-full blur-[120px] hidden md:block"></div>
        <div class="absolute bottom-[-10%] left-[-5%] w-[500px] h-[500px] bg-amber-500/10 rounded-full blur-[120px] hidden md:block"></div>
      </div>

      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        
        <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-12 border-b border-slate-800/60 pb-6">
          <nav class="flex text-xs font-bold tracking-widest uppercase text-slate-400">
            <a href="/" class="hover:text-teal-400 transition-colors">Home</a>
            <span class="mx-2">/</span>
            <span class="text-slate-500">Destinations</span>
            <span class="mx-2">/</span>
            <span class="text-white">Italy</span>
          </nav>
          
          <div class="inline-flex items-center gap-2 bg-slate-900/80 border border-slate-700/50 rounded-full px-4 py-1.5 backdrop-blur-md shadow-sm">
            <span class="relative flex h-2 w-2">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-amber-400 opacity-75"></span>
              <span class="relative inline-flex rounded-full h-2 w-2 bg-amber-500"></span>
            </span>
            <span class="text-[10px] font-bold text-slate-300 uppercase tracking-wider">Verified for 2026 Intake</span>
          </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-center">
          
          <div class="lg:col-span-7">
            
            <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-lg bg-amber-500/10 border border-amber-500/20 text-amber-400 font-bold tracking-widest uppercase mb-6 text-xs shadow-inner">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
              DSU Scholarship Available
            </div>
            
            <h1 class="text-5xl md:text-6xl lg:text-[4.5rem] font-black text-white mb-4 tracking-tighter leading-[1.05]">
              Study in Italy with <br class="hidden md:block"/>
              <span class="text-transparent bg-clip-text bg-gradient-to-r from-amber-300 to-yellow-500">100% Scholarship</span>
            </h1>
            
            <p class="text-xl md:text-2xl text-teal-300 font-bold mb-6 leading-relaxed">
              + Annual Stipend of up to €7,400 (₹8 Lakhs)
            </p>

            <p class="text-lg text-slate-300 font-medium mb-10 leading-relaxed max-w-2xl">
              Zero Tuition Fees. Top Public Universities. Valid across 29 Schengen Countries. <span class="text-white font-bold">Your Gateway to Europe without the Financial Burden.</span>
            </p>

            <div class="flex flex-col sm:flex-row gap-4 mb-14">
              <a href="/contact" class="flex justify-center items-center gap-2 bg-gradient-to-r from-amber-500 to-yellow-400 hover:from-amber-400 hover:to-yellow-300 text-slate-950 px-8 py-4.5 rounded-xl text-lg font-black transition-all shadow-[0_0_30px_rgba(245,158,11,0.25)] active:scale-95 group">
                Check Eligibility
                <svg class="w-5 h-5 transform group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
              </a>
              
              <a href="#process" class="flex justify-center items-center gap-2 bg-slate-900 hover:bg-slate-800 text-white border border-slate-700 hover:border-slate-500 px-8 py-4.5 rounded-xl text-lg font-bold transition-all active:scale-95 group shadow-sm">
                <svg class="w-5 h-5 text-slate-400 group-hover:text-white transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path></svg>
                Download Guide
              </a>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-8 pt-8 border-t border-slate-800/60">
              <div class="flex items-start gap-3.5">
                <div class="w-10 h-10 rounded-lg bg-slate-900 border border-slate-700/50 flex items-center justify-center shrink-0 shadow-inner">
                  <span class="text-amber-400 font-black text-lg">€0</span>
                </div>
                <div>
                  <p class="text-white font-bold text-sm tracking-wide">Zero Tuition Fees</p>
                  <p class="text-slate-500 text-xs mt-1 font-medium">In top public universities.</p>
                </div>
              </div>
              
              <div class="flex items-start gap-3.5">
                <div class="w-10 h-10 rounded-lg bg-slate-900 border border-slate-700/50 flex items-center justify-center shrink-0 shadow-inner">
                  <svg class="w-5 h-5 text-teal-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
                </div>
                <div>
                  <p class="text-white font-bold text-sm tracking-wide">Part-Time Jobs</p>
                  <p class="text-slate-500 text-xs mt-1 font-medium">Earn €9-10/hr legally.</p>
                </div>
              </div>
            </div>

          </div>

          <div class="lg:col-span-5 hidden lg:block relative z-20">
            
            <div class="absolute -inset-2 bg-gradient-to-tr from-blue-500/20 to-amber-400/20 blur-2xl rounded-[3rem] opacity-70"></div>

            <div class="relative w-full aspect-[4/5] rounded-[2.5rem] p-3 bg-slate-800/30 border border-slate-700/50 backdrop-blur-xl shadow-2xl">
              
              <div class="relative w-full h-full rounded-[2rem] overflow-hidden group">
                
                <Picture 
                  src={heroImage} 
                  alt="Student at Italian University Campus" 
                  widths={[400, 800, 1200, 1920]} 
                  sizes="(max-width: 400px) 400px, (max-width: 800px) 800px, (max-width: 1200px) 1200px, 1920px"
                  fallbackFormat="avif"
                  fetchpriority="high"
                  loading="eager"
                  class="absolute inset-0 w-full h-full object-cover object-center transform group-hover:scale-110 transition-transform duration-[2000ms] ease-out"
                />
                
                <div class="absolute inset-0 bg-gradient-to-t from-slate-950 via-slate-900/10 to-transparent opacity-90"></div>

                <div class="absolute bottom-6 left-6 right-auto bg-slate-900/80 backdrop-blur-2xl border border-amber-500/30 p-4 pr-8 rounded-2xl flex items-center gap-4 shadow-[0_8px_32px_rgba(0,0,0,0.5)] transform translate-y-1 group-hover:translate-y-0 transition-all duration-500">
                  <div class="w-12 h-12 bg-gradient-to-br from-amber-400 to-yellow-600 rounded-xl flex items-center justify-center text-slate-950 font-black text-xl shadow-inner shrink-0">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                  </div>
                  <div>
                    <p class="text-white font-black text-lg tracking-tight">€7,400 <span class="text-sm font-medium text-slate-400">/ Year</span></p>
                    <p class="text-amber-400 font-bold text-[10px] uppercase tracking-widest mt-0.5">Direct Bank Transfer</p>
                  </div>
                </div>

                <div class="absolute top-6 right-6 bg-slate-900/60 backdrop-blur-md border border-white/10 px-3 py-1.5 rounded-full flex items-center gap-2">
                  <span class="w-1.5 h-1.5 rounded-full bg-amber-400"></span>
                  <span class="text-white text-[9px] font-bold tracking-widest uppercase">DSU Scholarship</span>
                </div>

              </div>
            </div>
          </div>

        </div>
      </div>
    </section>

<section class="py-32 relative transition-colors duration-1000 ease-in-out bg-slate-50" id="money-math-section">
      
      <div id="bg-glow-eu" class="absolute inset-0 bg-rose-500/5 transition-opacity duration-1000 opacity-100 pointer-events-none"></div>
      <div id="bg-glow-italy" class="absolute inset-0 bg-amber-500/10 transition-opacity duration-1000 opacity-0 pointer-events-none"></div>
      
      <div class="absolute inset-0 bg-[url('data:image/svg+xml;base64,PHN2ZyB3aWR0aD0iNDAiIGhlaWdodD0iNDAiIHhtbG5zPSJodHRwOi8vd3d3LnczLm9yZy8yMDAwL3N2ZyI+CgkJPGNpcmNsZSBjeD0iMSIgY3k9IjEiIHI9IjEiIGZpbGw9InJnYmEoMCwwLDAsMC4wNSkiLz4KCTwvc3ZnPg==')] pointer-events-none"></div>

      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">

        <div class="text-center mb-16">
          <h2 class="text-4xl md:text-6xl font-black text-slate-900 tracking-tighter mb-6 transition-colors duration-700" id="main-heading">
            The Cost of Studying Abroad.
          </h2>
          <p class="text-slate-500 text-lg md:text-xl font-medium max-w-2xl mx-auto transition-colors duration-700" id="sub-heading">
            Experience the financial difference yourself. Flip the switch to see why Italy is the ultimate hack for Indian students.
          </p>
        </div>

        <div class="flex justify-center mb-16 relative z-20">
          <div class="bg-white border-2 border-slate-200 rounded-full p-1.5 flex relative shadow-lg">
            <div id="toggle-slider" class="absolute top-1.5 left-1.5 bottom-1.5 w-[calc(50%-6px)] bg-slate-900 rounded-full transition-all duration-500 ease-in-out shadow-md"></div>
            
            <button id="btn-eu" class="relative w-40 md:w-48 py-3.5 text-sm md:text-base font-bold text-white transition-colors duration-500 z-10">
              Other Countries
            </button>
            <button id="btn-italy" class="relative w-40 md:w-48 py-3.5 text-sm md:text-base font-bold text-slate-500 transition-colors duration-500 z-10 flex items-center justify-center gap-2">
              <svg class="w-4 h-4 opacity-0 transition-opacity duration-500" id="italy-sparkle" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"></path></svg>
              Study in Italy
            </button>
          </div>
        </div>

        <div class="relative max-w-5xl mx-auto">
          <div class="bg-white rounded-[2.5rem] shadow-[0_20px_60px_-15px_rgba(0,0,0,0.1)] border border-slate-200 p-8 md:p-12 transition-all duration-700" id="data-card">

            <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-center">
              
              <div class="lg:col-span-7 space-y-8">
                
                <div class="pb-6 border-b border-slate-200/50 transition-colors duration-700" id="border-1">
                  <p class="text-slate-400 text-xs font-bold uppercase tracking-widest mb-2 transition-colors duration-700" id="label-1">University Tuition Fee</p>
                  <div class="relative h-14">
                    <div id="tuition-eu" class="absolute inset-0 transition-all duration-500 transform translate-y-0 opacity-100">
                      <span class="text-2xl md:text-3xl font-black text-slate-800">€3,000 - €4,000 <span class="text-base text-slate-500 font-bold">/ Yr</span></span>
                      <p class="text-sm text-slate-500 mt-1 font-medium">Standard fees in most public universities.</p>
                    </div>
                    <div id="tuition-italy" class="absolute inset-0 transition-all duration-500 transform translate-y-4 opacity-0 pointer-events-none">
                      <span class="text-2xl md:text-3xl font-black text-teal-400">€0 <span class="text-base text-teal-500/80 font-bold">(100% Waived)</span></span>
                      <p class="text-sm text-slate-400 mt-1 font-medium">Under the DSU Scholarship scheme.</p>
                    </div>
                  </div>
                </div>

                <div class="pb-6 border-b border-slate-200/50 transition-colors duration-700" id="border-2">
                  <p class="text-slate-400 text-xs font-bold uppercase tracking-widest mb-2 transition-colors duration-700" id="label-2">Accommodation & Hostel</p>
                  <div class="relative h-14">
                    <div id="hostel-eu" class="absolute inset-0 transition-all duration-500 transform translate-y-0 opacity-100">
                      <span class="text-2xl md:text-3xl font-black text-slate-800">€400 - €600 <span class="text-base text-slate-500 font-bold">/ Month</span></span>
                      <p class="text-sm text-slate-500 mt-1 font-medium">High rent in private shared apartments.</p>
                    </div>
                    <div id="hostel-italy" class="absolute inset-0 transition-all duration-500 transform translate-y-4 opacity-0 pointer-events-none">
                      <span class="text-2xl md:text-3xl font-black text-white">Priority Discounts</span>
                      <p class="text-sm text-slate-400 mt-1 font-medium">Subsidized university hostels for DSU students.</p>
                    </div>
                  </div>
                </div>

                <div>
                  <p class="text-slate-400 text-xs font-bold uppercase tracking-widest mb-2 transition-colors duration-700" id="label-3">Daily Canteen Meals</p>
                  <div class="relative h-14">
                    <div id="meals-eu" class="absolute inset-0 transition-all duration-500 transform translate-y-0 opacity-100">
                      <span class="text-2xl md:text-3xl font-black text-slate-800">€5 <span class="text-base text-slate-500 font-bold">/ Meal</span></span>
                      <p class="text-sm text-slate-500 mt-1 font-medium">Adds up to €150-200 per month.</p>
                    </div>
                    <div id="meals-italy" class="absolute inset-0 transition-all duration-500 transform translate-y-4 opacity-0 pointer-events-none">
                      <span class="text-2xl md:text-3xl font-black text-teal-400">FREE <span class="text-base text-teal-500/80 font-bold">(1-2 Meals/Day)</span></span>
                      <p class="text-sm text-slate-400 mt-1 font-medium">Healthy meals provided at the campus mensa (canteen).</p>
                    </div>
                  </div>
                </div>

              </div>

              <div class="lg:col-span-5 h-full flex items-center">
                <div class="w-full bg-slate-50 rounded-[2rem] p-8 md:p-10 text-center border border-slate-200 transition-all duration-700 relative" id="roi-box">
                  
                  <p class="text-slate-500 text-sm font-bold uppercase tracking-widest mb-6 transition-colors duration-500" id="roi-label">Your Net Position</p>
                  
                  <div class="relative h-24 md:h-28 w-full flex justify-center items-center">
                    <div id="roi-eu" class="absolute inset-0 flex items-center justify-center transition-all duration-500 transform translate-y-0 opacity-100">
                      <span class="text-5xl md:text-6xl font-black text-rose-500 tracking-tighter drop-shadow-sm">-€9,300</span>
                    </div>
                    <div id="roi-italy" class="absolute inset-0 flex items-center justify-center transition-all duration-500 transform translate-y-4 opacity-0 pointer-events-none">
                      <span class="text-5xl md:text-6xl font-black text-transparent bg-clip-text bg-gradient-to-br from-amber-400 to-yellow-600 drop-shadow-md tracking-tighter leading-none">+€7,400</span>
                    </div>
                  </div>
                  
                  <p class="text-slate-500 font-medium text-sm mt-4 transition-colors duration-500" id="roi-subtext">Estimated total burden per year.</p>
                </div>
              </div>

            </div>
          </div>
        </div>

        <p class="text-center text-slate-400 font-medium text-sm mt-10 opacity-0 transition-all duration-1000 transform translate-y-4 pointer-events-none" id="expert-insight">
          <span class="text-amber-500 font-bold uppercase tracking-widest">Expert Note:</span> This €7,400 stipend is credited directly to your bank account under the DSU scheme based on family income.
        </p>

      </div>
    </section>

    <script>
      function initRealitySwitch() {
        const btnEu = document.getElementById('btn-eu');
        const btnItaly = document.getElementById('btn-italy');
        const slider = document.getElementById('toggle-slider');
        const section = document.getElementById('money-math-section');
        const dataCard = document.getElementById('data-card');
        
        // Backgrounds & Headings
        const bgEu = document.getElementById('bg-glow-eu');
        const bgItaly = document.getElementById('bg-glow-italy');
        const mainHeading = document.getElementById('main-heading');
        const subHeading = document.getElementById('sub-heading');
        
        // Data States (EU vs Italy) - NOW 3 ITEMS
        const tuitionEu = document.getElementById('tuition-eu');
        const tuitionItaly = document.getElementById('tuition-italy');
        
        const hostelEu = document.getElementById('hostel-eu');
        const hostelItaly = document.getElementById('hostel-italy');
        
        const mealsEu = document.getElementById('meals-eu');
        const mealsItaly = document.getElementById('meals-italy');
        
        const roiEu = document.getElementById('roi-eu');
        const roiItaly = document.getElementById('roi-italy');
        
        // UI Elements for Theme Sync
        const labels = [document.getElementById('label-1'), document.getElementById('label-2'), document.getElementById('label-3')];
        const borders = [document.getElementById('border-1'), document.getElementById('border-2')];
        
        const roiBox = document.getElementById('roi-box');
        const roiLabel = document.getElementById('roi-label');
        const roiSubtext = document.getElementById('roi-subtext');
        const italySparkle = document.getElementById('italy-sparkle');
        const expertInsight = document.getElementById('expert-insight');

        if(!btnEu || !btnItaly) return;

        const hideElement = (el) => {
          if(el) {
            el.classList.remove('opacity-100', 'translate-y-0');
            el.classList.add('opacity-0', '-translate-y-4', 'pointer-events-none');
          }
        };

        const showElement = (el) => {
          if(el) {
            el.classList.remove('opacity-0', 'translate-y-4', '-translate-y-4', 'pointer-events-none');
            el.classList.add('opacity-100', 'translate-y-0');
          }
        };

        // STATE 1: OTHER COUNTRIES (LIGHT MODE)
        btnEu.addEventListener('click', () => {
          slider.style.transform = 'translateX(0)';
          slider.className = 'absolute top-1.5 left-1.5 bottom-1.5 w-[calc(50%-6px)] bg-slate-900 rounded-full transition-all duration-500 shadow-md';
          btnEu.classList.replace('text-slate-500', 'text-white');
          btnItaly.classList.replace('text-slate-900', 'text-slate-500');
          italySparkle.classList.replace('opacity-100', 'opacity-0');

          section.classList.replace('bg-slate-900', 'bg-slate-50');
          mainHeading.classList.replace('text-white', 'text-slate-900');
          subHeading.classList.replace('text-slate-400', 'text-slate-500');
          bgEu.classList.replace('opacity-0', 'opacity-100');
          bgItaly.classList.replace('opacity-100', 'opacity-0');
          
          dataCard.className = 'bg-white rounded-[2.5rem] shadow-[0_20px_60px_-15px_rgba(0,0,0,0.1)] border border-slate-200 p-8 md:p-12 transition-all duration-700';

          labels.forEach(l => l.classList.replace('text-slate-500', 'text-slate-400'));
          borders.forEach(b => b.classList.replace('border-slate-700', 'border-slate-200/50'));

          showElement(tuitionEu); hideElement(tuitionItaly);
          showElement(hostelEu);  hideElement(hostelItaly);
          showElement(mealsEu);   hideElement(mealsItaly);
          showElement(roiEu);     hideElement(roiItaly);

          roiBox.className = 'w-full bg-slate-50 rounded-[2rem] p-8 md:p-10 text-center border border-slate-200 transition-all duration-700 relative';
          roiLabel.classList.replace('text-amber-500', 'text-slate-500');
          roiSubtext.classList.replace('text-amber-200/60', 'text-slate-500');
          roiSubtext.textContent = 'Estimated total burden per year.';

          expertInsight.classList.remove('opacity-100', 'translate-y-0');
          expertInsight.classList.add('opacity-0', 'translate-y-4');
        });

        // STATE 2: STUDY IN ITALY (DARK MODE)
        btnItaly.addEventListener('click', () => {
          slider.style.transform = 'translateX(100%)';
          slider.className = 'absolute top-1.5 left-1.5 bottom-1.5 w-[calc(50%-6px)] bg-gradient-to-r from-amber-400 to-yellow-500 rounded-full transition-all duration-500 shadow-[0_0_20px_rgba(245,158,11,0.4)]';
          btnItaly.classList.replace('text-slate-500', 'text-slate-900');
          btnEu.classList.replace('text-white', 'text-slate-500');
          italySparkle.classList.replace('opacity-0', 'opacity-100');
          italySparkle.classList.replace('text-currentColor', 'text-slate-900');

          section.classList.replace('bg-slate-50', 'bg-slate-900');
          mainHeading.classList.replace('text-slate-900', 'text-white');
          subHeading.classList.replace('text-slate-500', 'text-slate-400');
          bgEu.classList.replace('opacity-100', 'opacity-0');
          bgItaly.classList.replace('opacity-0', 'opacity-100');
          
          dataCard.className = 'bg-slate-900/60 backdrop-blur-xl rounded-[2.5rem] shadow-[0_30px_80px_-15px_rgba(0,0,0,0.5)] border border-slate-700 p-8 md:p-12 transition-all duration-700';

          labels.forEach(l => l.classList.replace('text-slate-400', 'text-slate-500'));
          borders.forEach(b => b.classList.replace('border-slate-200/50', 'border-slate-700'));

          hideElement(tuitionEu); showElement(tuitionItaly);
          hideElement(hostelEu);  showElement(hostelItaly);
          hideElement(mealsEu);   showElement(mealsItaly);
          hideElement(roiEu);     showElement(roiItaly);

          roiBox.className = 'w-full bg-slate-950 rounded-[2rem] p-8 md:p-10 text-center border border-amber-500/30 transition-all duration-700 relative shadow-2xl transform md:scale-105';
          roiLabel.classList.replace('text-slate-500', 'text-amber-500');
          roiSubtext.classList.replace('text-slate-500', 'text-amber-200/60');
          roiSubtext.textContent = 'Direct cash stipend (Approx ₹8 Lakhs)';

          expertInsight.classList.remove('opacity-0', 'translate-y-4');
          expertInsight.classList.add('opacity-100', 'translate-y-0');
        });
      }

      initRealitySwitch();
      document.addEventListener('astro:page-load', initRealitySwitch);
    </script>
    


    <!-- Section -3 -->
    <section class="py-24 bg-white relative overflow-hidden" id="eligibility">
