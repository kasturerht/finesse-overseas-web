---
// src/pages/study-in-italy.astro
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';

// 🌟 CORRECTED: Image imported from assets folder
import { Picture } from 'astro:assets';
import heroImage from '../assets/italy-hero.avif'; 
---

<Layout title="Study in Italy with 100% Scholarship | Finesse Overseas" description="Get 100% tuition fee waiver and an annual stipend of up to €7,400 (8 Lakhs INR) in top Italian Public Universities.">
  
  <main class="pt-20 flex-grow">

    <section class="relative bg-slate-950 pt-16 pb-24 lg:pt-24 lg:pb-32 overflow-hidden border-b border-slate-800">
      
      <div class="absolute inset-0 z-0 overflow-hidden pointer-events-none">
        <div class="absolute top-[-10%] right-[-5%] w-[600px] h-[600px] bg-blue-600/10 rounded-full blur-[120px] hidden md:block"></div>
        <div class="absolute bottom-[-10%] left-[-5%] w-[500px] h-[500px] bg-amber-500/10 rounded-full blur-[120px] hidden md:block"></div>
      </div>

      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        
        <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-12 border-b border-slate-800/60 pb-6">
          <nav class="flex text-xs font-bold tracking-widest uppercase text-slate-400">
            <a href="/" class="hover:text-teal-400 transition-colors">Home</a>
            <span class="mx-2">/</span>
            <span class="text-slate-500">Destinations</span>
            <span class="mx-2">/</span>
            <span class="text-white">Italy</span>
          </nav>
          
          <div class="inline-flex items-center gap-2 bg-slate-900/80 border border-slate-700/50 rounded-full px-4 py-1.5 backdrop-blur-md shadow-sm">
            <span class="relative flex h-2 w-2">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-amber-400 opacity-75"></span>
              <span class="relative inline-flex rounded-full h-2 w-2 bg-amber-500"></span>
            </span>
            <span class="text-[10px] font-bold text-slate-300 uppercase tracking-wider">Verified for 2026 Intake</span>
          </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-center">
          
          <div class="lg:col-span-7">
            
            <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-lg bg-amber-500/10 border border-amber-500/20 text-amber-400 font-bold tracking-widest uppercase mb-6 text-xs shadow-inner">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
              DSU Scholarship Available
            </div>
            
            <h1 class="text-5xl md:text-6xl lg:text-[4.5rem] font-black text-white mb-4 tracking-tighter leading-[1.05]">
              Study in Italy with <br class="hidden md:block"/>
              <span class="text-transparent bg-clip-text bg-gradient-to-r from-amber-300 to-yellow-500">100% Scholarship</span>
            </h1>
            
            <p class="text-xl md:text-2xl text-teal-300 font-bold mb-6 leading-relaxed">
              + Annual Stipend of up to €7,400 (₹8 Lakhs)
            </p>

            <p class="text-lg text-slate-300 font-medium mb-10 leading-relaxed max-w-2xl">
              Zero Tuition Fees. Top Public Universities. Valid across 29 Schengen Countries. <span class="text-white font-bold">Your Gateway to Europe without the Financial Burden.</span>
            </p>

            <div class="flex flex-col sm:flex-row gap-4 mb-14">
              <a href="/contact" class="flex justify-center items-center gap-2 bg-gradient-to-r from-amber-500 to-yellow-400 hover:from-amber-400 hover:to-yellow-300 text-slate-950 px-8 py-4.5 rounded-xl text-lg font-black transition-all shadow-[0_0_30px_rgba(245,158,11,0.25)] active:scale-95 group">
                Check Eligibility
                <svg class="w-5 h-5 transform group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
              </a>
              
              <a href="#process" class="flex justify-center items-center gap-2 bg-slate-900 hover:bg-slate-800 text-white border border-slate-700 hover:border-slate-500 px-8 py-4.5 rounded-xl text-lg font-bold transition-all active:scale-95 group shadow-sm">
                <svg class="w-5 h-5 text-slate-400 group-hover:text-white transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path></svg>
                Download Guide
              </a>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-8 pt-8 border-t border-slate-800/60">
              <div class="flex items-start gap-3.5">
                <div class="w-10 h-10 rounded-lg bg-slate-900 border border-slate-700/50 flex items-center justify-center shrink-0 shadow-inner">
                  <span class="text-amber-400 font-black text-lg">€0</span>
                </div>
                <div>
                  <p class="text-white font-bold text-sm tracking-wide">Zero Tuition Fees</p>
                  <p class="text-slate-500 text-xs mt-1 font-medium">In top public universities.</p>
                </div>
              </div>
              
              <div class="flex items-start gap-3.5">
                <div class="w-10 h-10 rounded-lg bg-slate-900 border border-slate-700/50 flex items-center justify-center shrink-0 shadow-inner">
                  <svg class="w-5 h-5 text-teal-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
                </div>
                <div>
                  <p class="text-white font-bold text-sm tracking-wide">Part-Time Jobs</p>
                  <p class="text-slate-500 text-xs mt-1 font-medium">Earn €9-10/hr legally.</p>
                </div>
              </div>
            </div>

          </div>

          <div class="lg:col-span-5 hidden lg:block relative z-20">
            
            <div class="absolute -inset-2 bg-gradient-to-tr from-blue-500/20 to-amber-400/20 blur-2xl rounded-[3rem] opacity-70"></div>

            <div class="relative w-full aspect-[4/5] rounded-[2.5rem] p-3 bg-slate-800/30 border border-slate-700/50 backdrop-blur-xl shadow-2xl">
              
              <div class="relative w-full h-full rounded-[2rem] overflow-hidden group">
                
                <Picture 
                  src={heroImage} 
                  alt="Student at Italian University Campus" 
                  widths={[400, 800, 1200, 1920]} 
                  sizes="(max-width: 400px) 400px, (max-width: 800px) 800px, (max-width: 1200px) 1200px, 1920px"
                  fallbackFormat="avif"
                  fetchpriority="high"
                  loading="eager"
                  class="absolute inset-0 w-full h-full object-cover object-center transform group-hover:scale-110 transition-transform duration-[2000ms] ease-out"
                />
                
                <div class="absolute inset-0 bg-gradient-to-t from-slate-950 via-slate-900/10 to-transparent opacity-90"></div>

                <div class="absolute bottom-6 left-6 right-auto bg-slate-900/80 backdrop-blur-2xl border border-amber-500/30 p-4 pr-8 rounded-2xl flex items-center gap-4 shadow-[0_8px_32px_rgba(0,0,0,0.5)] transform translate-y-1 group-hover:translate-y-0 transition-all duration-500">
                  <div class="w-12 h-12 bg-gradient-to-br from-amber-400 to-yellow-600 rounded-xl flex items-center justify-center text-slate-950 font-black text-xl shadow-inner shrink-0">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                  </div>
                  <div>
                    <p class="text-white font-black text-lg tracking-tight">€7,400 <span class="text-sm font-medium text-slate-400">/ Year</span></p>
                    <p class="text-amber-400 font-bold text-[10px] uppercase tracking-widest mt-0.5">Direct Bank Transfer</p>
                  </div>
                </div>

                <div class="absolute top-6 right-6 bg-slate-900/60 backdrop-blur-md border border-white/10 px-3 py-1.5 rounded-full flex items-center gap-2">
                  <span class="w-1.5 h-1.5 rounded-full bg-amber-400"></span>
                  <span class="text-white text-[9px] font-bold tracking-widest uppercase">DSU Scholarship</span>
                </div>

              </div>
            </div>
          </div>

        </div>
      </div>
    </section>

  </main>
  
  <Footer />
</Layout>