---
// src/pages/tier-a-mbbs-india.astro
import Layout from '../layouts/Layout.astro';

const seoTitle = "Tier-A Private MBBS Admissions | Official Management Quota | Finesse Overseas";
const seoDescription = "Secure your child's MBBS seat in India's top Tier-A private medical colleges. 100% transparent process. Pay fees directly to the institution. Zero hidden charges.";
---

<Layout title={seoTitle} description={seoDescription}>

    <meta property="og:title" content={seoTitle} />
    <meta property="og:description" content={seoDescription} />
    <meta property="og:image" content="https://finesseoverseas.com/images/tier-a-mbbs-preview.jpg" />
    <meta property="og:url" content="https://finesseoverseas.com/tier-a-mbbs-india" />
    <meta property="og:type" content="website" />

  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "EducationalOrganization",
      "name": "Finesse Overseas Education",
      "description": "Secure your MBBS/BDS/MD seat in India's top Tier-A private medical colleges through official management and NRI quotas.",
      "url": "https://finesseoverseas.com/tier-a-mbbs-india",
      "sameAs": [
        "https://www.facebook.com/FinesseOverseasEducation"
      ],
      "contactPoint": {
        "@type": "ContactPoint",
        "telephone": "+91-98500 69600", 
        "contactType": "admissions",
        "availableLanguage": "en"
      },
      "areaServed": "IN",
      "offers": {
        "@type": "Offer",
        "category": "Educational Service",
        "name": "Tier-A Private MBBS Admissions Guidance",
        "priceCurrency": "INR",
        "price": "12000000"
      }
    }
  </script>

  <main class="flex-grow bg-[#03070E] selection:bg-amber-500/30 selection:text-amber-200">

    <div class="absolute top-0 left-0 w-full z-50 px-6 py-6 lg:px-12 flex justify-between items-center pointer-events-auto">
        <div class="flex items-center gap-2">
            <div class="w-8 h-8 rounded bg-emerald-500 text-white font-black flex items-center justify-center text-lg">F</div>
            <span class="text-white font-black text-xl tracking-tight">Finesse.</span>
        </div>
        <button type="button" onclick="document.getElementById('bouncer-form').scrollIntoView({ behavior: 'smooth' })" class="text-xs font-bold text-white bg-white/10 hover:bg-white/20 border border-white/10 px-5 py-2.5 rounded-full backdrop-blur-md transition-all">
            Secure Seat
        </button>
    </div>

    <section id="spotlight-hero" class="relative min-h-[100vh] lg:min-h-[850px] flex items-center bg-[#010204] overflow-hidden selection:bg-emerald-500/30">
  
      <div class="absolute inset-0 z-0 pointer-events-none">
        <div class="absolute top-0 left-0 w-full h-full bg-[radial-gradient(circle_at_30%_50%,rgba(16,185,129,0.03)_0%,transparent_60%)]"></div>
      </div>

      <div class="relative z-20 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 w-full">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 lg:gap-20 items-center">
          
          <div class="lg:col-span-6 relative z-30 flex flex-col items-start text-left py-20 lg:py-0 pointer-events-auto">
            <div class="flex items-center gap-4 mb-8">
                <div class="h-[1px] w-12 bg-emerald-500/50"></div>
                <span class="text-emerald-400 text-[10px] font-black uppercase tracking-[0.5em]">The Finesse Official Standard</span>
            </div>
            
            <h1 class="text-6xl sm:text-7xl lg:text-[7.5rem] font-extralight text-white tracking-tighter leading-[0.9] mb-10">
              Clarity.<br/>
              <span class="font-black italic text-transparent bg-clip-text bg-gradient-to-r from-emerald-400 via-emerald-200 to-teal-500">Authority.</span>
            </h1>
            
            <p class="text-slate-300 text-lg lg:text-xl font-light leading-relaxed max-w-md mb-12" id="hero-description">
              We decode the complex transition of elite medical profiles into Tier-A institutions with absolute transparency and legality.<br/>
              <span class="text-emerald-400/80 font-serif italic mt-4 block text-sm">Strictly Institutional: ₹1.2 Cr+ Outlay Only</span>
            </p>

            <div class="flex gap-10 border-b border-white/5 pb-5 mb-12 relative w-full opacity-0 animate-fade-in-up" style="animation-delay: 0.2s;">
               <button id="btn-target-india" class="group relative py-2 text-emerald-400 text-[10px] font-black uppercase tracking-[0.4em] transition-all">
                 Target: India
                 <div id="line-india" class="absolute bottom-[-21px] left-0 w-full h-[2px] bg-emerald-500 shadow-[0_0_15px_rgba(16,185,129,0.5)]"></div>
               </button>
               <button id="btn-fallback-abroad" class="group relative py-2 text-slate-600 hover:text-white text-[10px] font-black uppercase tracking-[0.4em] transition-all">
                 Plan B: Global
                 <div id="line-abroad" class="absolute bottom-[-21px] left-0 w-0 h-[2px] bg-amber-500"></div>
               </button>
            </div>

            <button onclick="document.getElementById('bouncer-form').scrollIntoView({ behavior: 'smooth' })" class="group relative px-14 py-5 border border-white/20 rounded-full text-white text-[10px] font-black uppercase tracking-[0.4em] hover:bg-emerald-500 hover:border-emerald-500 hover:shadow-[0_10px_30px_rgba(16,185,129,0.3)] transition-all duration-500 opacity-0 animate-fade-in-up" style="animation-delay: 0.3s;">
                Initiate Verification
            </button>
          </div>

          <div id="spotlight-zone" class="lg:col-span-6 relative w-full h-[500px] lg:h-[750px] flex items-center justify-center cursor-crosshair overflow-hidden group select-none">
              
              <div class="absolute inset-0 flex flex-wrap content-center justify-center gap-x-6 gap-y-4 text-center opacity-40">
                  <span class="text-slate-800 text-4xl lg:text-6xl font-black uppercase tracking-tighter">100% Direct</span>
                  <span class="text-slate-800 text-3xl lg:text-5xl font-black uppercase tracking-tighter">Zero Agents</span>
                  <span class="text-slate-800 text-5xl lg:text-7xl font-black uppercase tracking-tighter italic">Audited</span>
                  <span class="text-slate-800 text-4xl lg:text-5xl font-black uppercase tracking-tighter">NRI Quota</span>
                  <span class="text-slate-800 text-5xl lg:text-6xl font-black uppercase tracking-tighter">Legality</span>
                  <span class="text-slate-800 text-3xl lg:text-5xl font-black uppercase tracking-tighter italic">NMC Approved</span>
                  <span class="text-slate-800 text-6xl lg:text-8xl font-black uppercase tracking-tighter">Tier-A</span>
                  <span class="text-slate-800 text-4xl lg:text-5xl font-black uppercase tracking-tighter">Zero Advance</span>
                  <span class="text-slate-800 text-5xl lg:text-6xl font-black uppercase tracking-tighter italic">Verified</span>
              </div>

              <div id="spotlight-mask" class="absolute inset-0 flex flex-wrap content-center justify-center gap-x-6 gap-y-4 text-center transition-opacity duration-700 opacity-0 lg:group-hover:opacity-100">
                  <span class="text-transparent bg-clip-text bg-gradient-to-r from-emerald-400 to-teal-200 text-4xl lg:text-6xl font-black uppercase tracking-tighter drop-shadow-[0_0_15px_rgba(16,185,129,0.5)]">100% Direct</span>
                  <span class="text-white text-3xl lg:text-5xl font-black uppercase tracking-tighter drop-shadow-[0_0_10px_rgba(255,255,255,0.8)]">Zero Agents</span>
                  <span class="text-transparent bg-clip-text bg-gradient-to-r from-emerald-400 to-teal-200 text-5xl lg:text-7xl font-black uppercase tracking-tighter italic drop-shadow-[0_0_15px_rgba(16,185,129,0.5)]">Audited</span>
                  <span class="text-white text-4xl lg:text-5xl font-black uppercase tracking-tighter drop-shadow-[0_0_10px_rgba(255,255,255,0.8)]">NRI Quota</span>
                  <span class="text-transparent bg-clip-text bg-gradient-to-r from-emerald-400 to-teal-200 text-5xl lg:text-6xl font-black uppercase tracking-tighter drop-shadow-[0_0_15px_rgba(16,185,129,0.5)]">Legality</span>
                  <span class="text-amber-400 text-3xl lg:text-5xl font-black uppercase tracking-tighter italic drop-shadow-[0_0_15px_rgba(245,158,11,0.5)]">NMC Approved</span>
                  <span class="text-white text-6xl lg:text-8xl font-black uppercase tracking-tighter drop-shadow-[0_0_10px_rgba(255,255,255,0.8)]">Tier-A</span>
                  <span class="text-transparent bg-clip-text bg-gradient-to-r from-emerald-400 to-teal-200 text-4xl lg:text-5xl font-black uppercase tracking-tighter drop-shadow-[0_0_15px_rgba(16,185,129,0.5)]">Zero Advance</span>
                  <span class="text-white text-5xl lg:text-6xl font-black uppercase tracking-tighter italic drop-shadow-[0_0_10px_rgba(255,255,255,0.8)]">Verified</span>
              </div>
          </div>
          
        </div>
      </div>
    </section>

    <section id="bouncer-form" class="relative py-16 lg:py-24 bg-[#FDFDFD] border-t border-slate-200 overflow-hidden">
      <div class="absolute inset-0 pointer-events-none flex z-0">
        <div class="w-full lg:w-[45%] bg-[#F8F9FA] border-r border-slate-200 h-full relative overflow-hidden">
            <div class="absolute top-[-10%] left-[-10%] w-[500px] h-[500px] bg-amber-500/5 rounded-full blur-[100px] animate-pulse-slow"></div>
            <div class="absolute inset-0 opacity-[0.03] bg-[url('data:image/svg+xml;base64,PHN2ZyB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciIHdpZHRoPSI0IiBoZWlnaHQ9IjQiPgoJPHJlY3Qgd2lkdGg9IjQiIGhlaWdodD0iNCIgZmlsbD0iIzAwMCIgZmlsbC1vcGFjaXR5PSIwLjA1Ii8+Cjwvc3ZnPg==')]"></div>
        </div>
        <div class="hidden lg:block lg:w-[55%] bg-[#FDFDFD] h-full"></div>
      </div>

      <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 w-full">
        <div class="flex flex-col lg:flex-row items-center gap-12 lg:gap-16 xl:gap-24">
            
            <div class="w-full lg:w-[45%] flex flex-col justify-center py-8 lg:py-0 relative">
                <div class="inline-flex items-center gap-2.5 px-3 py-1.5 rounded-md bg-emerald-50 border border-emerald-100 mb-8 max-w-fit">
                    <span class="relative flex h-2 w-2">
                      <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
                      <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
                    </span>
                    <span class="text-emerald-700 text-[9px] font-black uppercase tracking-[0.2em]">Finesse Legal Desk</span>
                </div>
                <h2 class="text-4xl lg:text-5xl font-black text-slate-900 mb-5 leading-[1.1] tracking-tight">
                    The Gold Standard of <br/> 
                    <span class="text-transparent bg-clip-text bg-gradient-to-r from-amber-500 to-amber-700">Medical Admissions.</span>
                </h2>
                <p class="text-slate-500 text-sm lg:text-base font-medium leading-relaxed mb-12 lg:pr-8">
                    We replace the chaos of backdoor agents with a structured, 100% legally audited admission strategy.
                </p>

                <div class="relative w-full max-w-[360px] group perspective-1000">
                    <div class="absolute inset-0 bg-slate-200/60 rounded-3xl transform -rotate-2 translate-x-2 translate-y-3 blur-[3px] transition-all duration-700 group-hover:rotate-0 group-hover:translate-x-1 group-hover:translate-y-4"></div>
                    <div class="relative bg-white/95 backdrop-blur-xl border border-slate-100 rounded-3xl p-7 shadow-xl transform transition-all duration-700 group-hover:-translate-y-2 animate-[float_6s_ease-in-out_infinite]">
                        <div class="flex justify-between items-start mb-5">
                            <div class="w-10 h-10 rounded-xl bg-amber-50 border border-amber-100 flex items-center justify-center">
                                <svg aria-hidden="true" class="w-5 h-5 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
                            </div>
                            <div class="text-right">
                                <span class="text-[8px] font-black text-slate-400 uppercase tracking-widest block mb-0.5">Status</span>
                                <span class="inline-flex items-center gap-1 text-emerald-600 text-[9px] font-bold bg-emerald-50 px-2 py-0.5 rounded border border-emerald-100">
                                    <svg aria-hidden="true" class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg> Verified
                                </span>
                            </div>
                        </div>
                        <p class="font-black text-slate-900 text-lg mb-1 tracking-tight">Zero-Risk Financial Policy</p>
                        <p class="text-slate-500 text-[11px] font-medium mb-5">Our commitment to transparency.</p>
                        <div class="space-y-2.5 bg-slate-50 p-3.5 rounded-lg border border-slate-100">
                            <div class="flex justify-between items-center text-xs">
                                <span class="text-slate-500 font-medium">Agency Cash Advance</span>
                                <span class="font-black text-emerald-600">₹0.00</span>
                            </div>
                            <div class="w-full h-px border-dashed border-b border-slate-200"></div>
                            <div class="flex justify-between items-center text-xs">
                                <span class="text-slate-500 font-medium">Tuition Payment</span>
                                <span class="font-black text-slate-900">100% Direct</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="w-full lg:w-[55%] flex flex-col justify-center">
                <div class="w-full bg-white rounded-[2rem] p-6 sm:p-10 border border-slate-100 shadow-[0_20px_60px_-15px_rgba(0,0,0,0.06)] relative overflow-hidden">
                    
                    <div class="flex gap-2 mb-8">
                        <div id="split-dot-1" class="h-1.5 flex-grow bg-slate-900 rounded-full transition-colors duration-500"></div>
                        <div id="split-dot-2" class="h-1.5 flex-grow bg-slate-100 rounded-full transition-colors duration-500"></div>
                        <div id="split-dot-3" class="h-1.5 flex-grow bg-slate-100 rounded-full transition-colors duration-500"></div>
                    </div>

                    <div class="grid relative min-h-[360px]">
                        
                        <div id="step-course" class="step-container step-active">
                            <span class="text-slate-400 font-bold text-[10px] uppercase tracking-[0.2em] mb-2 block">Step 01</span>
                            <h3 class="text-2xl sm:text-3xl font-black text-slate-900 mb-6 tracking-tight">Select Targeted Course</h3>
                            <div class="grid gap-3">
                                <button type="button" class="course-btn group flex items-center w-full p-4 rounded-xl border-2 border-slate-100 bg-white hover:bg-slate-50 hover:border-amber-500 transition-all shadow-sm text-left" data-val="MBBS">
                                    <div class="w-4 h-4 rounded-full border-2 border-slate-300 group-hover:border-amber-500 mr-4 flex items-center justify-center transition-colors"></div>
                                    <div>
                                        <div class="text-slate-800 font-bold text-base mb-0.5">MBBS</div>
                                        <div class="text-slate-400 text-[9px] uppercase tracking-widest font-bold">Undergraduate</div>
                                    </div>
                                </button>
                                <button type="button" class="course-btn group flex items-center w-full p-4 rounded-xl border-2 border-slate-100 bg-white hover:bg-slate-50 hover:border-amber-500 transition-all shadow-sm text-left" data-val="BDS">
                                    <div class="w-4 h-4 rounded-full border-2 border-slate-300 group-hover:border-amber-500 mr-4 flex items-center justify-center transition-colors"></div>
                                    <div>
                                        <div class="text-slate-800 font-bold text-base mb-0.5">BDS</div>
                                        <div class="text-slate-400 text-[9px] uppercase tracking-widest font-bold">Dental</div>
                                    </div>
                                </button>
                                <button type="button" class="course-btn group flex items-center w-full p-4 rounded-xl border-2 border-amber-100 bg-amber-50 hover:bg-amber-100 hover:border-amber-500 transition-all shadow-sm text-left" data-val="MD">
                                    <div class="w-4 h-4 rounded-full border-2 border-slate-300 group-hover:border-amber-500 mr-4 flex items-center justify-center transition-colors"></div>
                                    <div>
                                        <div class="text-slate-800 font-bold text-base mb-0.5">MD / MS</div>
                                        <div class="text-slate-400 text-[9px] uppercase tracking-widest font-bold">Postgraduate</div>
                                    </div>
                                </button>
                            </div>
                        </div>

                        <div id="step-ug-score" class="step-container step-hide-right">
                            <div class="flex items-center justify-between mb-2">
                                <span class="text-slate-400 font-bold text-[10px] uppercase tracking-[0.2em] block">Step 02</span>
                                <button type="button" class="back-btn flex items-center gap-1.5 text-slate-400 hover:text-slate-800 transition-colors text-[9px] font-bold uppercase tracking-widest" data-back="step-course" data-dot="1">
                                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 19l-7-7 7-7"></path></svg> Back
                                </button>
                            </div>
                            <h3 class="text-2xl sm:text-3xl font-black text-slate-900 mb-6 tracking-tight">Expected NEET 2026 Score?</h3>
                            <div class="grid gap-3">
                                <button type="button" class="ug-score-btn group flex items-center w-full p-4 rounded-xl border-2 border-slate-100 bg-white hover:bg-slate-50 hover:border-amber-500 transition-all shadow-sm text-left" data-val="Just Qualified">
                                    <div class="w-4 h-4 rounded-full border-2 border-slate-300 group-hover:border-amber-500 mr-4 flex items-center justify-center transition-colors"></div>
                                    <div>
                                        <div class="text-slate-800 font-bold text-base mb-0.5">Just Qualified</div>
                                        <div class="text-slate-400 text-[9px] uppercase tracking-widest font-bold">Borderline Score</div>
                                    </div>
                                </button>
                                <button type="button" class="ug-score-btn group flex items-center w-full p-4 rounded-xl border-2 border-emerald-100 bg-emerald-50 hover:border-emerald-500 transition-all shadow-sm text-left" data-val="Just Qualified - 450">
                                    <div class="w-4 h-4 rounded-full border-2 border-slate-300 group-hover:border-emerald-500 mr-4 flex items-center justify-center transition-colors"></div>
                                    <div>
                                        <div class="text-slate-800 font-bold text-base mb-0.5">Just Qualified - 450</div>
                                        <div class="text-emerald-600 text-[9px] uppercase tracking-widest font-bold">Target Merit</div>
                                    </div>
                                </button>
                                <button type="button" class="ug-score-btn group flex items-center w-full p-4 rounded-xl border-2 border-slate-100 bg-white hover:bg-slate-50 hover:border-amber-500 transition-all shadow-sm text-left" data-val="450+">
                                    <div class="w-4 h-4 rounded-full border-2 border-slate-300 group-hover:border-amber-500 mr-4 flex items-center justify-center transition-colors"></div>
                                    <div>
                                        <div class="text-slate-800 font-bold text-base mb-0.5">450+</div>
                                        <div class="text-slate-400 text-[9px] uppercase tracking-widest font-bold">High Score</div>
                                    </div>
                                </button>
                            </div>
                        </div>

                        <div id="step-ug-category" class="step-container step-hide-right">
                            <div class="flex items-center justify-between mb-2">
                                <span class="text-slate-400 font-bold text-[10px] uppercase tracking-[0.2em] block">Step 03</span>
                                <button type="button" class="back-btn flex items-center gap-1.5 text-slate-400 hover:text-slate-800 transition-colors text-[9px] font-bold uppercase tracking-widest" data-back="dynamic-category" data-dot="2">
                                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 19l-7-7 7-7"></path></svg> Back
                                </button>
                            </div>
                            <h3 class="text-2xl sm:text-3xl font-black text-slate-900 mb-6 tracking-tight">Select Category</h3>
                            <div class="grid gap-3">
                                <button type="button" class="cat-btn group flex items-center w-full p-5 rounded-xl border-2 border-slate-100 bg-white hover:bg-slate-50 hover:border-amber-500 transition-all shadow-sm text-left" data-val="Open">
                                    <div class="w-4 h-4 rounded-full border-2 border-slate-300 group-hover:border-amber-500 mr-4 flex items-center justify-center transition-colors"></div>
                                    <div class="text-slate-800 font-bold text-lg">Open (General)</div>
                                </button>
                                <button type="button" class="cat-btn group flex items-center w-full p-5 rounded-xl border-2 border-slate-100 bg-white hover:bg-slate-50 hover:border-amber-500 transition-all shadow-sm text-left" data-val="Reserved">
                                    <div class="w-4 h-4 rounded-full border-2 border-slate-300 group-hover:border-amber-500 mr-4 flex items-center justify-center transition-colors"></div>
                                    <div>
                                        <div class="text-slate-800 font-bold text-lg mb-0.5">Reserved</div>
                                        <div class="text-slate-400 text-[9px] uppercase tracking-widest font-bold">NRI / OBC / SC / ST</div>
                                    </div>
                                </button>
                            </div>
                        </div>

                        <div id="step-ug-pathway" class="step-container step-hide-right">
                            <div class="flex items-center justify-between mb-2">
                                <span class="text-slate-400 font-bold text-[10px] uppercase tracking-[0.2em] block">Step 03</span>
                                <button type="button" class="back-btn flex items-center gap-1.5 text-slate-400 hover:text-slate-800 transition-colors text-[9px] font-bold uppercase tracking-widest" data-back="step-ug-score" data-dot="2">
                                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 19l-7-7 7-7"></path></svg> Back
                                </button>
                            </div>
                            <h3 class="text-2xl sm:text-3xl font-black text-slate-900 mb-6 tracking-tight">Select Targeted Pathway</h3>
                            <div class="grid gap-3">
                                <button type="button" class="pathway-btn group flex items-center w-full p-4 rounded-xl border-2 border-slate-100 bg-white hover:bg-slate-50 hover:border-amber-500 transition-all shadow-sm text-left" data-val="India">
                                    <div class="w-4 h-4 rounded-full border-2 border-slate-300 group-hover:border-amber-500 mr-4 flex items-center justify-center transition-colors"></div>
                                    <div>
                                        <div class="text-slate-800 font-bold text-base mb-0.5">Tier-A Indian Institutes</div>
                                        <div class="text-slate-400 text-[9px] uppercase tracking-widest font-bold">Domestic Management Quota</div>
                                    </div>
                                </button>
                                <button type="button" class="pathway-btn group flex items-center w-full p-4 rounded-xl border-2 border-slate-100 bg-white hover:bg-slate-50 hover:border-amber-500 transition-all shadow-sm text-left" data-val="Abroad">
                                    <div class="w-4 h-4 rounded-full border-2 border-slate-300 group-hover:border-amber-500 mr-4 flex items-center justify-center transition-colors"></div>
                                    <div>
