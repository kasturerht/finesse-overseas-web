<style is:global>


/* 🚨 KILL THE LEAKS: Hide Global Header & Footer on this Landing Page ONLY 🚨 */
  header, 
  footer, 
  .navbar, 
  #navbar, 
  .site-header, 
  .site-footer {
      display: none !important;
  }


  /* Base Animations */
  @keyframes float {
    0%, 100% { transform: translateY(0px); }
    50% { transform: translateY(-12px); }
  }
  .animate-pulse-slow {
    animation: pulse 6s cubic-bezier(0.4, 0, 0.6, 1) infinite;
  }
  
  /* Fixed Marquee for Seamless Loop */
  @keyframes marquee {
    0% { transform: translateX(0%); }
    100% { transform: translateX(-100%); }
  }
  .animate-marquee {
    animation: marquee 25s linear infinite;
  }

  /* Form iOS Slide Physics */
  .step-container {
      grid-area: 1 / 1;
      width: 100%;
      display: flex;
      flex-direction: column;
      transition: all 0.6s cubic-bezier(0.25, 1, 0.15, 1); 
  }
  .step-active {
      opacity: 1;
      transform: translateX(0);
      pointer-events: auto;
      z-index: 10;
  }
  .step-hide-left {
      opacity: 0;
      transform: translateX(-40px);
      pointer-events: none;
      z-index: 0;
  }
  .step-hide-right {
      opacity: 0;
      transform: translateX(40px);
      pointer-events: none;
      z-index: 0;
  }

  /* 3D & Mobile Fallbacks */
  .perspective-1000 { perspective: 1000px; }
  .perspective-\[1500px\] { perspective: 1500px; }
  .transform-style-3d { transform-style: preserve-3d; }
  
  @media (min-width: 768px) {
      .translate-z-\[40px\] { transform: translateZ(40px); }
  }
  @media (max-width: 767px) {
      /* Gives mobile cards a permanent subtle premium glow since they can't hover */
      .mobile-glow {
          box-shadow: inset 0 0 20px rgba(255,255,255,0.02);
          border-color: rgba(255,255,255,0.1);
      }
  }
</style>

<script>
    const initMasterLogic = () => {
        
        /* --- 1. FORM SLIDING & SUBMIT LOGIC --- */
        const s1 = document.getElementById('split-step-1');
        const s2 = document.getElementById('split-step-2');
        const s3 = document.getElementById('split-step-3');
        const sSuccess = document.getElementById('split-step-success'); // New Success Screen
        const sReject = document.getElementById('split-step-reject');
        
        const d1 = document.getElementById('split-dot-1');
        const d2 = document.getElementById('split-dot-2');

        const switchStep = (current, next, direction, updateDots) => {
            if(!current || !next) return;
            current.classList.remove('step-active');
            
            if(direction === 'forward') {
                current.classList.add('step-hide-left');
                next.classList.remove('step-hide-left');
                next.classList.add('step-hide-right');
            } else {
                current.classList.add('step-hide-right');
                next.classList.remove('step-hide-right');
                next.classList.add('step-hide-left');
            }

            void next.offsetWidth; // Force Reflow
            next.classList.remove('step-hide-left', 'step-hide-right');
            next.classList.add('step-active');
            if(updateDots) updateDots();
        };

        if (s1) {
            s1.querySelectorAll('.split-option').forEach(btn => {
                btn.addEventListener('click', () => {
                    switchStep(s1, s2, 'forward', () => d2.classList.replace('bg-slate-100', 'bg-slate-900'));
                });
            });

            s2.querySelectorAll('.split-option').forEach(btn => {
                btn.addEventListener('click', (e) => {
                    const budget = e.currentTarget.getAttribute('data-budget');
                    if (budget === 'high') {
                        switchStep(s2, s3, 'forward', () => {
                            d1.classList.replace('bg-slate-900', 'bg-emerald-500');
                            d2.classList.replace('bg-slate-900', 'bg-emerald-500');
                        });
                    } else {
                        switchStep(s2, sReject, 'forward', () => {
                            d1.classList.replace('bg-slate-900', 'bg-blue-500');
                            d2.classList.replace('bg-slate-900', 'bg-blue-500');
                        });
                    }
                });
            });

            document.querySelectorAll('.back-btn').forEach(btn => {
                btn.addEventListener('click', (e) => {
                    const target = e.currentTarget.getAttribute('data-back');
                    if (target === 'step-1') {
                        switchStep(s2, s1, 'backward', () => d2.classList.replace('bg-slate-900', 'bg-slate-100'));
                    } else if (target === 'step-2') {
                        const currentActive = s3.classList.contains('step-active') ? s3 : sReject;
                        switchStep(currentActive, s2, 'backward', () => {
                            d1.className = 'h-1.5 flex-grow bg-slate-900 rounded-full transition-colors duration-500';
                            d2.className = 'h-1.5 flex-grow bg-slate-900 rounded-full transition-colors duration-500';
                        });
                    }
                });
            });

            // 🚨 THE FORM FIX: Prevent Refresh & Show Success Screen 🚨
            // a23dc8d7-5a81-4be3-b711-32a0d054778b
            // 🚨 THE REAL DATA CAPTURE & TRACKING ENGINE 🚨
            const leadForm = document.getElementById('lead-form');
            if(leadForm) {
                leadForm.addEventListener('submit', async (e) => {
                    e.preventDefault(); 
                    
                    const submitBtn = leadForm.querySelector('button[type="submit"]');
                    const originalText = submitBtn.innerHTML;
                    submitBtn.innerHTML = 'Securing Protocol... <span class="animate-pulse">⏳</span>';
                    
                    // 1. Prepare Data
                    const formData = new FormData(leadForm);
                    
                    // 🔑 WEB3FORMS ACCESS KEY (इथे तुझी मिळालेली Key टाक)
                    formData.append("access_key", "YOUR_ACCESS_KEY_HERE");
                    
                    // (Optional) ईमेलचा Subject लाईन कस्टमाईज करण्यासाठी
                    formData.append("subject", "🚨 HIGH TICKET LEAD: Tier-A MBBS Landing Page");

                    try {
                        // 2. Send Data to Email
                        const response = await fetch('https://api.web3forms.com/submit', {
                            method: 'POST',
                            body: formData
                        });
                        
                        const result = await response.json();
                        
                        if (result.success) {
                            // 3. Show Success Screen (UI)
                            switchStep(s3, sSuccess, 'forward'); 
                            
                            // 🎯 4. FIRE GTM & META PIXEL EVENT (The Marketing Magic)
                            // हा कोड Facebook आणि Google Ads ला सांगेल की Lead कन्व्हर्ट झाली आहे
                            window.dataLayer = window.dataLayer || [];
                            window.dataLayer.push({
                                'event': 'lead_submitted',
                                'lead_type': 'tier_a_mbbs_hni',
                                'form_location': 'split_dashboard'
                            });
                            
                            // जर डायरेक्ट Meta Pixel लावला असेल तर:
                            if(typeof fbq === 'function') {
                                fbq('track', 'Lead', {
                                    content_name: 'Tier-A MBBS',
                                    currency: 'INR',
                                    value: 12000000 // 1.2 Cr (Optional for ROAS tracking)
                                });
                            }
                            
                        } else {
                            alert("System busy. Please try again.");
                            submitBtn.innerHTML = originalText;
                        }
                    } catch (error) {
                        alert("Network error. Please check your connection.");
                        submitBtn.innerHTML = originalText;
                    }
                });
            }
        }

        /* --- 2. SPOTLIGHT MATRIX LOGIC (Desktop Only) --- */
        if(window.matchMedia("(min-width: 768px)").matches) {
            const cards = document.querySelectorAll('.spotlight-card');
            const trapCards = document.querySelectorAll('.trap-card');
            const finesseVault = document.getElementById('finesse-vault');

            cards.forEach(card => {
                card.addEventListener('mousemove', e => {
                    const rect = card.getBoundingClientRect();
                    card.style.setProperty('--mouse-x', `${e.clientX - rect.left}px`);
                    card.style.setProperty('--mouse-y', `${e.clientY - rect.top}px`);
                });
            });

            if(finesseVault) {
                finesseVault.addEventListener('mouseenter', () => {
                    trapCards.forEach(trap => {
                        trap.style.opacity = '0.3';
                        trap.style.filter = 'grayscale(100%) blur(2px)';
                    });
                });
                finesseVault.addEventListener('mouseleave', () => {
                    trapCards.forEach(trap => {
                        trap.style.opacity = '1';
                        trap.style.filter = 'grayscale(0%) blur(0px)';
                    });
                });
            }
        }

        /* --- 3. 3D TILT CARDS LOGIC (Desktop Only) --- */
        if(window.matchMedia("(min-width: 768px)").matches) {
            const tiltCards = document.querySelectorAll('.tilt-card');
            tiltCards.forEach(card => {
                const glare = card.querySelector('.glare-layer');
                card.addEventListener('mousemove', (e) => {
                    const rect = card.getBoundingClientRect();
                    const x = e.clientX - rect.left; 
                    const y = e.clientY - rect.top;  
                    const rotateX = ((y - rect.height / 2) / (rect.height / 2)) * -10;
                    const rotateY = ((x - rect.width / 2) / (rect.width / 2)) * 10;
                    card.style.transform = `rotateX(${rotateX}deg) rotateY(${rotateY}deg)`;
                    if(glare) glare.style.background = `radial-gradient(circle at ${x}px ${y}px, rgba(255,255,255,0.08), transparent 50%)`;
                });
                card.addEventListener('mouseleave', () => {
                    card.style.transform = `rotateX(0deg) rotateY(0deg)`;
                    if(glare) glare.style.background = `radial-gradient(circle at 50% 50%, rgba(255,255,255,0), transparent 50%)`;
                });
            });

            const magneticBtn = document.getElementById('magnetic-btn');
            if(magneticBtn) {
                magneticBtn.addEventListener('mousemove', (e) => {
                    const rect = magneticBtn.getBoundingClientRect();
                    const x = e.clientX - rect.left - rect.width / 2;
                    const y = e.clientY - rect.top - rect.height / 2;
                    magneticBtn.style.transform = `translate(${x * 0.2}px, ${y * 0.2}px)`;
                });
                magneticBtn.addEventListener('mouseleave', () => magneticBtn.style.transform = `translate(0px, 0px)`);
            }
        }
    }

    initMasterLogic();
    document.addEventListener('astro:page-load', initMasterLogic);
</script>