---
// src/pages/tier-a-mbbs-india.astro
import Layout from '../layouts/Layout.astro';

const seoTitle = "Tier-A Private MBBS Admissions | Official Management Quota | Finesse Overseas";
const seoDescription = "Secure your child's MBBS seat in India's top Tier-A private medical colleges. 100% transparent process. Pay fees directly to the institution. Zero hidden charges.";
---

<Layout title={seoTitle} description={seoDescription}>
  <main class="flex-grow bg-[#03070E] selection:bg-amber-500/30 selection:text-amber-200">

    <div class="absolute top-0 left-0 w-full z-50 px-6 py-6 lg:px-12 flex justify-between items-center pointer-events-auto">
        <div class="flex items-center gap-2">
            <div class="w-8 h-8 rounded bg-emerald-500 text-white font-black flex items-center justify-center text-lg">F</div>
            <span class="text-white font-black text-xl tracking-tight">Finesse.</span>
        </div>
        
        <button onclick="document.getElementById('bouncer-form').scrollIntoView({ behavior: 'smooth' })" class="text-xs font-bold text-white bg-white/10 hover:bg-white/20 border border-white/10 px-5 py-2.5 rounded-full backdrop-blur-md transition-all">
            Secure Seat
        </button>
    </div>

    <section class="relative min-h-[600px] flex flex-col justify-center pt-28 pb-16 lg:pt-32 lg:pb-20 overflow-hidden border-b border-white/5">
      
      <div class="absolute inset-0 z-0 pointer-events-none">
        <img 
          src="https://images.unsplash.com/photo-1562774053-701939374585?auto=format,compress&fit=crop&q=60&w=1920" 
          srcset="https://images.unsplash.com/photo-1562774053-701939374585?auto=format,compress&fit=crop&q=50&w=800 800w,
                  https://images.unsplash.com/photo-1562774053-701939374585?auto=format,compress&fit=crop&q=60&w=1920 1920w"
          sizes="100vw"
          alt="Premium Medical Campus" 
          loading="eager"
          fetchpriority="high"
          decoding="sync"
          class="w-full h-full object-cover opacity-[0.06] mix-blend-luminosity grayscale-[60%]"
        />
        <div class="absolute inset-0 opacity-[0.03] bg-[url('data:image/svg+xml;base64,PHN2ZyB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciIHdpZHRoPSI0IiBoZWlnaHQ9IjQiPgoJPHJlY3Qgd2lkdGg9IjQiIGhlaWdodD0iNCIgZmlsbD0iI2ZmZiIgZmlsbC1vcGFjaXR5PSIwLjA1Ii8+Cjwvc3ZnPg==')]"></div>
        <div class="absolute inset-0 bg-gradient-to-r from-[#03070E] via-[#03070E]/95 to-[#03070E]/70"></div>
        <div class="absolute top-0 left-[-10%] w-[500px] h-[500px] bg-amber-500/10 rounded-full blur-[130px]"></div>
        <div class="absolute bottom-[-20%] right-[-10%] w-[600px] h-[600px] bg-emerald-500/5 rounded-full blur-[150px]"></div>
      </div>

      <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 w-full">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-16 items-center">
          
          <div class="lg:col-span-7 flex flex-col items-start text-left">
            <div class="inline-flex items-center gap-2.5 px-3 py-1.5 rounded-full border border-amber-500/20 bg-amber-500/5 backdrop-blur-xl mb-6 shadow-[0_4px_20px_rgba(245,158,11,0.05)]">
              <span class="relative flex h-1.5 w-1.5">
                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-amber-400 opacity-75"></span>
                <span class="relative inline-flex rounded-full h-1.5 w-1.5 bg-amber-500"></span>
              </span>
              <span class="text-amber-200/90 text-[10px] sm:text-[11px] font-bold uppercase tracking-[0.2em]">Official Management & NRI Quota</span>
            </div>

            <h1 class="text-4xl sm:text-5xl lg:text-[3.5rem] xl:text-[4.2rem] font-black text-white tracking-tighter leading-[1.05] mb-6">
              Secure Your Child's Medical Future in <br class="hidden xl:block" />
              <span class="text-transparent bg-clip-text bg-gradient-to-r from-amber-100 via-amber-300 to-yellow-600 drop-shadow-sm pr-2 pb-1 inline-block">India's Tier-A Institutions.</span>
            </h1>

            <p class="text-slate-400/90 text-base lg:text-lg font-medium leading-relaxed max-w-2xl mb-10">
              Bypass unverified agents. We navigate the complex private MBBS admissions strictly through official channels. <strong class="text-white font-semibold">Strictly for budgets of ₹1.2 Cr+.</strong>
            </p>

            <div class="flex flex-col sm:flex-row items-center gap-5 w-full sm:w-auto mb-10">
              <button onclick="document.getElementById('bouncer-form').scrollIntoView({ behavior: 'smooth' })" class="group relative inline-flex justify-center items-center gap-3 bg-gradient-to-b from-amber-400 to-amber-600 border border-amber-300/40 text-[#050B14] px-8 py-3.5 lg:py-4 rounded-xl text-base lg:text-lg font-black transition-all duration-300 shadow-[0_0_30px_rgba(245,158,11,0.15),inset_0_2px_0_rgba(255,255,255,0.3)] hover:shadow-[0_0_40px_rgba(245,158,11,0.3),inset_0_2px_0_rgba(255,255,255,0.5)] active:scale-[0.98] w-full sm:w-auto overflow-hidden">
                <span class="relative z-10 tracking-wide">Check Profile Eligibility</span>
                <svg aria-hidden="true" class="w-5 h-5 relative z-10 transform group-hover:translate-x-1 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
              </button>
              
              <div class="flex items-center gap-3 opacity-90 hover:opacity-100 transition-opacity cursor-default">
                <div class="flex -space-x-2">
                  <img class="w-8 h-8 rounded-full border-2 border-[#03070E] object-cover grayscale-[20%]" src="https://images.unsplash.com/photo-1559839734-2b71ea197ec2?auto=format&fit=crop&q=80&w=100" alt="HNI Parent" />
                  <img class="w-8 h-8 rounded-full border-2 border-[#03070E] object-cover grayscale-[20%]" src="https://images.unsplash.com/photo-1537368910025-700350fe46c7?auto=format&fit=crop&q=80&w=100" alt="Doctor Parent" />
                  <div class="w-8 h-8 rounded-full border-2 border-[#03070E] bg-slate-800/80 backdrop-blur-md flex items-center justify-center text-[9px] font-bold text-slate-300">+50</div>
                </div>
              </div>
            </div>
          </div>

          <div class="lg:col-span-5 relative w-full lg:h-[450px] flex items-center justify-center lg:justify-end">
            <div class="relative z-20 w-full max-w-sm bg-gradient-to-br from-white/[0.03] to-white/[0.01] backdrop-blur-3xl border border-white/5 rounded-[1.5rem] p-7 shadow-[0_20px_40px_-10px_rgba(0,0,0,0.8),inset_0_1px_0_rgba(255,255,255,0.05)] group hover:border-emerald-500/30 transition-colors duration-500">
              <div class="absolute -top-10 -right-10 w-32 h-32 bg-emerald-500/10 rounded-full blur-3xl pointer-events-none group-hover:bg-emerald-500/20 transition-colors duration-500"></div>
              
              <div class="w-12 h-12 rounded-[0.8rem] bg-gradient-to-b from-emerald-400/20 to-emerald-500/10 border border-emerald-400/20 flex items-center justify-center mb-6 shadow-[inset_0_1px_0_rgba(255,255,255,0.1)]">
                <svg aria-hidden="true" class="w-6 h-6 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
              </div>
              
              <h2 class="text-white font-bold text-xl mb-2 tracking-tight">100% Direct Payment</h2>
              <p class="text-slate-300 text-sm font-medium leading-relaxed mb-6">
              We do not touch your tuition fees. Pay directly to the institution's official bank account.
              </p>
              
              <div class="inline-flex items-center gap-2.5 bg-[#03070E]/50 border border-emerald-500/10 px-3.5 py-2 rounded-lg w-full">
                <div class="w-1.5 h-1.5 rounded-full bg-emerald-500 shadow-[0_0_8px_rgba(16,185,129,0.8)]"></div>
                <span class="text-emerald-400/90 text-[10px] font-bold uppercase tracking-[0.15em]">Zero Cash / Advance to Agents</span>
              </div>
            </div>

            <div class="absolute top-0 lg:-top-6 left-0 lg:-left-10 z-30 w-48 sm:w-52 bg-[#03070E]/60 backdrop-blur-2xl border border-white/5 rounded-xl p-4 shadow-[0_15px_30px_rgba(0,0,0,0.5)] animate-[float_6s_ease-in-out_infinite]">
              <div class="flex justify-between items-center mb-3">
                <span class="text-[9px] font-bold text-slate-400/80 uppercase tracking-widest">2026 Intake</span>
                <span class="relative flex h-2 w-2">
                  <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-red-400 opacity-75"></span>
                  <span class="relative inline-flex rounded-full h-2 w-2 bg-red-500"></span>
                </span>
              </div>
              <div class="flex items-baseline gap-2 mb-2">
                <span class="text-2xl font-black text-white leading-none tracking-tighter">07</span>
                <span class="text-[10px] text-slate-400 font-bold uppercase tracking-wide">Spots Left</span>
              </div>
              <div class="w-full h-1 bg-slate-800/50 rounded-full overflow-hidden">
                <div class="w-[65%] h-full bg-gradient-to-r from-red-500 to-amber-500 rounded-full"></div>
              </div>
            </div>

            <div class="absolute -bottom-6 lg:-bottom-8 right-0 lg:-right-4 z-10 w-40 sm:w-48 bg-[#03070E]/60 backdrop-blur-2xl border border-white/5 rounded-xl p-3.5 shadow-[0_15px_30px_rgba(0,0,0,0.5)] animate-[float_8s_ease-in-out_infinite_reverse]">
              <div class="flex items-center gap-3">
                <div class="w-9 h-9 rounded-lg bg-blue-500/10 border border-blue-500/20 flex items-center justify-center shrink-0">
                  <svg aria-hidden="true" class="w-4 h-4 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                </div>
                <div>
                  <p class="text-[8px] font-bold text-slate-500 uppercase tracking-widest mb-0.5">Audited By</p>
                  <p class="text-xs font-bold text-white/90 leading-tight">Finesse Legal</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section id="bouncer-form" class="relative py-16 lg:py-24 bg-[#FDFDFD] border-t border-slate-200 overflow-hidden">
      <div class="absolute inset-0 pointer-events-none flex z-0">
        <div class="w-full lg:w-[45%] bg-[#F8F9FA] border-r border-slate-200 h-full relative overflow-hidden">
            <div class="absolute top-[-10%] left-[-10%] w-[500px] h-[500px] bg-amber-500/5 rounded-full blur-[100px] animate-pulse-slow"></div>
            <div class="absolute inset-0 opacity-[0.03] bg-[url('data:image/svg+xml;base64,PHN2ZyB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciIHdpZHRoPSI0IiBoZWlnaHQ9IjQiPgoJPHJlY3Qgd2lkdGg9IjQiIGhlaWdodD0iNCIgZmlsbD0iIzAwMCIgZmlsbC1vcGFjaXR5PSIwLjA1Ii8+Cjwvc3ZnPg==')]"></div>
        </div>
        <div class="hidden lg:block lg:w-[55%] bg-[#FDFDFD] h-full"></div>
      </div>

      <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 w-full">
        <div class="flex flex-col lg:flex-row items-center gap-12 lg:gap-16 xl:gap-24">
            
            <div class="w-full lg:w-[45%] flex flex-col justify-center py-8 lg:py-0 relative">
                <div class="inline-flex items-center gap-2.5 px-3 py-1.5 rounded-md bg-emerald-50 border border-emerald-100 mb-8 max-w-fit">
                    <span class="relative flex h-2 w-2">
                      <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
                      <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
                    </span>
                    <span class="text-emerald-700 text-[9px] font-black uppercase tracking-[0.2em]">Finesse Legal Desk</span>
                </div>
                <h2 class="text-4xl lg:text-5xl font-black text-slate-900 mb-5 leading-[1.1] tracking-tight">
                    The Gold Standard of <br/> 
                    <span class="text-transparent bg-clip-text bg-gradient-to-r from-amber-500 to-amber-700">Medical Admissions.</span>
                </h2>
                <p class="text-slate-500 text-sm lg:text-base font-medium leading-relaxed mb-12 lg:pr-8">
                    We replace the chaos of backdoor agents with a structured, 100% legally audited admission strategy.
                </p>

                <div class="relative w-full max-w-[360px] group perspective-1000">
                    <div class="absolute inset-0 bg-slate-200/60 rounded-3xl transform -rotate-2 translate-x-2 translate-y-3 blur-[3px] transition-all duration-700 group-hover:rotate-0 group-hover:translate-x-1 group-hover:translate-y-4"></div>
                    <div class="relative bg-white/95 backdrop-blur-xl border border-slate-100 rounded-3xl p-7 shadow-xl transform transition-all duration-700 group-hover:-translate-y-2 animate-[float_6s_ease-in-out_infinite]">
                        <div class="flex justify-between items-start mb-5">
                            <div class="w-10 h-10 rounded-xl bg-amber-50 border border-amber-100 flex items-center justify-center">
                                <svg aria-hidden="true" class="w-5 h-5 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
                            </div>
                            <div class="text-right">
                                <span class="text-[8px] font-black text-slate-400 uppercase tracking-widest block mb-0.5">Status</span>
                                <span class="inline-flex items-center gap-1 text-emerald-600 text-[9px] font-bold bg-emerald-50 px-2 py-0.5 rounded border border-emerald-100">
                                    <svg aria-hidden="true" class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg> Verified
                                </span>
                            </div>
                        </div>
                        <h4 class="font-black text-slate-900 text-lg mb-1 tracking-tight">Zero-Risk Financial Policy</h4>
                        <p class="text-slate-500 text-[11px] font-medium mb-5">Our commitment to transparency.</p>
                        <div class="space-y-2.5 bg-slate-50 p-3.5 rounded-lg border border-slate-100">
                            <div class="flex justify-between items-center text-xs">
                                <span class="text-slate-500 font-medium">Agency Cash Advance</span>
                                <span class="font-black text-emerald-600">₹0.00</span>
                            </div>
                            <div class="w-full h-px border-dashed border-b border-slate-200"></div>
                            <div class="flex justify-between items-center text-xs">
                                <span class="text-slate-500 font-medium">Tuition Payment</span>
                                <span class="font-black text-slate-900">100% Direct</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="w-full lg:w-[55%] flex flex-col justify-center">
                <div class="w-full bg-white rounded-[2rem] p-6 sm:p-10 border border-slate-100 shadow-[0_20px_60px_-15px_rgba(0,0,0,0.06)] relative overflow-hidden">
                    
                    <div class="flex gap-2 mb-8">
                        <div id="split-dot-1" class="h-1.5 flex-grow bg-slate-900 rounded-full transition-colors duration-500"></div>
                        <div id="split-dot-2" class="h-1.5 flex-grow bg-slate-100 rounded-full transition-colors duration-500"></div>
                    </div>

                    <div class="grid relative min-h-[350px]">
                        
                        <div id="split-step-1" class="step-container step-active">
                            <span class="text-slate-400 font-bold text-[10px] uppercase tracking-[0.2em] mb-2 block">Question 01 of 02</span>
                            <h3 class="text-2xl sm:text-3xl font-black text-slate-900 mb-6 tracking-tight">What is the expected <br class="hidden sm:block"/> NEET 2026 score?</h3>
                            <div class="grid gap-3">
                                <button class="split-option group flex items-center w-full p-4 rounded-xl border-2 border-slate-100 bg-white hover:bg-slate-50 hover:border-amber-500 transition-all shadow-sm text-left" data-next="step-2">
                                    <div class="w-4 h-4 rounded-full border-2 border-slate-300 group-hover:border-amber-500 mr-4 flex items-center justify-center transition-colors"></div>
                                    <div>
                                        <div class="text-slate-800 font-bold text-base mb-0.5">Below 200</div>
                                        <div class="text-slate-400 text-[9px] uppercase tracking-widest font-bold">Just Qualified</div>
                                    </div>
                                </button>
                                <button class="split-option group flex items-center w-full p-4 rounded-xl border-2 border-slate-100 bg-white hover:bg-slate-50 hover:border-amber-500 transition-all shadow-sm text-left" data-next="step-2">
                                    <div class="w-4 h-4 rounded-full border-2 border-slate-300 group-hover:border-amber-500 mr-4 flex items-center justify-center transition-colors"></div>
                                    <div>
                                        <div class="text-slate-800 font-bold text-base mb-0.5">200 to 400</div>
                                        <div class="text-slate-400 text-[9px] uppercase tracking-widest font-bold">Average Merit</div>
                                    </div>
                                </button>
                                <button class="split-option group flex items-center w-full p-4 rounded-xl border-2 border-slate-100 bg-white hover:bg-slate-50 hover:border-amber-500 transition-all shadow-sm text-left" data-next="step-2">
                                    <div class="w-4 h-4 rounded-full border-2 border-slate-300 group-hover:border-amber-500 mr-4 flex items-center justify-center transition-colors"></div>
                                    <div>
                                        <div class="text-slate-800 font-bold text-base mb-0.5">400+</div>
                                        <div class="text-slate-400 text-[9px] uppercase tracking-widest font-bold">High Score</div>
                                    </div>
                                </button>
                            </div>
                        </div>

                        <div id="split-step-2" class="step-container step-hide-right">
                            <div class="flex items-center justify-between mb-2">
                                <span class="text-slate-400 font-bold text-[10px] uppercase tracking-[0.2em] block">Question 02 of 02</span>
                                <button class="back-btn flex items-center gap-1.5 text-slate-400 hover:text-slate-800 transition-colors text-[9px] font-bold uppercase tracking-widest" data-back="step-1">
                                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 19l-7-7 7-7"></path></svg> Back
                                </button>
                            </div>
                            <h3 class="text-2xl sm:text-3xl font-black text-slate-900 mb-2 tracking-tight">Planned Investment?</h3>
                            <p class="text-slate-500 mb-6 text-xs sm:text-sm">For the complete Tier-A private MBBS program.</p>
                            <div class="grid gap-4 mt-auto">
                                <button class="split-option group flex items-center w-full p-4 rounded-xl border-2 border-slate-100 bg-white hover:bg-slate-50 transition-all shadow-sm" data-budget="low">
                                    <div class="w-4 h-4 rounded-full border-2 border-slate-300 group-hover:border-slate-500 mr-4 flex items-center justify-center transition-colors"></div>
                                    <div class="text-slate-600 font-bold text-base">Under ₹90 Lakhs</div>
                                </button>
                                <button class="split-option group flex items-center w-full p-5 rounded-xl border-2 border-amber-500 bg-gradient-to-r from-amber-600 to-amber-500 hover:from-amber-500 hover:to-amber-400 transition-all shadow-[0_10px_20px_-10px_rgba(245,158,11,0.6)]" data-budget="high">
                                    <div class="w-5 h-5 rounded-full border-2 border-white/50 mr-4 flex items-center justify-center shadow-inner">
                                        <div class="w-2 h-2 rounded-full bg-white"></div>
                                    </div>
                                    <div class="text-white font-black text-lg sm:text-xl tracking-tight">₹1.2 Cr to ₹1.5 Cr+</div>
                                </button>
                            </div>
                        </div>

                        <div id="split-step-3" class="step-container step-hide-right justify-center">
                            <div class="absolute top-0 right-0 z-20">
                                <button class="back-btn flex items-center gap-1.5 text-slate-400 hover:text-slate-800 transition-colors text-[9px] font-bold uppercase tracking-widest" data-back="step-2">
                                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 19l-7-7 7-7"></path></svg> Edit
                                </button>
                            </div>
                            <div class="mb-6 text-center mt-4">
                                <div class="inline-flex items-center justify-center w-12 h-12 rounded-full bg-emerald-100 border-4 border-white shadow-sm mb-3">
                                    <svg aria-hidden="true" class="w-5 h-5 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
                                </div>
                                <h3 class="text-2xl sm:text-3xl font-black text-slate-900 mb-2 tracking-tight">Profile Pre-Approved</h3>
                                <p class="text-slate-500 text-xs sm:text-sm">Provide details to schedule a confidential strategy call.</p>
                            </div>
                            <form id="lead-form" class="space-y-3.5 w-full">
                                <div>
                                    <label for="parent_name" class="block text-[9px] font-bold text-slate-500 uppercase tracking-widest mb-1 ml-1">Parent's Name</label>
                                    <input type="text" id="parent_name" name="parent_name" autocomplete="name" placeholder="e.g. Dr. Rajesh Sharma" class="w-full bg-slate-50 border border-slate-200 rounded-lg px-4 py-3 text-slate-900 text-sm placeholder-slate-400 focus:outline-none focus:border-slate-900 focus:bg-white transition-all shadow-inner" required>
                                </div>
                                <div>
                                    <label for="phone" class="block text-[9px] font-bold text-slate-500 uppercase tracking-widest mb-1 ml-1">WhatsApp Number</label>
                                    <input type="tel" id="phone" name="phone" autocomplete="tel" placeholder="+91" class="w-full bg-slate-50 border border-slate-200 rounded-lg px-4 py-3 text-slate-900 text-sm placeholder-slate-400 focus:outline-none focus:border-slate-900 focus:bg-white transition-all shadow-inner" required>
                                </div>
                                <button type="submit" class="w-full mt-2 bg-slate-900 hover:bg-slate-800 text-white px-6 py-3.5 rounded-lg text-sm font-black transition-all shadow-lg active:scale-[0.98] flex items-center justify-center gap-2">
                                    Secure Consultation
