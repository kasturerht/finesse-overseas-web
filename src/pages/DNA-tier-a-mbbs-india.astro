<script>
    const initMasterLogic = () => {
        window.dataLayer = window.dataLayer || [];

        // Single Source of Truth for Data
        const data = { course: '', score: '', category: '', specializations: [], tag: '' };

        // Helper: Safe Value Setter
        const safeSet = (id, val) => {
            const el = document.getElementById(id);
            if(el) el.value = val;
        };

        // UI Helpers
        const d1 = document.getElementById('split-dot-1');
        const d2 = document.getElementById('split-dot-2');
        const d3 = document.getElementById('split-dot-3');

        const updateDots = (step) => {
            if(!d1 || !d2 || !d3) return;
            d1.className = step >= 1 ? 'h-1.5 flex-grow bg-slate-900 rounded-full transition-colors duration-500' : 'h-1.5 flex-grow bg-slate-100 rounded-full transition-colors duration-500';
            d2.className = step >= 2 ? 'h-1.5 flex-grow bg-slate-900 rounded-full transition-colors duration-500' : 'h-1.5 flex-grow bg-slate-100 rounded-full transition-colors duration-500';
            d3.className = step >= 3 ? 'h-1.5 flex-grow bg-emerald-500 rounded-full transition-colors duration-500' : 'h-1.5 flex-grow bg-slate-100 rounded-full transition-colors duration-500';
            
            if(step === 'reject') {
                d1.className = 'h-1.5 flex-grow bg-blue-500 rounded-full transition-colors duration-500';
                d2.className = 'h-1.5 flex-grow bg-blue-500 rounded-full transition-colors duration-500';
                d3.className = 'h-1.5 flex-grow bg-blue-500 rounded-full transition-colors duration-500';
            }
        };

        const switchStep = (currentId, nextId, direction, dotLevel) => {
            const current = document.getElementById(currentId);
            const next = document.getElementById(nextId);
            if(!current || !next) return;
            
            current.classList.remove('step-active');
            if(direction === 'forward') {
                current.classList.add('step-hide-left');
                next.classList.remove('step-hide-left');
                next.classList.add('step-hide-right');
            } else {
                current.classList.add('step-hide-right');
                next.classList.remove('step-hide-right');
                next.classList.add('step-hide-left');
            }
            
            void next.offsetWidth; // Force CSS Reflow
            next.classList.remove('step-hide-left', 'step-hide-right');
            next.classList.add('step-active');
            
            if(dotLevel) updateDots(dotLevel);
        };

        // --- EVENT LISTENERS ---

        // 1. Course Selection
        document.querySelectorAll('.course-btn').forEach(btn => {
            btn.addEventListener('click', (e) => {
                e.preventDefault(); 
                data.course = e.currentTarget.getAttribute('data-val');
                safeSet('hidden_course', data.course);
                
                if(data.course === 'MD') {
                    switchStep('step-course', 'step-pg-score', 'forward', 2);
                } else {
                    switchStep('step-course', 'step-ug-score', 'forward', 2);
                }
            });
        });

        // 2A. UG Score Selection
        document.querySelectorAll('.ug-score-btn').forEach(btn => {
            btn.addEventListener('click', (e) => {
                e.preventDefault();
                data.score = e.currentTarget.getAttribute('data-val');
                safeSet('hidden_score', data.score);

                if(data.score === 'Below 200') {
                    window.dataLayer.push({ 'event': 'lead_rejected_low_score' });
                    switchStep('step-ug-score', 'step-reject', 'forward', 'reject');
                } else if(data.score === '450+') {
                    data.tag = 'Merit Counseling';
                    safeSet('hidden_tag', data.tag);
                    safeSet('hidden_category', 'N/A');
                    switchStep('step-ug-score', 'step-lead', 'forward', 3);
                } else {
                    data.tag = 'Management Quota Target';
                    safeSet('hidden_tag', data.tag);
                    switchStep('step-ug-score', 'step-ug-category', 'forward', 2.5);
                }
            });
        });

        // 3A. UG Category Selection
        document.querySelectorAll('.cat-btn').forEach(btn => {
            btn.addEventListener('click', (e) => {
                e.preventDefault();
                data.category = e.currentTarget.getAttribute('data-val');
                safeSet('hidden_category', data.category);
                switchStep('step-ug-category', 'step-lead', 'forward', 3);
            });
        });

        // 2B. PG Score Manual Input Next
        const btnNextPg = document.getElementById('btn-next-pg-spec');
        if(btnNextPg) {
            btnNextPg.addEventListener('click', (e) => {
                e.preventDefault();
                const scoreInput = document.getElementById('pg-score-input')?.value;
                if(!scoreInput) { alert("Please enter expected PG score."); return; }
                data.score = scoreInput;
                safeSet('hidden_score', data.score);
                switchStep('step-pg-score', 'step-pg-spec', 'forward', 2.5);
            });
        }

        // 3B. PG Specialization Tags
        document.querySelectorAll('.spec-btn').forEach(btn => {
            btn.addEventListener('click', (e) => {
                e.preventDefault();
                const spec = e.currentTarget.getAttribute('data-val');
                e.currentTarget.classList.toggle('spec-selected');
                
                if(data.specializations.includes(spec)) {
                    data.specializations = data.specializations.filter(item => item !== spec);
                } else {
                    data.specializations.push(spec);
                }
            });
        });

        // PG Final Proceed Button
        const btnFinalPg = document.getElementById('btn-final-pg');
        if(btnFinalPg) {
            btnFinalPg.addEventListener('click', (e) => {
                e.preventDefault();
                if(data.specializations.length === 0) { alert("Please select at least one specialization."); return; }
                safeSet('hidden_spec', data.specializations.join(", "));
                data.tag = 'MD/MS Prospect';
                safeSet('hidden_tag', data.tag);
                switchStep('step-pg-spec', 'step-lead', 'forward', 3);
            });
        }

        // Universal Back Button Logic
        document.querySelectorAll('.back-btn').forEach(btn => {
            btn.addEventListener('click', (e) => {
                e.preventDefault();
                const targetId = e.currentTarget.getAttribute('data-back');
                const dotLevel = e.currentTarget.getAttribute('data-dot');
                const currentId = e.currentTarget.closest('.step-container')?.id;
                
                if(!currentId) return;

                if(targetId === 'dynamic') {
                    if(data.course === 'MD') switchStep(currentId, 'step-pg-spec', 'backward', 2.5);
                    else if(data.score === '450+') switchStep(currentId, 'step-ug-score', 'backward', 2);
                    else switchStep(currentId, 'step-ug-category', 'backward', 2.5);
                } else {
                    switchStep(currentId, targetId, 'backward', dotLevel);
                }
            });
        });

        // WEB3FORMS FINAL SUBMIT (Lead Capture)
        const leadForm = document.getElementById('lead-form');
        if(leadForm) {
            leadForm.addEventListener('submit', async (e) => {
                e.preventDefault(); 
                const submitBtn = leadForm.querySelector('button[type="submit"]');
                if(!submitBtn) return;
                
                const originalText = submitBtn.innerHTML;
                submitBtn.innerHTML = 'Securing Protocol... ⏳';
                
                safeSet('hidden_subject', `🚨 NEW ${data.course} LEAD - ${data.tag}`);
                
                const formData = new FormData(leadForm);

                try {
                    const response = await fetch('https://api.web3forms.com/submit', { method: 'POST', body: formData });
                    const result = await response.json();
                    
                    if (result.success) {
                        switchStep('step-lead', 'step-success', 'forward', 3); 
                        window.dataLayer.push({ 'event': 'lead_submitted', 'course': data.course, 'lead_type': data.tag });
                    } else {
                        alert("System busy. Please try again.");
                        submitBtn.innerHTML = originalText;
                    }
                } catch (error) {
                    alert("Network error. Please check connection.");
                    submitBtn.innerHTML = originalText;
                }
            });
        }

        // --- UI EFFECTS (Spotlight & Tilt) ---
        if(window.matchMedia("(min-width: 768px)").matches) {
            const cards = document.querySelectorAll('.spotlight-card');
            cards.forEach(card => {
                card.addEventListener('mousemove', e => {
                    const rect = card.getBoundingClientRect();
                    card.style.setProperty('--mouse-x', `${e.clientX - rect.left}px`);
                    card.style.setProperty('--mouse-y', `${e.clientY - rect.top}px`);
                });
            });

            const tiltCards = document.querySelectorAll('.tilt-card');
            tiltCards.forEach(card => {
                const glare = card.querySelector('.glare-layer');
                card.addEventListener('mousemove', (e) => {
                    const rect = card.getBoundingClientRect();
                    const x = e.clientX - rect.left; 
                    const y = e.clientY - rect.top;  
                    const rotateX = ((y - rect.height / 2) / (rect.height / 2)) * -10;
                    const rotateY = ((x - rect.width / 2) / (rect.width / 2)) * 10;
                    card.style.transform = `rotateX(${rotateX}deg) rotateY(${rotateY}deg)`;
                    if(glare) glare.style.background = `radial-gradient(circle at ${x}px ${y}px, rgba(255,255,255,0.08), transparent 50%)`;
                });
                card.addEventListener('mouseleave', () => {
                    card.style.transform = `rotateX(0deg) rotateY(0deg)`;
                    if(glare) glare.style.background = `radial-gradient(circle at 50% 50%, rgba(255,255,255,0), transparent 50%)`;

                    
                });
            });
        }

        const waBtn = document.getElementById('wa-float-btn');
        if(waBtn) {
            waBtn.addEventListener('click', () => {
                window.dataLayer.push({ 
                    'event': 'whatsapp_click', 
                    'page_name': 'Tier-A MBBS India' 
                });
            });
        }
    };

    // Re-initialize for Astro ViewTransitions
    initMasterLogic();
    document.addEventListener('astro:page-load', initMasterLogic);
    
</script>

<script is:inline>
  window.addEventListener('load', () => {
    // १. मोबाईल चेक (मोबाईलवर स्पीडसाठी इंजिन बंद)
    if (window.innerWidth < 768) {
        const canvas = document.getElementById('dna-canvas');
        if(canvas) canvas.style.display = 'none';
        return; 
    }
    // २. डेस्कटॉपवर १.२ सेकंद थांबा (Lighthouse साठी)
    setTimeout(initDNAEngine, 1200); 
  });

  function initDNAEngine() {
    const canvas = document.getElementById('dna-canvas');
    const placeholder = document.getElementById('dna-placeholder');
    if (!canvas) return;
    const ctx = canvas.getContext('2d', { alpha: true });

    const setCanvasSize = () => {
        const rect = canvas.parentElement.getBoundingClientRect();
        canvas.width = rect.width * 2;
        canvas.height = rect.height * 2;
        ctx.scale(2, 2);
    };
    setCanvasSize();
    window.addEventListener('resize', setCanvasSize);

    // Sprite Caching (Calculations वाचवण्यासाठी)
    const createBallSprite = (color) => {
        const sCanvas = document.createElement('canvas');
        sCanvas.width = 40; sCanvas.height = 40;
        const sCtx = sCanvas.getContext('2d');
        sCtx.shadowBlur = 10;
        sCtx.shadowColor = color;
        sCtx.fillStyle = color;
        sCtx.beginPath();
        sCtx.arc(20, 20, 2.5, 0, Math.PI * 2);
        sCtx.fill();
        return sCanvas;
    };

    const emeraldSprite = createBallSprite('#10B981');
    const amberSprite = createBallSprite('#F59E0B');

    const particles = [];
    const numParticles = 120; 
    const radius = 60; 
    const ySpacing = 6; 
    let rotation = 0;

    for (let i = 0; i < numParticles; i++) {
        const y = i * ySpacing - (numParticles * ySpacing) / 2;
        const angle = i * 0.2;
        particles.push({ y, baseAngle: angle, sprite: emeraldSprite, type: 'strandA', pairId: i });
        particles.push({ y, baseAngle: angle + Math.PI, sprite: amberSprite, type: 'strandB', pairId: i });
    }

    let mouse = { x: 9999, y: 9999 };
    document.addEventListener('mousemove', (e) => {
        const rect = canvas.getBoundingClientRect();
        mouse.x = e.clientX - rect.left;
        mouse.y = e.clientY - rect.top;
    });

    let isVisible = true;
    const observer = new IntersectionObserver((entries) => {
        isVisible = entries[0].isIntersecting;
    }, { threshold: 0.1 });
    observer.observe(canvas);

    const render = () => {
        if (!isVisible) { requestAnimationFrame(render); return; }
        ctx.clearRect(0, 0, canvas.width, canvas.height);
        const centerX = canvas.width / 4;
        const centerY = canvas.height / 4;
        rotation += 0.005;

        const projected = particles.map(p => {
            const currentAngle = p.baseAngle + rotation;
            const x3d = Math.cos(currentAngle) * radius;
            const z3d = Math.sin(currentAngle) * radius;
            const scale = 250 / (250 + z3d);
            const x2d = centerX + x3d * scale;
            const y2d = centerY + p.y * scale;

            const dx = mouse.x - x2d;
            const dy = mouse.y - y2d;
            const distSq = dx*dx + dy*dy;
            let repelX = 0, repelY = 0;
            if (distSq < 6400) {
                const dist = Math.sqrt(distSq);
                const force = (80 - dist) / 80;
                repelX = -(dx / dist) * force * 20;
                repelY = -(dy / dist) * force * 20;
            }
            return { ...p, x2d: x2d + repelX, y2d: y2d + repelY, z3d, scale };
        });

        ctx.lineWidth = 0.5;
        ctx.strokeStyle = 'rgba(255, 255, 255, 0.1)';
        for (let i = 0; i < numParticles; i += 2) {
            const pA = projected.find(p => p.type === 'strandA' && p.pairId === i);
            const pB = projected.find(p => p.type === 'strandB' && p.pairId === i);
            if (pA && pB) {
                ctx.beginPath();
                ctx.moveTo(pA.x2d, pA.y2d);
                ctx.lineTo(pB.x2d, pB.y2d);
                ctx.stroke();
            }
        }

        projected.sort((a, b) => b.z3d - a.z3d);
        projected.forEach(p => {
            const size = 40 * p.scale;
            ctx.globalAlpha = Math.max(0.2, p.scale);
            ctx.drawImage(p.sprite, p.x2d - size/2, p.y2d - size/2, size, size);
        });
        
        ctx.globalAlpha = 1;
        requestAnimationFrame(render);
    };

    // Transition: Glow घालवा आणि DNA दाखवा
    canvas.style.transition = 'opacity 1.5s ease-in-out';
    canvas.style.opacity = '1';
    if(placeholder) {
        placeholder.style.transition = 'opacity 1s ease-out';
        placeholder.style.opacity = '0';
    }
    render();

    // Toggle Logic
    const btnIndia = document.getElementById('btn-target-india');
    const btnAbroad = document.getElementById('btn-fallback-abroad');
    const highlight = document.getElementById('toggle-highlight');
    const desc = document.getElementById('hero-description');

    if(btnIndia && btnAbroad && highlight && desc) {
        btnIndia.addEventListener('click', () => {
            highlight.style.transform = 'translateX(0)';
            highlight.className = 'absolute left-1 top-1 bottom-1 w-[160px] bg-emerald-500/20 border border-emerald-500/30 rounded-lg transition-transform duration-500 ease-out';
            btnIndia.className = 'relative z-10 w-[160px] py-2.5 text-emerald-400 text-xs font-black uppercase tracking-widest transition-colors';
            btnAbroad.className = 'relative z-10 w-[160px] py-2.5 text-slate-500 hover:text-white text-xs font-black uppercase tracking-widest transition-colors';
            desc.innerHTML = `Medical success is not random. It's engineered. We decode complex Tier-A private medical admissions strictly through legally audited Management & NRI channels. <strong class="text-white block mt-2">Zero Agents. 100% Direct. Strictly ₹1.2 Cr+.</strong>`;
        });

        btnAbroad.addEventListener('click', () => {
            highlight.style.transform = 'translateX(100%)';
            highlight.className = 'absolute left-1 top-1 bottom-1 w-[160px] bg-blue-500/20 border border-blue-500/30 rounded-lg transition-transform duration-500 ease-out';
            btnAbroad.className = 'relative z-10 w-[160px] py-2.5 text-blue-400 text-xs font-black uppercase tracking-widest transition-colors';
            btnIndia.className = 'relative z-10 w-[160px] py-2.5 text-slate-500 hover:text-white text-xs font-black uppercase tracking-widest transition-colors';
            desc.innerHTML = `If Indian budgets don't align, our blueprint extends globally. We secure admissions in World-class Government Medical Universities Abroad as a secure, affordable fallback option. <strong class="text-white block mt-2">NMC Approved. 100% English Taught.</strong>`;
        });
    }
  }
</script>