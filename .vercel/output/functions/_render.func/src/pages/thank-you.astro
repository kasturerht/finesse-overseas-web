---
// src/pages/thank-you.astro
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import WhatsAppWidget from '../components/WhatsAppWidget.astro';

const title = "Request Received | Finesse Overseas Education";
const description = "Thank you for contacting Finesse Overseas Education. Our experts will be in touch with you shortly.";
---

<Layout title={title} description={description}>
  <Header />

  <script is:inline>
    // This script ensures that when a user lands here, Meta Ads counts it as a successful 'Lead'
    document.addEventListener('DOMContentLoaded', () => {
      if (typeof fbq === 'function') {
        fbq('track', 'Lead');
      } else {
        console.log("Meta Pixel not loaded yet, but Lead event is ready to fire.");
      }
    });
  </script>

  <section class="flex flex-col items-center justify-center bg-slate-50 py-20 lg:py-32 relative overflow-hidden">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,_var(--tw-gradient-stops))] from-teal-50 via-white to-white opacity-80 z-0"></div>

    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 text-center">
      
      <div class="mb-8 flex justify-center">
        <div class="w-24 h-24 bg-teal-100 rounded-full flex items-center justify-center shadow-lg shadow-teal-100/50 animate-bounce-slow">
          <div class="w-16 h-16 bg-teal-500 rounded-full flex items-center justify-center text-white">
            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path>
            </svg>
          </div>
        </div>
      </div>

      <h1 class="text-4xl md:text-5xl font-extrabold text-slate-900 mb-6 tracking-tight">
        You've Taken the <span class="text-teal-600">First Step!</span>
      </h1>
      
      <p class="text-lg text-slate-600 mb-10 max-w-xl mx-auto leading-relaxed">
        Thank you for reaching out. We have received your details. Our expert counselors are currently reviewing your profile for top-tier European universities.
      </p>

      <div class="bg-white rounded-2xl p-6 md:p-8 shadow-xl border border-slate-100 mb-10 max-w-2xl mx-auto text-left">
        <h3 class="text-xl font-bold text-slate-800 mb-4 border-b border-slate-100 pb-3">What happens next?</h3>
        <ul class="space-y-4">
          <li class="flex items-start gap-3">
            <div class="w-6 h-6 rounded-full bg-teal-100 text-teal-600 flex items-center justify-center shrink-0 mt-0.5 font-bold text-sm">1</div>
            <p class="text-slate-600">You will receive a call or WhatsApp message from our experts within <span class="font-semibold text-slate-900">24 hours</span>.</p>
          </li>
          <li class="flex items-start gap-3">
            <div class="w-6 h-6 rounded-full bg-teal-100 text-teal-600 flex items-center justify-center shrink-0 mt-0.5 font-bold text-sm">2</div>
            <p class="text-slate-600">We will discuss your academic background and map it to Tuition-Free programs in Germany or 100% Scholarships in Italy.</p>
          </li>
          <li class="flex items-start gap-3">
            <div class="w-6 h-6 rounded-full bg-slate-100 text-slate-400 flex items-center justify-center shrink-0 mt-0.5 font-bold text-sm">3</div>
            <p class="text-slate-600">We start processing your APS and university applications with zero delays.</p>
          </li>
        </ul>
      </div>

      <div class="flex flex-col sm:flex-row gap-4 justify-center relative z-20">
        <a href="/" class="relative z-20 px-8 py-4 bg-slate-900 hover:bg-slate-800 text-white font-bold rounded-xl transition-all shadow-md">
          Back to Home
        </a>
        <a href="https://wa.me/+919850069600" target="_blank" rel="noopener noreferrer" class="relative z-20 px-8 py-4 bg-teal-50 hover:bg-teal-100 text-teal-700 font-bold rounded-xl transition-all border border-teal-200 flex items-center justify-center gap-2">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 00-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
          Chat on WhatsApp
        </a>
      </div>

    </div>
  </section>

  <Footer />
  <WhatsAppWidget />
</Layout>

<style>
  .animate-bounce-slow {
    animation: bounce 3s infinite;
  }
  @keyframes bounce {
    0%, 100% { transform: translateY(-5%); animation-timing-function: cubic-bezier(0.8,0,1,1); }
    50% { transform: none; animation-timing-function: cubic-bezier(0,0,0.2,1); }
  }
</style>