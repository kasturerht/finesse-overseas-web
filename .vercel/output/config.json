{
	"version": 3,
	"routes": [
		{
			"handle": "filesystem"
		},
		{
			"src": "^/media/(.*)$",
			"headers": {
				"cache-control": "public, max-age=31536000, immutable"
			},
			"continue": true
		},
		{
			"src": "^/_server-islands/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/_image/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/config\\.yml$",
			"dest": "_render"
		},
		{
			"src": "^/admin/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/keystatic(?:/(.*?))?/?$",
			"dest": "_render"
		},
		{
			"src": "^/contact/?$",
			"dest": "_render"
		},
		{
			"src": "^/germany-admission/?$",
			"dest": "_render"
		},
		{
			"src": "^/germany-admission01/?$",
			"dest": "_render"
		},
		{
			"src": "^/Invitation/?$",
			"dest": "_render"
		},
		{
			"src": "^/keystatic(?:/(.*?))?/?$",
			"dest": "_render"
		},
		{
			"src": "^/mbbs-India-abroad/?$",
			"dest": "_render"
		},
		{
			"src": "^/oauth/callback/?$",
			"dest": "_render"
		},
		{
			"src": "^/oauth/?$",
			"dest": "_render"
		},
		{
			"src": "^/presentation/?$",
			"dest": "_render"
		},
		{
			"src": "^/study-in-austria/?$",
			"dest": "_render"
		},
		{
			"src": "^/study-in-germany/?$",
			"dest": "_render"
		},
		{
			"src": "^/study-in-italy/?$",
			"dest": "_render"
		},
		{
			"src": "^/study-in-uk-usa/?$",
			"dest": "_render"
		},
		{
			"src": "^/terms-and-conditions/?$",
			"dest": "_render"
		},
		{
			"src": "^/thank-you/?$",
			"dest": "_render"
		},
		{
			"src": "^/$",
			"dest": "_render"
		},
		{
			"src": "^/404/?$",
			"dest": "_render"
		},
		{
			"src": "^/.*$",
			"dest": "_render",
			"status": 404
		}
	]
}